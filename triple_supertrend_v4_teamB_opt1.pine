var float notS3 = 0.0

inLong  = strategy.position_size > 0
inShort = strategy.position_size < 0
inPos   = strategy.position_size != 0
posSize = math.abs(strategy.position_size)
avgPx   = strategy.position_avg_price

// ?箏蝯?敺??單飛?塚?瘨迨??銝?鞈港?銝璉辣?莎?
//   entryBar ?寥?蝵桃 na嚗?a)?撟喳摰?蔭??霈???嚗?b)timeStop 隞?na(entryBar) 摰?嚗?//   ?? bar_index-0 撠厭???啁征?炊閮???if not inPos
    l1On := false
    l2On := false
    l3On := false
    s1On := false
    s2On := false
    s3On := false
    entryRisk := na
    entryPx   := na
    entryBar  := na
    trailExt  := na
    trailStop := na
    tp1Done   := false
    tp2Done   := false
    peakR     := 0.0
    peakBar   := bar_index  // ?趙閮??冽飛???∪?撠??嗅?璉?銝活?脣??撖?
    bankedQty := 0.0
    openInitQty := 0.0
    fadeArmed := true
    voteFadeArmed := true   // [F2] ?典像?蔭甇西?(銝活??閫貊銝◤??
    dvArmed := true         // [G2] ?典像?蔭甇西?
    lastAddBar := -100000   // ??????蔭(銝活擐銝◤?餅?)
    notL1 := 0.0
    notL2 := 0.0
    notL3 := 0.0
    notS1 := 0.0
    notS2 := 0.0
    notS3 := 0.0

longStage  = (l1On?1:0) + (l2On?1:0) + (l3On?1:0)
shortStage = (s1On?1:0) + (s2On?1:0) + (s3On?1:0)
stage = inLong ? longStage : inShort ? shortStage : 0   // 璉??潘??? 禮9 ?典像閫貊(reductions ??雿輻

// ????????????????????????????????????????????????????????????????????????????
// 禮7  ??閮?嚗T-Core嚗僑?郭?璅? ??? ??蝮賣?獢?clamp ??qty嚗?//     qty = (targetVol / instVolAnn) * equity * weight / close
//     ?Ⅳ撅斗????clamp(er/erThr,0.5,1.0)嚗R 靽∪艙??
// ????????????????????????????????????????????????????????????????????????????
// 頝臬?靘陷?嚗??鞈?像皛?equity 瘛瑕?雿 sizing ?箸?嚗?銴頝臬??曉之??// 瘛瑕?靽 eqBlendInit / eqBlendSmooth 撌脫??脩?航矽 input(???0.5 / 0.99)??var float avgEq = na
avgEq := na(avgEq) ? strategy.equity : avgEq * eqBlendSmooth + strategy.equity * (1.0 - eqBlendSmooth)
sizeBase = eqBlendInit * strategy.initial_capital + (1.0 - eqBlendInit) * avgEq

// vol-target 瘥?嚗?????摰????改?瘥?=1嚗?vtScale = useVolTarget ? targetVol / instVolAnn : 1.0
// ER 靽∪艙靽嚗??嚗lamp 0.5~1.0嚗????冽?Ⅳ撅?L2/L3嚗???L1 銝葬??convMult = useConvAdd and erThr > 0 ? math.min(math.max(er / erThr, 0.5), 1.0) : 1.0
wL2eff = wL2 * convMult
wL3eff = wL3 * convMult
totW    = wL1 + wL2 + wL3          // 蝮賣?獢踹??誑?甈?(銝靽∪艙蝮格)?箏皞?靽?銝?蝛拙?
var int capHits = 0

// ?桐??箏嚗策摰惜甈? ???格?? ???府撅文???瑽▼銝? clamp ??qty(??/?aN)
qtyFor(w) =>
    float notion = vtScale * sizeBase * w
    // 閰脣惜???啁??銝?嚗蜇瑽▼???格???靘???
    float nCap = totW > 0 ? sizeBase * maxGross * (w / totW) : sizeBase * maxGross
    bool  capped = notion > nCap
    notion := math.min(notion, nCap)
    float q = close > 0 ? notion / close : 0.0
    q := math.max(nz(q, 0.0), 0.0)
    [q, capped]

[qty1, cap1] = qtyFor(wL1)
[qty2, cap2] = qtyFor(wL2eff)
[qty3, cap3] = qtyFor(wL3eff)

// ????????????????????????????????????????????????????????????????????????????
// 禮8  R-multiple ??Chandelier ratchet ??嚗?蝛粹??only-up / only-down嚗?//     R ?? = entryRisk嚗脣??銋?chandMult?atrChand ??甇Ｘ?頝嚗?//     entryPx/rBasePx 銋 L1 敹 L2/L3 ?券?游??◤閫詨?嚗 ?摰祕摮敹?// ????????????????????????????????????????????????????????????????????????????
rDenom  = na(entryRisk) ? (chandMult * atrChand) : entryRisk   // ?祕??甇Ｘ?頝
rBasePx = na(entryPx)   ? avgPx : entryPx
R = inPos and rDenom > 0 ? (inLong ? (close - rBasePx) / rDenom : (rBasePx - close) / rDenom) : 0.0
// ?湔? high-water R嚗?脖??嚗ot inPos 撌脫 禮6 甇賊嚗?//   ?瑟撜啣澆?璉???peakBar嚗??箄隅?Ｗ僑朣??趙閮??函??箸???if inPos
    if R > peakR
        peakR   := R
        peakBar := bar_index   // ?瑟 high-water R ???蔭?趙閮?
// 撜啣澆?皛舀??賂?頝?甈∪??peakR 撌脤?撟暹?嚗??∪???0
barsSincePeak = inPos ? math.max(bar_index - peakBar, 0) : 0

// ?? R ?０?嚗祝?葉??嚗隤踵蝺???曉之?喳偏??瑕椰撠橘???
//   ?箇?銝?嚗<1 撖?=??mult)??~2 銝准?2 蝺?multStepBase = not useRStep ? chandMult : (R < 1 ? chandMult : R < 2 ? trailMidR : trailTightR)
multStep = multStepBase
// 瘜Ｗ??芷?蜓 trail嚗?銝?蝺?(R>=1嚗歇?ａ???撖祆?)隞交郭???芷?凝隤踴?//   ?澆靘?嚗?閮剛???breathClamp(relVol/brakeK)嚗??賊??????breathPctl
//   (atrPct ?曉?雿?銝１ brakeK)??瘜Ｗ? ??靽?? ??蝬剜??嗥?嚗?瘜Ｗ? ???曉祝??//   clamp ??[trailTightR, chandMult] 蝬剜??株矽??trailBreath = effDecorrGauge ? breathPctl : breathClamp
if effBreathTrail and useRStep and inPos and R >= 1
    float bt = multStepBase * trailBreath
    multStep := math.min(math.max(bt, trailTightR), chandMult)
// 憭偕摨行???游漲 ratchet嚗誑銝偕摨行??瑽?撖思蜓 trail 擛?(?郭?蜓 trail ??蝺?????//   coherence==3(?典????亙熒) ???曉祝 cohRelaxK(銝? chandMult) 蝯行?憭批?賂?
//   coherence<=1(敹思葉撠箏漲?) ???嗅?蝺? trailTightR ???嚗oherence==2 ??銝???if effCoherenceTrail and useRStep and inPos and R >= 1
    int coh = inLong ? coherenceLong : coherenceShort
    if coh >= 3
        multStep := math.min(multStep * cohRelaxK, chandMult)
    else if coh <= 1
        multStep := math.min(multStep, trailTightR)

// TP1 ?質?敺??詨??撥?嗡??穿?蝑??BE 閫貊??歇?質????
beActive = (useBE and R >= kBE) or (useBEonTP1 and tp1Done)

// ?? 瘜Ｗ??芷????嚗ffGiveback = multBE ? clamp(relVol,1.0,brakeK) ??
//   銴 relVol(禮4)/brakeK/multBE嚗?啣? input??瘜Ｗ??曉祝??(?踹???)??//   雿郭?蝺????憭瞏????澆??摰?givebackR=multBE??breathMult = effBreathGB ? breathClamp : 1.0
// 頞典撟湧翩??趙?嗥?嚗陸?澆?皛航?銋???????撠??唳頞?)嚗?憭??stallShrinkMin ??//   stallShrink = clamp(1 ??barsSincePeak/timeStopBars, stallShrinkMin, 1.0)??//   閮剛??牧嚗ong-since-new-high ?舫??函???銵啁垠???雁摨西????郭??撌脣祕?曄??甇?漱??stallFrac   = barsSincePeak * 1.0 / math.max(timeStopBars, 1)   // 撘瑕 float ?斗?嚗??豢??stallShrink = effStallRatchet and timeStopBars > 0 ? math.min(math.max(1.0 - stallFrac, stallShrinkMin), 1.0) : 1.0
effGiveback= multBE * breathMult * stallShrink
// Peak-R ???唳嚗???peakR 撌脩?銝?effGiveback 銋??????踹????????//   ?銋??ffPeakRatchet 撌脣 usePureA??peakFloorOn= effPeakRatchet and inPos and peakR > effGiveback

// ?? TP ?０撘??砍?選?瘥鋡?畾萄?蹂???multBE?rDenom ??
//   stairRungs嚗歇?質?畾菜(TP1???P2??)嚗??= rBasePx 簣 stairRungs?multBE?rDenom??//   ??peakR ????唳 / BE ?唳 / R ?０ 銝敺?math.max/min ??蝺???multBE/tp ????stairRungs   = (tp1Done ? 1 : 0) + (tp2Done ? 1 : 0)
tpStairOn    = effTPstair and inPos and stairRungs > 0
tpStairFloorL= rBasePx + stairRungs * multBE * rDenom
tpStairFloorS= rBasePx - stairRungs * multBE * rDenom

// ?? 撌脣祕?曄?拚靽?唳嚗ankFrac=bankedQty/openInitQty嚗??rBasePx簣bankFrac?rDenom ??
//   ?餌? multBE(銝１)嚗?歇?質???憪蜇?瘥???交撠敹?雿??拐???//   bankFrac?0,1] ???唳?憭??rBasePx+1?rDenom(=+1R)嚗迤瘥撌脣祕?暹?靘??株矽銝宏??bankFrac      = openInitQty > 1e-9 ? math.min(bankedQty / openInitQty, 1.0) : 0.0
bankedFloorOn = effBankedFloor and inPos and bankFrac > 1e-9
bankedFloorL  = rBasePx + bankFrac * rDenom
bankedFloorS  = rBasePx - bankFrac * rDenom

// ?? [NEW-A1] 頝典偕摨?ATR ?折?甇Ｘ?撠箏漲?唳嚗??beActive 敺敹??剁?憭征?∪?嚗??
//   閮剛??牧嚗敹??Ｗ偕摨西隅?ｇ??Ｚ隅?Ｘ迤撣詨?詨?摨阡?憭扳敹怠偕摨?atrChand嚗敹?ATR 閮?trail
//   ? low-vol pocket ?敹?亙熒??銝剜??箝璈??trail ??ATR 撠箏漲?寧
//   atrScale=max(atrChand, |close?t3|)?誑?Ｗ偕摨?ST3 band 撖砍漲雿?瑼◢?芣?撠偕摨血?選?雿踹??//   蝛粹??典??詨??祕??撅祆??偕摨艾?曉之 rawStop(撠箏漲?唳)?atchet 隞?霅?trailStop ?芷脖??嚗?//   銝憭批?憪?R(beActive ??雿)????st3/atrChand ?嗆憓?input?? breathPctl(??雿蔭)甇?漱??st3Band   = na(st3) ? 0.0 : math.abs(close - st3)
atrScaleX = effMultiScaleStop and beActive ? math.max(atrChand, st3Band) : atrChand

if useChandelier and inLong
    trailExt  := na(trailExt) ? high : math.max(trailExt, high)
    rawStop    = trailExt - multStep * atrScaleX
    trailStop := na(trailStop) ? rawStop : math.max(trailStop, rawStop)   // ratchet ?芷脖??
    if beActive
        trailStop := math.max(trailStop, rBasePx + multBE * rDenom)
    if tpStairOn
        trailStop := math.max(trailStop, tpStairFloorL)                   // ?０?唳
    if bankedFloorOn
        trailStop := math.max(trailStop, bankedFloorL)                    // 撌脣祕?曄?拚?唳
    if peakFloorOn
        trailStop := math.max(trailStop, rBasePx + (peakR - effGiveback) * rDenom)   // ?澆/撟湧翩????唳
else if useChandelier and inShort
    trailExt  := na(trailExt) ? low : math.min(trailExt, low)
    rawStop    = trailExt + multStep * atrScaleX
    trailStop := na(trailStop) ? rawStop : math.min(trailStop, rawStop)   // ratchet ?芷脖??
    if beActive
        trailStop := math.min(trailStop, rBasePx - multBE * rDenom)
    if tpStairOn
        trailStop := math.min(trailStop, tpStairFloorS)                   // ?０?唳(?∪?)
    if bankedFloorOn
        trailStop := math.min(trailStop, bankedFloorS)                    // 撌脣祕?曄?拚?唳(?∪?)
    if peakFloorOn
        trailStop := math.min(trailStop, rBasePx - (peakR - effGiveback) * rDenom)   // ?澆/撟湧翩????唳(?∪?)

// ????????????????????????????????????????????????????????????????????????????
// 禮9  ?箏閫貊嚗??蝔梧?頞典???箔蜓?箏嚗elowAvg ?孵?畾萎??舫?嚗?//     time-stop 璉靘?ER ?芷??effTimeStop = round(timeStopBars?clamp(er/erThr,0.5,1.0))
//     閮鳴??祆挾?典像閫貊??禮10 隞颱? reductions 銋?閰摯嚗?撘 禮6 璉? stage ??甇?Ⅱ??// ????????????????????????????????????????????????????????????????????????????
trailHitLong  = useChandelier and inLong  and not na(trailStop) and close < trailStop
trailHitShort = useChandelier and inShort and not na(trailStop) and close > trailStop
// ?賡摨?嚗翰+銝?ST ????嚗? ST 蝧餃?嚗?twoSTRevLong  = inLong  and st1Bear and st2Bear
twoSTRevShort = inShort and st1Bull and st2Bull
// ER ?芷??time-stop 璉嚗???er/erThr/timeStopBars嚗?啣? input嚗ffAdaptiveTS 撌脣 usePureA嚗?tsScale     = effAdaptiveTS and erThr > 0 ? math.min(math.max(er / erThr, 0.5), 1.0) : 1.0
effTimeStop = math.max(math.round(timeStopBars * tsScale), 1)
// timeStop ??not na(entryBar) 摰?(憭征撠迂)嚗ntryBar 撌脤?蝵桃 na ?厭???芷脣???閮?嚗?//   ?? (bar_index-0) ???鈭活撟喳?tsAge         = na(entryBar) ? 0 : (bar_index - entryBar)
timeStopLong  = useTimeStop and inLong  and not na(entryBar) and tsAge >= effTimeStop and R < 1 and stage < 3
timeStopShort = useTimeStop and inShort and not na(entryBar) and tsAge >= effTimeStop and R < 1 and stage < 3

// ????????????????????????????????????????????????????????????????????????????
// 禮10  銝?瑁?嚗??箏敺脣嚗?璉????喳?甇伐?
// ????????????????????????????????????????????????????????????????????????????
var bool exitedThisBar = false
exitedThisBar := false

// ?? ??摨??暑?????? stale 敹怎 ??
//   禮6 ??stage/posSize ?冽???????銝甈～蝔?????0 ??TP/cut/fade/belowAvg ???//   l*On/s*On 銝血祕?葬撠雿?隞?posLive 餈質馱???嗅??拚??其?(瘥活 drain 敺?文祕??鈭日? d)
//   雿???drain ??posAbs 銝? + TP ?質??箸嚗???stage-gate ?寧??fresh l*On/s*On
//   ?單????暑 stage嚗?????stale stage??var float posLive = 0.0
posLive := posSize   // 璉?隞亙祕?雿?憪?嚗?甈?drain 敺 global scope ??撖阡??漱??d

bool fullExitNow = false

// ????????????????????????????????????????????????????????????????????????????
// [intrabar hardstop ????芣晾 + ?箏?芸?摨??包 ????????????????????????????????
//   (a) ?隞??璉?committed ??trailStop?? strategy.exit(?脰歲蝛箇銝剜?鈭歹?銝?璉???嚗?//       ?餅?銝?摰?from_entry 雿踹?箸項???tranche ?擃雿????//   (b) ?支葉?漱?菜葫??敺?朣?璉?甇???? live stop = trailStop[1]??
//       brokerStopHit = (憭? low<=trailStop[1] / 蝛? high>=trailStop[1])??//   (c) 銝??brokerStopHit嚗??喟頝舀璉??????TP/cut/fade/belowAvg)?擗?斤Ⅱ隤?//       ?箏(閮?exitedThisBar/blockPartials=true)嚗???璉摮 hX ?典?鈭?蝯??找?????//   (d) ????單撅文? brokerStopHit ??銝剖董??蝵栽?歇?芾?撟喳?銝?璉?禮6 not inPos
//       ?芰摰?蔭(??entryBar:=na)嚗???璉?? stageLive==opentrades??// ????????????????????????????????????????????????????????????????????????????
// ?詨??祆??迤????live stop = 銝?璉?committed ??trailStop(trailStop[1])
liveStopLong  = useHardStop and inLong  and not na(trailStop[1])
liveStopShort = useHardStop and inShort and not na(trailStop[1])
// ?嚗??祆? committed ??trailStop 銝漱??蝝?????脰歲蝛綽?銝?璉??支葉?漱??)??if useHardStop and inLong and not na(trailStop)
    strategy.exit("hX-L", stop=trailStop, comment="HardStopL")
if useHardStop and inShort and not na(trailStop)
    strategy.exit("hX-S", stop=trailStop, comment="HardStopS")
// ?支葉?漱?菜葫嚗?朣?璉??? live stop(trailStop[1])
bool brokerStopHit = (liveStopLong and low <= trailStop[1]) or (liveStopShort and high >= trailStop[1])
// brokerStopHit ???祆??其?撌脩 hX ?典像?????剛楝?祆????砍惜皜??嗥蝣箄??箏(鈭)
bool blockPartials = brokerStopHit
if brokerStopHit
    exitedThisBar := true   // ?餅迫?祆?銝??蝥?close/close_all/?典?皜??詨?撌脣?像??
// ??銝餃??A嚗handelier trailStop嚗?斤Ⅱ隤? ??//   瘜冽?嚗rokerStopHit ??exitedThisBar 撌?true嚗???not exitedThisBar ?券?剛楝??if not exitedThisBar and trailHitLong
    strategy.close_all(comment="TrailL")
    fullExitNow := true
else if not exitedThisBar and trailHitShort
    strategy.close_all(comment="TrailS")
    fullExitNow := true

// ???箏 B嚗? ST ??摨? ??if not exitedThisBar and not fullExitNow and twoSTRevLong
    strategy.close_all(comment="2STrevL")
    fullExitNow := true
else if not exitedThisBar and not fullExitNow and twoSTRevShort
    strategy.close_all(comment="2STrevS")
    fullExitNow := true

// ???箏 C嚗???????if not exitedThisBar and not fullExitNow and (timeStopLong or timeStopShort)
    strategy.close_all(comment="TimeStop")
    fullExitNow := true

// [inline ?典像?蔭] ??單撅?close_all ?箏(trail/2ST/timeStop)閫貊嚗rokerStopHit 頝臬?
//   銝粥甇方?(?詨??芾?撟喳?銝?璉?禮6 ?芰?蔭)??//   撠迂?澆撘脣?瑕嚗ffCooldown=round(cooldownBars?clamp(relVol,1,brakeK))??if fullExitNow
    l1On := false
    l2On := false
    l3On := false
    s1On := false
    s2On := false
    s3On := false
    entryRisk := na
    entryPx   := na
    entryBar  := na         // 摰?蔭??entryBar:=na嚗?蝯?bar_index-0 瘙⊥?
    trailExt  := na
    trailStop := na
    tp1Done   := false
    tp2Done   := false
    peakR     := 0.0
    peakBar   := bar_index  // ?趙閮??冽飛??    bankedQty := 0.0
    openInitQty := 0.0
    fadeArmed := true
    voteFadeArmed := true   // [F2] ?典像?蔭甇西?
    dvArmed := true         // [G2] ?典像?蔭甇西?
    notL1 := 0.0
    notL2 := 0.0
    notL3 := 0.0
    notS1 := 0.0
    notS2 := 0.0
    notS3 := 0.0
    exitedThisBar := true
    float effCooldown = effAdaptiveCooldown ? math.max(math.round(cooldownBars * breathClamp), 0) : cooldownBars
    cooldownUntil := bar_index + effCooldown
    posLive := 0.0   // ?典像敺?璉擗雿飛?塚?敺? drain ??posAbs 銝???TP ?箸?喟 0

// ?? contiguous-stack ?臭?皜?隤?蝝撘?top-first drain + global-scope 閫???神嚗??
//   [Pine v5 蝖祉?? ?賢??找??舀撖怠?撅?scope var???寧蝝撘????撅文????典??誑
//   ??喳??霈?撠撘????賊?蝞???湔敺?[done, ?啣??捌?, ?啣?棺?] tuple嚗?//   ?迤???mutation 銝敺 global scope ?刻圾瑽釵?澆??trategy.close(id, qty=) ?澆撘
//   ????蝢抬?隞?newest-first(L3?2?1) ???摰?撅斗???撅扎畾???遣?典 bool嚗?//   銝?撘?l3On?2On?1On ??top-first ??蝡?drainLong(reqQty, posAbs, n3, n2, n1) =>
    float want = math.min(math.max(nz(reqQty, 0.0), 0.0), posAbs)
    float done = 0.0
    float r3 = n3
    float r2 = n2
    float r1 = n1
    if r3 > 1e-9 and want - done > 1e-9
        float take = math.min(want - done, r3)
        if take > 1e-9
            strategy.close("L3", qty=take, comment="cut-L3")
            r3   := r3 - take
            done := done + take
    if r2 > 1e-9 and want - done > 1e-9
        float take = math.min(want - done, r2)
        if take > 1e-9
            strategy.close("L2", qty=take, comment="cut-L2")
            r2   := r2 - take
            done := done + take
    if r1 > 1e-9 and want - done > 1e-9
        float take = math.min(want - done, r1)
        if take > 1e-9
            strategy.close("L1", qty=take, comment="cut-L1")
            r1   := r1 - take
            done := done + take
    [done, r3, r2, r1, r3 > 1e-9, r2 > 1e-9, r1 > 1e-9]
drainShort(reqQty, posAbs, n3, n2, n1) =>
    float want = math.min(math.max(nz(reqQty, 0.0), 0.0), posAbs)
    float done = 0.0
    float r3 = n3
    float r2 = n2
    float r1 = n1
    if r3 > 1e-9 and want - done > 1e-9
        float take = math.min(want - done, r3)
        if take > 1e-9
            strategy.close("S3", qty=take, comment="cut-S3")
            r3   := r3 - take
            done := done + take
    if r2 > 1e-9 and want - done > 1e-9
        float take = math.min(want - done, r2)
        if take > 1e-9
            strategy.close("S2", qty=take, comment="cut-S2")
            r2   := r2 - take
            done := done + take
    if r1 > 1e-9 and want - done > 1e-9
        float take = math.min(want - done, r1)
        if take > 1e-9
            strategy.close("S1", qty=take, comment="cut-S1")
            r1   := r1 - take
            done := done + take
    [done, r3, r2, r1, r3 > 1e-9, r2 > 1e-9, r1 > 1e-9]

// trancheTopLong/Short嚗??賢?嚗??喋???怠?游惜???柴???cutTop ????tranche
//   嚗???惜?嚗?璉?甈?cut ?勗??芸?怎垢??drain 敺?蝞??踹? stale ?嚗?trancheTopLong(on3, on2, on1, n3, n2, n1) =>
    on3 ? n3 : on2 ? n2 : on1 ? n1 : 0.0
trancheTopShort(on3, on2, on1, n3, n2, n1) =>
    on3 ? n3 : on2 ? n2 : on1 ? n1 : 0.0

// ?? ?挾 R-multiple Partial TP嚗擗雿?posLive?瘥?蝎曄Ⅱ?質?嚗? contiguous-stack嚗??
//   tpQty 銝敺誑 posLive(???嗅??拚??其?)?箏?賂?drain ??posAbs 銝?鈭血 posLive嚗?甈∟鋡?//   敺?posLive -= d?P1 ??TP2 ????閫貊??TP2 ?芸?隞亦葬撠??拚??其?閮??拇挾??瘞訾?頞??嗅?
//   蝮賡雿敹?L1 ??newest-first + posAbs clamp ??靽風?ankedQty 蝝航?撖阡??質???撠董??//   not blockPartials嚗rokerStopHit 璉?敺??潮??close嚗? hX ?典?鈭支??乓?tpHitL1 = usePartialTP and not exitedThisBar and not blockPartials and inLong  and R >= tp1R and not tp1Done
tpHitL2 = usePartialTP and not exitedThisBar and not blockPartials and inLong  and R >= tp2R and not tp2Done
tpHitS1 = usePartialTP and not exitedThisBar and not blockPartials and inShort and R >= tp1R and not tp1Done
tpHitS2 = usePartialTP and not exitedThisBar and not blockPartials and inShort and R >= tp2R and not tp2Done
if tpHitL1
    [d, n3, n2, n1, o3, o2, o1] = drainLong(posLive * tp1Pct / 100.0, posLive, notL3, notL2, notL1)
    notL3 := n3
    notL2 := n2
    notL1 := n1
    l3On  := o3
    l2On  := o2
    l1On  := o1
    bankedQty := bankedQty + d
    posLive   := math.max(posLive - d, 0.0)
    tp1Done := true
if tpHitL2
    [d, n3, n2, n1, o3, o2, o1] = drainLong(posLive * tp2Pct / 100.0, posLive, notL3, notL2, notL1)
    notL3 := n3
    notL2 := n2
    notL1 := n1
    l3On  := o3
    l2On  := o2
    l1On  := o1
    bankedQty := bankedQty + d
    posLive   := math.max(posLive - d, 0.0)
    tp2Done := true
if tpHitS1
    [d, n3, n2, n1, o3, o2, o1] = drainShort(posLive * tp1Pct / 100.0, posLive, notS3, notS2, notS1)
    notS3 := n3
    notS2 := n2
    notS1 := n1
    s3On  := o3
    s2On  := o2
    s1On  := o1
    bankedQty := bankedQty + d
    posLive   := math.max(posLive - d, 0.0)
    tp1Done := true
if tpHitS2
    [d, n3, n2, n1, o3, o2, o1] = drainShort(posLive * tp2Pct / 100.0, posLive, notS3, notS2, notS1)
    notS3 := n3
    notS2 := n2
    notS1 := n1
    s3On  := o3
    s2On  := o2
    s1On  := o1
    bankedQty := bankedQty + d
    posLive   := math.max(posLive - d, 0.0)
    tp2Done := true

// ???箏 D嚗T ???挾皜?cut嚗??蝬?contiguous-stack top-first嚗偶銝撅??香嚗?//   閫貊璇辣嚗??嚗T1 ??嚗敹隅?Ｚ?撘梧???撅歹?ST2 ??嚗葉撠箏漲頧摹嚗???撅扎?//   瘜冽?嚗t1 ??st2 ???箏??? 禮9 twoSTRevLong/Short 銋?close_all 撌脣?銵撟喃蒂閮?//   exitedThisBar嚗?甇方? cut ??銝 ST ???銝 ST 隞???皜Ⅳ??????//   cutL2/cutS2 閬??喳????Ⅳ撅文?湛?l2On or l3On嚗?蝣箔? ST2 頝臬?銝?刻孛?敹?L1??//   閫貊 bool 撌脖誑 fresh l*On/s*On ?斗(??stale stage)嚗rain ??posAbs 銝??寧 posLive??//   not blockPartials嚗rokerStopHit 璉?敺??潮??close??cutL1 = usePartialST and not exitedThisBar and not blockPartials and inLong  and st1FlipDn and (l1On or l2On or l3On)
cutL2 = usePartialST and not exitedThisBar and not blockPartials and inLong  and st2FlipDn and (l2On or l3On)
cutS1 = usePartialST and not exitedThisBar and not blockPartials and inShort and st1FlipUp and (s1On or s2On or s3On)
cutS2 = usePartialST and not exitedThisBar and not blockPartials and inShort and st2FlipUp and (s2On or s3On)
// cutTop ??global-scope inline嚗??惜 tranche ??drain ??閫???神?典???//   ?? cutL1 敺?cutL2 ?誑??啣??? notL*/l*On ?? tranche嚗??stale ?嚗?if cutL1
    float tr = trancheTopLong(l3On, l2On, l1On, notL3, notL2, notL1)
    if tr > 1e-9
        [d, n3, n2, n1, o3, o2, o1] = drainLong(tr, posLive, notL3, notL2, notL1)
        notL3 := n3
        notL2 := n2
        notL1 := n1
        l3On  := o3
        l2On  := o2
        l1On  := o1
        posLive := math.max(posLive - d, 0.0)
if cutL2
    float tr = trancheTopLong(l3On, l2On, l1On, notL3, notL2, notL1)
    if tr > 1e-9
        [d, n3, n2, n1, o3, o2, o1] = drainLong(tr, posLive, notL3, notL2, notL1)
        notL3 := n3
        notL2 := n2
        notL1 := n1
        l3On  := o3
        l2On  := o2
        l1On  := o1
        posLive := math.max(posLive - d, 0.0)
if cutS1
    float tr = trancheTopShort(s3On, s2On, s1On, notS3, notS2, notS1)
    if tr > 1e-9
        [d, n3, n2, n1, o3, o2, o1] = drainShort(tr, posLive, notS3, notS2, notS1)
        notS3 := n3
        notS2 := n2
        notS1 := n1
        s3On  := o3
        s2On  := o2
        s1On  := o1
        posLive := math.max(posLive - d, 0.0)
if cutS2
    float tr = trancheTopShort(s3On, s2On, s1On, notS3, notS2, notS1)
    if tr > 1e-9
        [d, n3, n2, n1, o3, o2, o1] = drainShort(tr, posLive, notS3, notS2, notS1)
        notS3 := n3
        notS2 := n2
        notS1 := n1
        s3On  := o3
        s2On  := o2
        s1On  := o1
        posLive := math.max(posLive - d, 0.0)

// ???箏 E嚗egime-fade ?詨??駁◢?迎??箏?游?蝔望?脣靽∪艙?Ⅳ嚗???//   ?葉 er < erThr?fadeK嚗縑敹菜??嚗?嚗? contiguous-stack ???怠?蝣澆惜????tranche嚗?//   閬?瘣?stage>=2嚗撠?銝?Ⅳ撅文?湛?隞乩?霅?閫詨??詨? L1???皛航風甈?
//     (1) re-arm ??er >= erThr嚗??湧皛臬葆嚗?(2) ?拇活?惜?喳??? fadeCoolBars 璉?//   effRegimeFade ??usePureA?ot blockPartials??if not inPos or er >= erThr
    fadeArmed := true   // ER ??頞?摰?瑼?erThr ???唳郎鋆??脫趙撣塚?
fadeTrig    = effRegimeFade and not exitedThisBar and not blockPartials and erThr > 0 and er < erThr * fadeK
fadeReady   = fadeArmed and (bar_index - lastFadeBar) >= fadeCoolBars
// 隞乓迨??fresh l*On/s*On ?單?????瘣?stage ??>=2 霅瑟?嚗?蝯???禮6 璉? stale stage??fadeStageLong  = (l1On?1:0) + (l2On?1:0) + (l3On?1:0)
fadeStageShort = (s1On?1:0) + (s2On?1:0) + (s3On?1:0)
regimeFadeLong  = fadeTrig and inLong  and fadeStageLong  >= 2 and fadeReady
regimeFadeShort = fadeTrig and inShort and fadeStageShort >= 2 and fadeReady
if regimeFadeLong
    float tr = trancheTopLong(l3On, l2On, l1On, notL3, notL2, notL1)
    if tr > 1e-9
        [d, n3, n2, n1, o3, o2, o1] = drainLong(tr, posLive, notL3, notL2, notL1)
        notL3 := n3
        notL2 := n2
        notL1 := n1
        l3On  := o3
        l2On  := o2
        l1On  := o1
        posLive := math.max(posLive - d, 0.0)
    fadeArmed   := false
    lastFadeBar := bar_index
if regimeFadeShort
    float tr = trancheTopShort(s3On, s2On, s1On, notS3, notS2, notS1)
    if tr > 1e-9
        [d, n3, n2, n1, o3, o2, o1] = drainShort(tr, posLive, notS3, notS2, notS1)
        notS3 := n3
        notS2 := n2
        notS1 := n1
        s3On  := o3
        s2On  := o2
        s1On  := o1
        posLive := math.max(posLive - d, 0.0)
    fadeArmed   := false
    lastFadeBar := bar_index

// ???箏 E2嚗??EW-F2 ?梯?蟡冽銵圈?駁◢?迎?E2 ?梯??賊????蝘餃?箏?湛???A 撠?嚗???//   ?葉?嗅??孵? regime 蟡冽 votesDir(ER/ADX/ST3 ??蟡?頝 effMinVotes ??閬憭? regime
//   ?梯?銵啁垠(瘥??ER ?渡帘?乓?拇鋡怠? trail ?箏)嚗? cutTop ???怠?蝣澆惜????tranche
//   (銝??詨? L1嚗? contiguous-stack + fresh 瘣?stage>=2 靽?)???皛航風甈?
//     (1) re-arm ??votesDir >= effMinVotes嚗??湧皛臬葆嚗?(2) ?拇活?惜?喳??? fadeCoolBars 璉?//   ??regime-fade(??ER 瘞湔?)甇?漱嚗2 ?霅巨?貊?瑽? erThr 閫?艾???votesLong/Short/
//   effMinVotes/cutTop/fadeCoolBars嚗?啣???? input??蝛粹????芸?蟡冽)?ffVoteFade ??usePureA??//   not blockPartials嚗rokerStopHit 璉??潮??close?nabledVotes==0(?券?)???閫貊??votesDirLong  = votesLong
votesDirShort = votesShort
// re-arm嚗?渡巨?詨??????湧?瑼?effMinVotes ???唳郎鋆??脫趙撣塚??∪? regime-fade ??er>=erThr)
if not inPos or enabledVotes == 0 or (inLong and votesDirLong >= effMinVotes) or (inShort and votesDirShort >= effMinVotes)
    voteFadeArmed := true
voteFadeReady   = voteFadeArmed and (bar_index - lastVoteFadeBar) >= fadeCoolBars
// 隞?fresh l*On/s*On ?單???瘣?stage ??>=2 霅瑟?嚗?蝯???禮6 璉? stale stage??vfStageLong  = (l1On?1:0) + (l2On?1:0) + (l3On?1:0)
vfStageShort = (s1On?1:0) + (s2On?1:0) + (s3On?1:0)
voteFadeTrigLong  = effVoteFade and not exitedThisBar and not blockPartials and enabledVotes > 0 and inLong  and votesDirLong  < effMinVotes and vfStageLong  >= 2 and voteFadeReady
voteFadeTrigShort = effVoteFade and not exitedThisBar and not blockPartials and enabledVotes > 0 and inShort and votesDirShort < effMinVotes and vfStageShort >= 2 and voteFadeReady
// [F2 甇詨?閫皜柵 蝝航?鋡怠?撅斗活?賂?靘?walk-forward ?圾鋡怠??Ⅳ撅文?鞎?雿?炊畾箏撠暹?惜??var int voteFadeCuts = 0
if voteFadeTrigLong
    float tr = trancheTopLong(l3On, l2On, l1On, notL3, notL2, notL1)
    if tr > 1e-9
        [d, n3, n2, n1, o3, o2, o1] = drainLong(tr, posLive, notL3, notL2, notL1)
        notL3 := n3
        notL2 := n2
        notL1 := n1
        l3On  := o3
        l2On  := o2
        l1On  := o1
        posLive := math.max(posLive - d, 0.0)
        voteFadeCuts += 1
    voteFadeArmed   := false
    lastVoteFadeBar := bar_index
if voteFadeTrigShort
    float tr = trancheTopShort(s3On, s2On, s1On, notS3, notS2, notS1)
    if tr > 1e-9
        [d, n3, n2, n1, o3, o2, o1] = drainShort(tr, posLive, notS3, notS2, notS1)
        notS3 := n3
        notS2 := n2
        notS1 := n1
        s3On  := o3
        s2On  := o2
        s1On  := o1
        posLive := math.max(posLive - d, 0.0)
        voteFadeCuts += 1
    voteFadeArmed   := false
    lastVoteFadeBar := bar_index

// ???箏 G2嚗???NEW-G2 撜啣澆????箏??drawdown-velocity嚗?頞?堆?A ??B ?嚗???//   ?葉隞?dvRate=(peakR?)/dvWin(dvWin=fadeCoolBars ?Ｘ?璉撠箏漲)?菜葫?雿???????
//   ??頞 dvThr=dvThrK?multBE ?喟? cutTop ???怠?蝣澆惜????tranche(瘣?vfStage>=2 霅瑟?繚瘞訾?
//   ?敹?L1)?? F2(?梯?蟡冽)/regime-fade(ER 瘞湔?)/peakR ????蝯?撟漲?唳)甇?漱?????//   敹恍?頧? votes/ER 撠頝???拇??喳偏靽風?vThr ?望??multBE 瘣曄?(?身 dvThrK=0?vThr=0??//   ??useDrawdownVel ?身?????????啣?蝯?撣豢)?vWin ?冽??fadeCoolBars嚗?啣????
//   input???皛荔?(1)re-arm ??dvRate<=dvThr(???)嚗?2)?拇活?惜?? fadeCoolBars 璉粥 cutTop
//   銝粥 close_all 蝬剜? stageLive ????蝛粹??R 撌脫?飛銝繚peakR ?箸??擃偌雿??ffDrawdownVel
//   ??usePureA?ot blockPartials?eakR<=R(撠??)??dvRate<=0 銝孛?潦?璈?嗅?銵?dvWin   = math.max(fadeCoolBars, 1)
dvThr   = dvThrK * multBE
dvRate  = inPos ? math.max(peakR - R, 0.0) / dvWin : 0.0
// re-arm嚗?????圈?瑼颱誑銝?????芸??????唳郎鋆?if not inPos or not effDrawdownVel or dvThr <= 0.0 or dvRate <= dvThr
    dvArmed := true
dvReady = dvArmed and (bar_index - lastDvBar) >= fadeCoolBars
// 隞?fresh l*On/s*On ?單???瘣?stage ??>=2 霅瑟?(銴 F2 ??vfStage*嚗?0 ??摨??歇?????dvStageLong  = (l1On?1:0) + (l2On?1:0) + (l3On?1:0)
dvStageShort = (s1On?1:0) + (s2On?1:0) + (s3On?1:0)
dvTrigLong  = effDrawdownVel and not exitedThisBar and not blockPartials and dvThr > 0.0 and inLong  and dvRate > dvThr and dvStageLong  >= 2 and dvReady
dvTrigShort = effDrawdownVel and not exitedThisBar and not blockPartials and dvThr > 0.0 and inShort and dvRate > dvThr and dvStageShort >= 2 and dvReady
// [G2 甇詨?閫皜柵 蝝航?鋡怠?撅斗活?賂?靘?walk-forward ?圾鋡怠?撅斗?血??箏翰??頧??喳偏靽風?賭葉??var int dvCuts = 0
if dvTrigLong
    float tr = trancheTopLong(l3On, l2On, l1On, notL3, notL2, notL1)
    if tr > 1e-9
        [d, n3, n2, n1, o3, o2, o1] = drainLong(tr, posLive, notL3, notL2, notL1)
        notL3 := n3
        notL2 := n2
        notL1 := n1
        l3On  := o3
        l2On  := o2
        l1On  := o1
        posLive := math.max(posLive - d, 0.0)
        dvCuts += 1
    dvArmed   := false
    lastDvBar := bar_index
if dvTrigShort
    float tr = trancheTopShort(s3On, s2On, s1On, notS3, notS2, notS1)
    if tr > 1e-9
        [d, n3, n2, n1, o3, o2, o1] = drainShort(tr, posLive, notS3, notS2, notS1)
        notS3 := n3
        notS2 := n2
        notS1 := n1
        s3On  := o3
        s2On  := o2
        s1On  := o1
        posLive := math.max(posLive - d, 0.0)
        dvCuts += 1
    dvArmed   := false
    lastDvBar := bar_index

// ???箏 F嚗elowAvg/aboveAvg ?怠惜皜Ⅳ嚗?挾??閮剝?嚗??撟喟??詨??? ??//   蝬?contiguous-stack嚗?????怠?游惜????tranche嚗op-first嚗?靽??詨? L1 頝撠橘?
//   瘣?stage>=2 璇辣蝣箔??喳?????蝣澆惜?臬?嚗1 瘞訾?鋡急迨頝臬?閫詨???//   stage>=2 霅瑟??寧甇文 fresh l*On/s*On ?單????暑 stage?ot blockPartials??belowStageLong  = (l1On?1:0) + (l2On?1:0) + (l3On?1:0)
aboveStageShort = (s1On?1:0) + (s2On?1:0) + (s3On?1:0)
belowAvgLong  = useBelowAvg and not exitedThisBar and not blockPartials and inLong  and belowStageLong  >= 2 and close < avgPx - kBuf * atrChand
aboveAvgShort = useBelowAvg and not exitedThisBar and not blockPartials and inShort and aboveStageShort >= 2 and close > avgPx + kBuf * atrChand
if belowAvgLong
    float tr = trancheTopLong(l3On, l2On, l1On, notL3, notL2, notL1)
    if tr > 1e-9
        [d, n3, n2, n1, o3, o2, o1] = drainLong(tr, posLive, notL3, notL2, notL1)
        notL3 := n3
        notL2 := n2
        notL1 := n1
        l3On  := o3
        l2On  := o2
        l1On  := o1
        posLive := math.max(posLive - d, 0.0)
if aboveAvgShort
    float tr = trancheTopShort(s3On, s2On, s1On, notS3, notS2, notS1)
    if tr > 1e-9
        [d, n3, n2, n1, o3, o2, o1] = drainShort(tr, posLive, notS3, notS2, notS1)
        notS3 := n3
        notS2 := n2
        notS1 := n1
        s3On  := o3
        s2On  := o2
        s1On  := o1
        posLive := math.max(posLive - d, 0.0)

// ????????????????????????????????????????????????????????????????????????????
// 禮11  ?脣嚗?蝛箏?潮??擐憟?regime gate嚗?蝣澆? winners-add-only + vol-brake嚗?//      ??禮10 靽? stage ???嚗1Cond(stage==0) ??蝣?l1On==true) 瘞詨???⊿?蝝?甇颯?//      brokerStopHit 璉?exitedThisBar=true ???祆?銝脣(canEnter ??not exitedThisBar)??// ????????????????????????????????????????????????????????????????????????????
canEnter = bar_index >= cooldownUntil and not exitedThisBar
// ?脣 stage ??敺誑??0 皜? fresh l*On/s*On ?單?????瘣?stage ?斗嚗?????禮6 璉?
//   stale stage?1Cond/s1Cond 銝血?撠? stage==0 ??瘙⊥??脰風??curLongStage  = (l1On?1:0) + (l2On?1:0) + (l3On?1:0)
curShortStage = (s1On?1:0) + (s2On?1:0) + (s3On?1:0)
// [NEW-A2] ?脣???孵榆蝣箄???擐 |close?t1| ??kBuf?atrChand嚗???kBuf/atrChand ?嗆憓?input嚗?//   ?芸??蝧餉????芣銵??脤??殷??蕪?Ｚ??云??餈賡?/餈賜征?柴?蝛粹?ffEntryDistGate 撌脣 usePureA??//   na 摰?嚗t1/atrChand 隞颱? na ??atrChand<=0 ???餅?(???銵)嚗??璈?隤日???entryDistOK = not effEntryDistGate or na(st1) or na(atrChand) or atrChand <= 0 or math.abs(close - st1) <= kBuf * atrChand
// [?EW-C2] 銝剖偕摨阡脣蝣箄???擐??瘙葉撠箏漲 ST2 ??嚗? st2Bull / 蝛?st2Bear嚗?//   鋆?regime gate ?葉撠箏漲?孵??脤?(銝巨 ER/ADX/ST3 銝 ST2)????st2Bull/st2Bear ?嗆憓?input??//   憭征?∪??雿擐?ffMidConfirm 撌脣 usePureA嚗????拇? OK ??true(???銵)??midConfirmLongOK  = not effMidConfirm or st2Bull
midConfirmShortOK = not effMidConfirm or st2Bear
// 擐嚗T1 蝧餃? + regime gate嚗 MTF ?Ｙ?瑽??漲嚗? ?孵榆??A2) + 銝剖偕摨衣Ⅱ隤?(C2)
l1Cond = curLongStage == 0 and curShortStage == 0 and st1FlipUp and regimeLongOK  and canEnter and entryDistOK and midConfirmLongOK
s1Cond = curLongStage == 0 and curShortStage == 0 and st1FlipDn and regimeShortOK and canEnter and entryDistOK and midConfirmShortOK
// ?Ⅳ嚗?畾萄歇瘚桃?(R>0)?隅?Ｗ??T ?亙?蝧餃????芾孛??vol-brake嚗?瘜Ｗ???嚗?//   [NEW-A3] 銝?游漲?Ⅳ靽∪艙??addOK ???撅砌蒂??AND coherence>=2嚗? coherenceLong / 蝛?coherenceShort嚗?//   [?EW-C1] ER ??漲?Ⅳ????AND (er >= nz(er[1], er))(??芣??????er[1] ?嗆憓?input??蝣?erThr??//   [??NEW-E3] ?Ⅳ???餃?????AND (bar_index ??lastAddBar ??addSpace)?ddSpace ?望??len1/persistBars
//     瘣曄?(?嗆憓隤輸?)嚗??芾?銵??????桃???蝛箏?典?銝 lastAddBar(???⊥???∪?)??//   銝???convMult(隤?size)甇?漱嚗3 ??瑽1 ???賢??漲?3 ??摨?頝onvMult ?偌皞?蝛粹??addCohLongOK  = not effCoherenceAdd or coherenceLong  >= 2
addCohShortOK = not effCoherenceAdd or coherenceShort >= 2
// [?EW-C1 + ?梯?靽格迤 CFix-2] ER 銝?榆??撣嗆扔撠皛荔?er >= er[1] ??erHystFrac?erThr??//   erHystFrac=0 ????>=(??A 蝑)嚗?0 蝯血璉??楨銵??芣??＊???賣?銵凝撠?瑼?//   nz(er[1],er) ??摰?(擐???銵?嚗???er/erThr嚗?蝛箏?典?銝 er 憭拍?∪???erHystBand    = erHystFrac * erThr                          // ?脫趙撣嗥?撠?(?詨? erThr 撠箏漲?楊???芷??
addErAccelOK  = not effErAccelAdd or er >= nz(er[1], er) - erHystBand
// [???EW-G1] ADX ???蝣箄??Ⅳ???Ⅳ??AND ta.change(adx) >= ?dxSlopeHystBand??//   閬??Ⅳ?嗡?頞典撘瑕漲?(ADX 銝?榆??銝銵圈???冽??adx嚗? C1(ER 銝?榆??甇?漱??//   ?脫趙撣?adxSlopeHystBand=adxSlopeHystK?adxOff(?身 0 ???潑0)?z ??摰?擐??曇???//   ADX ?⊥??憭征?梁?? adxChg 憭拍?∪???adxChg            = adx - nz(adx[1], adx)                    // ADX 銝?榆??頞典撘瑕漲?)
adxSlopeHystBand  = adxSlopeHystK * adxOff
addAdxSlopeOK     = not effAdxSlopeAdd or adxChg >= -adxSlopeHystBand
// [??ABSORB-F1] 瘜Ｗ??芷??蝣潮?頝?addSpaceBase 銋?spaceVolK ??round/clamp ??[2,persistBars]??//   spaceVolK=clamp(1+(50?trPctRank)/100, spcVolLo, spcVolHi)嚗?璈?atrPctRank na ???50????1(蝑??)??//   gated ??E3 ??銝?effAddSpaceVol 撌脣 effAddSpacing)???冽??atrPctRank/len1/persistBars??addSpaceBase  = math.min(math.max(len1, 2), persistBars)   // ???箸???(璉?嚗?Ｘ?蝯?瘣曄?
spaceVolK     = effAddSpaceVol ? math.min(math.max(1.0 + (50.0 - nz(atrPctRank, 50.0)) / 100.0, spcVolLo), spcVolHi) : 1.0
addSpace      = math.min(math.max(math.round(addSpaceBase * spaceVolK), 2), persistBars)   // F1 ?芷??隞?clamp ??蝯???addSpacingOK  = not effAddSpacing or (bar_index - lastAddBar) >= addSpace
addOKLong  = not volBrakeOn and R > 0 and addCohLongOK  and addErAccelOK and addAdxSlopeOK and addSpacingOK
addOKShort = not volBrakeOn and R > 0 and addCohShortOK and addErAccelOK and addAdxSlopeOK and addSpacingOK
// [?梯?靽格迤 CFix-3繚E3/F1 甇詨?閫皜柵 蝝航???⊿?頝??砍?曇???鋡??芷??)addSpace ????Ⅳ甈⊥??//   蝝?皜?銝鈭斗?銵)嚗?隞?= 閰脣惜?園??Ⅳ??(??G1)?冽?蝡? addSpacingOK ??false ?◤??//   ?∠? F1 敺?spacingBlocked ?刻?拇?敺?addSpace嚗?撖阡????瑼颱????踹?甇詨??恍)??//   [G1 甇詨?閫皜柵 g1BlockedAdds嚗擗????恍?頝??冽?蝡? addAdxSlopeOK ??false ?◤ G1 ??var int e3BlockedAdds = 0
var int g1BlockedAdds = 0
spacingBlocked = effAddSpacing and (bar_index - lastAddBar) < addSpace
adxSlopeBlocked = effAdxSlopeAdd and adxChg < -adxSlopeHystBand
addBaseLong2  = curLongStage == 1 and l1On and inLong  and st2FlipUp and st1Bull and not volBrakeOn and R > 0 and addCohLongOK  and addErAccelOK
addBaseLong3  = curLongStage == 2 and l1On and l2On and inLong  and st3FlipUp and st1Bull and st2Bull and not volBrakeOn and R > 0 and addCohLongOK  and addErAccelOK
addBaseShort2 = curShortStage == 1 and s1On and inShort and st2FlipDn and st1Bear and not volBrakeOn and R > 0 and addCohShortOK and addErAccelOK
addBaseShort3 = curShortStage == 2 and s1On and s2On and inShort and st3FlipDn and st1Bear and st2Bear and not volBrakeOn and R > 0 and addCohShortOK and addErAccelOK
anyAddBase = addBaseLong2 or addBaseLong3 or addBaseShort2 or addBaseShort3
// E3/F1 ?甇詨?嚗擗?? G1 ?冽?蝡???????if spacingBlocked and addAdxSlopeOK and anyAddBase
    e3BlockedAdds += 1
// G1 ?甇詨?嚗擗?????冽?蝡? G1 ADX ??????if adxSlopeBlocked and addSpacingOK and anyAddBase
    g1BlockedAdds += 1
l2Cond = curLongStage == 1 and l1On and inLong  and st2FlipUp and st1Bull and addOKLong
l3Cond = curLongStage == 2 and l1On and l2On and inLong  and st3FlipUp and st1Bull and st2Bull and addOKLong
s2Cond = curShortStage == 1 and s1On and inShort and st2FlipDn and st1Bear and addOKShort
s3Cond = curShortStage == 2 and s1On and s2On and inShort and st3FlipDn and st1Bear and st2Bear and addOKShort

if l1Cond
    strategy.entry("L1", strategy.long, qty=qty1, comment="L1")
    entryRisk := chandMult * atrChand   // ???祕??甇Ｘ?頝??R ??
    entryPx   := close
    trailExt  := high
    trailStop := na
    entryBar  := bar_index
    peakR     := 0.0
    peakBar   := bar_index               // ?啣???趙閮???    bankedQty := 0.0
    openInitQty := qty1
    fadeArmed := true
    voteFadeArmed := true   // [F2] ?圈??桅?蝵格郎鋆?    dvArmed := true         // [G2] ?圈??桅?蝵格郎鋆?    lastAddBar := bar_index   // [E3] 擐???Ⅳ??閮???    l1On := true
    notL1 := qty1   // 閮?閰脣惜銝?⊥嚗? TP/cut/fade 蝝蝎曄Ⅱ撠董
if l2Cond
    strategy.entry("L2", strategy.long, qty=qty2, comment="L2")
    l2On := true
    notL2 := qty2
    openInitQty := openInitQty + qty2
    lastAddBar := bar_index   // [E3] ?Ⅳ敺?圈?頝??
if l3Cond
    strategy.entry("L3", strategy.long, qty=qty3, comment="L3")
    l3On := true
    notL3 := qty3
    openInitQty := openInitQty + qty3
    lastAddBar := bar_index   // [E3] ?Ⅳ敺?圈?頝??
if s1Cond
    strategy.entry("S1", strategy.short, qty=qty1, comment="S1")
    entryRisk := chandMult * atrChand   // ???祕??甇Ｘ?頝??R ??
    entryPx   := close
    trailExt  := low
    trailStop := na
    entryBar  := bar_index
    peakR     := 0.0
    peakBar   := bar_index               // ?啣???趙閮???    bankedQty := 0.0
    openInitQty := qty1
    fadeArmed := true
    voteFadeArmed := true   // [F2] ?圈??桅?蝵格郎鋆?    dvArmed := true         // [G2] ?圈??桅?蝵格郎鋆?    lastAddBar := bar_index   // [E3] 擐???Ⅳ??閮???    s1On := true
    notS1 := qty1
if s2Cond
    strategy.entry("S2", strategy.short, qty=qty2, comment="S2")
    s2On := true
    notS2 := qty2
    openInitQty := openInitQty + qty2
    lastAddBar := bar_index   // [E3] ?Ⅳ敺?圈?頝??
if s3Cond
    strategy.entry("S3", strategy.short, qty=qty3, comment="S3")
    s3On := true
    notS3 := qty3
    openInitQty := openInitQty + qty3
    lastAddBar := bar_index   // [E3] ?Ⅳ敺?圈?頝??

// nCap ??閮嚗??vol-target ?臬鋡急?獢蹂???頝荔?
if cap1 or cap2 or cap3
    capHits += 1

// 璉 fresh 瘣?stage嚗?0 皜?+ 禮11 ?Ⅳ敺?蝯?l*On/s*On ?遣嚗? 禮12 閬死?? 禮14
//   stage==opentrades 撠董雿輻?? ??stage ?箸?擐?靘?禮9 timeStop 甇?Ⅱ閮?)嚗＊蝷?撠董
//   ?寧 stageLive(璉 fresh)隞亙??璉?祕撅斗??//   閮鳴?brokerStopHit 璉?銝剖歇撟喳?雿?strategy.position_size 閬?銝璉??? flat嚗??祆?
//   inLong/inShort 隞?true?tageLive 隞＊蝷箸?鈭文?撅斗嚗??詨?敺?蝞? opentrades 銝?湛?閰脫?
//   禮14 銝炊?梁撣喉?銝?璉?Ⅱ隤?flat 敺?禮6 ?芰摰?蔭??蝑敺押?stageLive = inLong ? ((l1On?1:0) + (l2On?1:0) + (l3On?1:0)) : inShort ? ((s1On?1:0) + (s2On?1:0) + (s3On?1:0)) : 0

