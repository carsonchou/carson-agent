var int   lastDvBar     = -100000
// [??NEW-E3] 銝?甈∪?蝣??脣璉??Ⅳ???餃????嚗??脣/?Ⅳ??撖怠?lat ?蔭??//   憭征?梁?? var(???⊥??憭拍?∪?)????-100000 雿輸??桐?鋡恍?頝??餅???var int   lastAddBar    = -100000
// ?惜銝?⊥閮董嚗? Partial TP / cut / regime-fade 蝝蝎曄Ⅱ撠董嚗脣撖怠????扎lat 甇賊嚗?var float notL1 = 0.0
var float notL2 = 0.0
var float notL3 = 0.0
var float notS1 = 0.0
