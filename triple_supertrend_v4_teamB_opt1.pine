effEntryDistGate   = useEntryDistGate   and not usePureA   // NEW-A2 ?脣???孵榆蝣箄???effCoherenceAdd    = useCoherenceAdd    and not usePureA   // NEW-A3 銝?游漲?Ⅳ靽∪艙??effErAccelAdd      = useErAccelAdd      and not usePureA   // ?EW-C1 ER ??漲?Ⅳ??effMidConfirm      = useMidConfirm      and not usePureA   // ?EW-C2 銝剖偕摨阡脣蝣箄???effAdaptiveMinVotes= useAdaptiveMinVotes and not usePureA  // ??NEW-E2 瘜Ｗ??芷??minVotes
effAddSpacing      = useAddSpacing      and not usePureA   // ??NEW-E3 ?Ⅳ???餃???effVoteFade        = useVoteFade        and not usePureA   // ??NEW-F2 ?梯?蟡冽銵圈?駁◢?芷?
effAddSpaceVol     = useAddSpaceVol     and effAddSpacing and not usePureA  // ??NEW-F1 瘜Ｗ??芷??蝣潮?頝?gated ??E3 銝?
effAdxSlopeAdd     = useAdxSlopeAdd     and not usePureA   // ???EW-G1 ADX ???蝣箄??Ⅳ??effDrawdownVel     = useDrawdownVel     and not usePureA   // ???EW-G2 撜啣澆????箏??
// ?曉?雿?閬?撠?????乩蝙?刻? Lo/Hi ?蔭嚗??swap 蝬剜??株矽
pctlLo = math.min(pctlGaugeLo, pctlGaugeHi)
pctlHi = math.max(pctlGaugeLo, pctlGaugeHi)
// F1 ??靽銝?????乩蝙?刻? Lo/Hi ?蔭嚗??swap 蝬剜??株矽
spcVolLo = math.min(spaceVolLo, spaceVolHi)
spcVolHi = math.max(spaceVolLo, spaceVolHi)

// ????????????????????????????????????????????????????????????????????????????
// 禮2  銝惜 SuperTrend嚗銝?箇??望?瘣曄?嚗a.supertrend ? [value,direction]嚗?//     direction < 0 ?箏???// ????????????????????????????????????????????????????????????????????????????
len1 = baseLen
len2 = math.max(math.round(baseLen * midMult), 2)
len3 = math.max(math.round(baseLen * slowMult), 3)
[st1, dir1] = ta.supertrend(f1, len1)
[st2, dir2] = ta.supertrend(f2, len2)
[st3, dir3] = ta.supertrend(f3, len3)

st1Bull = dir1 < 0
st2Bull = dir2 < 0
st3Bull = dir3 < 0
st1Bear = not st1Bull
st2Bear = not st2Bull
st3Bear = not st3Bull
// 蝧餉?鈭辣嚗??格?暺???
st1FlipUp   = st1Bull and not st1Bull[1]
st2FlipUp   = st2Bull and not st2Bull[1]
st3FlipUp   = st3Bull and not st3Bull[1]
st1FlipDn   = st1Bear and not st1Bear[1]
st2FlipDn   = st2Bear and not st2Bear[1]
st3FlipDn   = st3Bear and not st3Bear[1]

// ST3 蝧餃?敺?瘣餅??賂??Ｙ?瑽??漲嚗?璉閮? request.security ?鼓憸券嚗?var int st3BullBars = 0
var int st3BearBars = 0
st3BullBars := st3Bull ? nz(st3BullBars[1]) + 1 : 0
st3BearBars := st3Bear ? nz(st3BearBars[1]) + 1 : 0
// persistBars ?望??len3 瘣曄?嚗?baseLen?slowMult嚗? clamp ??[3, mtfCapBars]嚗?// ??撖行?莎?mtfCapBars ?箝憓??航矽 input???桃??脣?撣豢??潛?交捱摰?MTF 擐
//   ?曇??瑼?persistBars嚗惇??蝛粹?蝬剖漲嚗?閮?祕?蝛粹?銝行 walk-forward ???漲皜祈岫??persistBars  = math.min(math.max(len3, 3), mtfCapBars)
mtfBullOK    = not effMTFgate or (st3Bull and st3BullBars >= persistBars)
mtfBearOK    = not effMTFgate or (st3Bear and st3BearBars >= persistBars)

// 憭偕摨行???游漲嚗???ST ?賂?憭征??嚗?啣? input???孵?蝯?嚗?coherenceLong  = (st1Bull?1:0) + (st2Bull?1:0) + (st3Bull?1:0)
coherenceShort = (st1Bear?1:0) + (st2Bear?1:0) + (st3Bear?1:0)

// ????????????????????????????????????????????????????????????????????????????
// 禮3  ATR% 甇???皞???????瑼颱?敺撠?嚗?頝典???蝝情??
// ????????????????????????????????????????????????????????????????????????????
atrAdx   = ta.atr(adxLen)
atrChand = ta.atr(chandLen)
atrPct   = atrAdx / close              // ATR%嚗撠??箸?嚗?
// ????????????????????????????????????????????????????????????????????????????
// 禮4  瘜Ｗ??摯閮?撟游??撠?嚗? VT-Core ??
//     instVolAnn嚗僑??郭???冽??甇????relVol嚗撠葉雿嚗?澆???頠?+
//     瘜Ｗ??? + 瘜Ｗ?銝?trail + 瘜Ｗ??瑕
//     breathPctl嚗trPct ?曉?雿妝?澆靽嚗??箸郭?蜓 trail ??賊?(銝１ brakeK)?蹂誨撽?
// ????????????????????????????????????????????????????????????????????????????
logRet      = math.log(close / close[1])
stdevDaily  = ta.stdev(logRet, volLen)
volAnnATR   = atrPct       * math.sqrt(barsPerYear)   // ATR% 撟游?
volAnnStd   = stdevDaily   * math.sqrt(barsPerYear)   // ?梢 std 撟游?
instVolAnn  = volEstMode == "Stdev" ? volAnnStd : volAnnATR
// ?詨??????頨怨? brakeLen 璉僑?郭??雿??嚗楊???芷???踹?蝯? floor 憭梁?
// fallback 0.02 ?箝僑??2%??蝝?摰絲暺??詨??仃????撽?摰?潘??撣 magic bp嚗?volFloor    = ta.percentile_linear_interpolation(instVolAnn, brakeLen, 5)
volFloor   := na(volFloor) ? 0.02 : math.max(volFloor, 0.001)
instVolAnn := math.max(nz(instVolAnn, volFloor), volFloor)
// ??頠皞?instVolAnn ?詨??園?葉雿
volMedian   = ta.median(instVolAnn, brakeLen)
volMedian  := na(volMedian) ? instVolAnn : math.max(volMedian, volFloor)
relVol      = instVolAnn / volMedian
volBrakeOn  = useVolBrake and relVol > brakeK     // true=擃郭???怠??Ⅳ
// 蝯曹??澆靽嚗???relVol/brakeK嚗?瘜Ｗ???/瘜Ｗ?銝?trail/瘜Ｗ??瑕?梁嚗lamp ??[1, brakeK]嚗?breathClamp = math.min(math.max(relVol, 1.0), brakeK)
// ?餌?郭??閬?atrPct ?刻? brakeLen 璉??曉?雿妝(0~100) ???澆靽 [pctlLo, pctlHi]??//   銝?鞈?relVol/brakeK嚗???頠???/?瑕?餌????brakeK ?桅??摹?扼?//   percentrank ?箏?雿?蝵????撳?瑼?嚗??偏/頝喟征?渡帘?乓???atrPct/brakeLen嚗?//   ?????[pctlLo, pctlHi] ?箸??脩??航矽 input(??勗虜??1/2)??atrPctRank  = ta.percentrank(atrPct, brakeLen)        // 0~100
breathPctl  = pctlLo + nz(atrPctRank, 50.0) / 100.0 * (pctlHi - pctlLo)   // [pctlLo, pctlHi]
var int floorHits = 0
if instVolAnn <= volFloor + 1e-12
    floorHits += 1

// ????????????????????????????????????????????????????????????????????????????
// 禮5  Regime ??嚗R / ADX ?脫趙 / ST3 ?Ｘ??嚗? ?巨?券??脤?甇?// ????????????????????????????????????????????????????????????????????????????
// Kaufman ??瘥??駁?日嚗 math.sum ??math.sum嚗?erChange = math.abs(close - close[erLen])
erVolSum = math.sum(math.abs(close - close[1]), erLen)
er       = erVolSum > 0 ? erChange / erVolSum : 0.0
er      := nz(er, 0.0)
// [?EW-C1 閫皜祇?] ER ?銝?榆???漲?孵?)嚗z ??摰?嚗?璉??0(銝炊?斗????//   蝝?皜祇?(靘?C1 ??/ ?銵冽 ?ER ? / debug)嚗鈭斗?敶梢(??虫誑 er>=nz(er[1],er) 銵刻膩)??erSlope  = er - nz(er[1], er)
// [OBS-D1 閫皜祇?] ER 鈭??漲(?漲????) = erSlope ??erSlope[1]嚗z ??摰???//   ???雿?閫皜研???go/no-go?? C1 銝?榆?頞典撠暹挾擃漲?梁?嚗????憓???勗漲??erAccel2 = erSlope - nz(erSlope[1], erSlope)

// ADX / DI嚗皛舫??曉潘?
[diPlus, diMinus, adx] = ta.dmi(adxLen, adxLen)
var bool adxOn_state = false
if adx > adxOn
    adxOn_state := true
else if adx < adxOff
    adxOn_state := false

// ST3 ?Ｘ??
slowBull = st3Bull
slowBear = st3Bear

// ?巨嚗?蟡函??舐蝡??????巨銝??亙?瘥???嚗?voteER_long   = useER     and er > erThr
voteADX_long  = useADX    and adxOn_state
voteSlow_long = useSlowST and slowBull
voteER_short  = useER     and er > erThr
voteADX_short = useADX    and adxOn_state
voteSlow_short= useSlowST and slowBear
votesLong  = (voteER_long?1:0)  + (voteADX_long?1:0)  + (voteSlow_long?1:0)
votesShort = (voteER_short?1:0) + (voteADX_short?1:0) + (voteSlow_short?1:0)
// 撌脣??函巨?賂????瑼?= min(minVotes, ?蟡冽)嚗??蟡典??甇?enabledVotes = (useER?1:0) + (useADX?1:0) + (useSlowST?1:0)
// [??NEW-E2] 瘜Ｗ??芷??minVotes嚗?瘜Ｗ???(atrPctRank<lowVolPctile嚗?游?蝒皞怠?)閬?憭?//   extraVoteLowVol 蟡?regime ?梯???瘜Ｗ???? minVotes???冽??atrPctRank(禮4)??//   ?霅耨甇?CFix-1?owVolPctile(33)/extraVoteLowVol(1) 撌脫??脩?航矽 input????葫?芰摨佗?
//   銝?摰?迂??啣??芰摨艾?瘜Ｗ?蝘拍?孵???蝛箏?蝔梧???C1/C2(?孵???甇?漱(?祇??箏霅??)??//   銝敺? clamp ??enabledVotes 隞亙????瑼餃??香?owVolRegime ??(atrPctRank na)???false 銝炊?嗥???lowVolRegime = effAdaptiveMinVotes and not na(atrPctRank) and atrPctRank < lowVolPctile
minVotesEff  = minVotes + (lowVolRegime ? extraVoteLowVol : 0)
effMinVotes  = math.min(minVotesEff, enabledVotes)
votesUnreachable = minVotesEff > enabledVotes   // ?瑼?> ?舫?蟡冽 ??撌脤??clamp嚗?銵冽?內
// ?孵?蟡剁?憭征?湔?∪?嚗??臭?撌桃嚗?DI ?孵????dirLong  = diPlus  > diMinus
dirShort = diMinus > diPlus
diLongOK  = not useDIgate or dirLong
diShortOK = not useDIgate or dirShort

// ?巨???文?嚗??函巨??0 ??? ST 撠(true)嚗???Ｚ炊???香
voteLongPass  = enabledVotes == 0 ? true : votesLong  >= effMinVotes
voteShortPass = enabledVotes == 0 ? true : votesShort >= effMinVotes
// MTF ?Ｙ?瑽??漲?蔥?仿???gate嚗ND嚗?閮剝?靘?ablation嚗ffMTFgate 撌脣 usePureA嚗?regimeLongOK  = not useRegime or (voteLongPass  and diLongOK  and mtfBullOK)
regimeShortOK = not useRegime or (voteShortPass and diShortOK and mtfBearOK)
// regime 撘瑕摹嚗??/?銵冽嚗?隞颱??孵???瑼餉???trend-on
regimeOn = (voteLongPass and dirLong) or (voteShortPass and dirShort)

