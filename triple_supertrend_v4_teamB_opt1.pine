var bool  tp2Done = false
// ? high-water R嚗eak-anchored ????嚗nline ?蔭甇賊
var float peakR = 0.0
// 銝活?瑟 peakR ??蝝Ｗ?嚗隅?Ｗ僑朣??趙閮??剁?嚗?啣陸?澆?湔????脣?蔭
var int   peakBar = 0
