    table.cell(dash, 0, 10, "?質?% / 摰?迂%", text_color=txc, bgcolor=bgH, text_size=size.small)
    table.cell(dash, 1, 10, inPos ? str.tostring(bankedPctH, "#.0") + "% / " + str.tostring(claimedPctH, "#.0") + "%" : "??, text_color=txc, bgcolor=bgV, text_size=size.small)
    table.cell(dash, 0, 11, "?孵?銝?游漲", text_color=txc, bgcolor=bgH, text_size=size.small)
    table.cell(dash, 1, 11, inPos ? str.tostring(cohNow) + "/3 " + (cohNow >= 3 ? "(銝偕摨血??)" : cohNow <= 1 ? "(敹怠偕摨血歇?)" : "(銝剜?") : "??, text_color=txc, bgcolor=inPos and cohNow >= 3 ? color.new(color.green, 35) : inPos and cohNow <= 1 ? color.new(color.orange, 35) : bgV, text_size=size.small)
    table.cell(dash, 0, 12, "撜啣澆?皛?撟湧翩", text_color=txc, bgcolor=bgH, text_size=size.small)
