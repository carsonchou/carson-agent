    table.cell(dash, 1, 17, modLine1, text_color=txc, bgcolor=usePureA ? color.new(color.gray, 20) : color.new(color.purple, 45), text_size=size.small)
    table.cell(dash, 0, 18, "?脤?璈(2/6)", text_color=txc, bgcolor=bgH, text_size=size.small)
