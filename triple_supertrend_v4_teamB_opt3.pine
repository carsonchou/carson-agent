// ?? 瘥?????蝝蝺?撘瑕?????脤?璈 ????????????????????????????????
effPeakRatchet     = usePeakRatchet     and not usePureA
effRegimeFade      = useRegimeFade      and not usePureA
effAdaptiveTS      = useAdaptiveTS      and not usePureA
effMTFgate         = useMTFgate         and not usePureA
effBreathGB        = useBreathGiveback  and not usePureA   // 瘜Ｗ??芷????
effTPstair         = useTPstairBE       and not usePureA   // TP ?０?唳
effBreathTrail     = useBreathTrail     and not usePureA   // 瘜Ｗ??芷?蜓 trail
effCoherenceTrail  = useCoherenceTrail  and not usePureA   // 憭偕摨行???游漲 ratchet
effBankedFloor     = useBankedFloor     and not usePureA   // 撌脣祕?曄?拚靽?唳
effAdaptiveCooldown= useAdaptiveCooldown and not usePureA  // 撠迂?澆撘脣?瑕
effDecorrGauge     = useDecorrVolGauge  and not usePureA   // ?餌?郭??閬?ATR% ?曉?雿?
effStallRatchet    = useStallRatchet    and not usePureA   // 頞典撟湧翩????唳
effMultiScaleStop  = useMultiScaleStop  and not usePureA   // NEW-1 頝典偕摨?ATR ?折?甇Ｘ?
effEntryDistGate   = useEntryDistGate   and not usePureA   // NEW-2 ?脣???孵榆蝣箄???effCoherenceAdd    = useCoherenceAdd    and not usePureA   // NEW-3 coherence ?Ⅳ靽∪艙??effGapGiveback     = useGapGiveback     and not usePureA   // NEW-5 頝喟征皛?菜葫?駁◢??effGivebackTP      = useGivebackTP      and not usePureA   // NEW-6 撜啣澆???蝚砌?畾菔鋡?effCohPersistGate  = useCohPersistGate  and not usePureA   // NEW-7 憭偕摨虫??游漲???折脣??effRiskBudgetCap   = useRiskBudgetCap   and not usePureA   // NEW-8 ?桃??賡憸券??銝???
// ?曉?雿?閬?撠?????乩蝙?刻? Lo/Hi ?蔭嚗??swap 蝬剜??株矽
pctlLo = math.min(pctlGaugeLo, pctlGaugeHi)
pctlHi = math.max(pctlGaugeLo, pctlGaugeHi)

// ????????????????????????????????????????????????????????????????????????????
// 禮2  銝惜 SuperTrend嚗銝?箇??望?瘣曄?嚗a.supertrend ? [value,direction]嚗?//     direction < 0 ?箏???// ????????????????????????????????????????????????????????????????????????????
len1 = baseLen
len2 = math.max(math.round(baseLen * midMult), 2)
len3 = math.max(math.round(baseLen * slowMult), 3)
[st1, dir1] = ta.supertrend(f1, len1)
[st2, dir2] = ta.supertrend(f2, len2)
[st3, dir3] = ta.supertrend(f3, len3)

st1Bull = dir1 < 0
st2Bull = dir2 < 0
st3Bull = dir3 < 0
st1Bear = not st1Bull
st2Bear = not st2Bull
st3Bear = not st3Bull
// 蝧餉?鈭辣嚗??格?暺???
st1FlipUp   = st1Bull and not st1Bull[1]
st2FlipUp   = st2Bull and not st2Bull[1]
st3FlipUp   = st3Bull and not st3Bull[1]
st1FlipDn   = st1Bear and not st1Bear[1]
st2FlipDn   = st2Bear and not st2Bear[1]
st3FlipDn   = st3Bear and not st3Bear[1]

// ST3 蝧餃?敺?瘣餅??賂??Ｙ?瑽??漲嚗?璉閮? request.security ?鼓憸券嚗?var int st3BullBars = 0
var int st3BearBars = 0
st3BullBars := st3Bull ? nz(st3BullBars[1]) + 1 : 0
st3BearBars := st3Bear ? nz(st3BearBars[1]) + 1 : 0
persistBars  = math.min(math.max(len3, 3), mtfCapBars)
mtfBullOK    = not effMTFgate or (st3Bull and st3BullBars >= persistBars)
mtfBearOK    = not effMTFgate or (st3Bear and st3BearBars >= persistBars)

// 憭偕摨行???游漲嚗???ST ?賂?憭征??嚗?啣? input???孵?蝯?嚗?coherenceLong  = (st1Bull?1:0) + (st2Bull?1:0) + (st3Bull?1:0)
coherenceShort = (st1Bear?1:0) + (st2Bear?1:0) + (st3Bear?1:0)

// [NEW-7] 憭偕摨虫??游漲???扯??詨嚗oherence>=cohPersistMin ???蝝航???飛?嗚?//   蝝??瑽??詻??憸券(???祆??風????蝛箏?蝬剛風銝璇?var int cohRunLong  = 0
var int cohRunShort = 0
cohRunLong  := coherenceLong  >= cohPersistMin ? nz(cohRunLong[1])  + 1 : 0
cohRunShort := coherenceShort >= cohPersistMin ? nz(cohRunShort[1]) + 1 : 0
// 擐???折?嚗??????true嚗??寡??Ｘ?擐銵嚗?蝛箏?潮??
cohPersistLongOK  = not effCohPersistGate or cohRunLong  >= cohPersistBars
cohPersistShortOK = not effCohPersistGate or cohRunShort >= cohPersistBars

// ????????????????????????????????????????????????????????????????????????????
// 禮3  ATR% 甇???皞???????瑼颱?敺撠?嚗?頝典???蝝情??
// ????????????????????????????????????????????????????????????????????????????
atrAdx   = ta.atr(adxLen)
atrChand = ta.atr(chandLen)
atrPct   = atrAdx / close              // ATR%嚗撠??箸?嚗?
// ????????????????????????????????????????????????????????????????????????????
// 禮4  瘜Ｗ??摯閮?撟游??撠?嚗? VT-Core ??
// ????????????????????????????????????????????????????????????????????????????
logRet      = math.log(close / close[1])
stdevDaily  = ta.stdev(logRet, volLen)
volAnnATR   = atrPct       * math.sqrt(barsPerYear)   // ATR% 撟游?
volAnnStd   = stdevDaily   * math.sqrt(barsPerYear)   // ?梢 std 撟游?
instVolAnn  = volEstMode == "Stdev" ? volAnnStd : volAnnATR
volFloor    = ta.percentile_linear_interpolation(instVolAnn, brakeLen, 5)
volFloor   := na(volFloor) ? 0.02 : math.max(volFloor, 0.001)
instVolAnn := math.max(nz(instVolAnn, volFloor), volFloor)
volMedian   = ta.median(instVolAnn, brakeLen)
volMedian  := na(volMedian) ? instVolAnn : math.max(volMedian, volFloor)
relVol      = instVolAnn / volMedian
volBrakeOn  = useVolBrake and relVol > brakeK     // true=擃郭???怠??Ⅳ
breathClamp = math.min(math.max(relVol, 1.0), brakeK)
atrPctRank  = ta.percentrank(atrPct, brakeLen)        // 0~100
breathPctl  = pctlLo + nz(atrPctRank, 50.0) / 100.0 * (pctlHi - pctlLo)   // [pctlLo, pctlHi]
var int floorHits = 0
if instVolAnn <= volFloor + 1e-12
    floorHits += 1

// ????????????????????????????????????????????????????????????????????????????
// 禮5  Regime ??嚗R / ADX ?脫趙 / ST3 ?Ｘ??嚗? ?巨?券??脤?甇?// ????????????????????????????????????????????????????????????????????????????
erChange = math.abs(close - close[erLen])
erVolSum = math.sum(math.abs(close - close[1]), erLen)
er       = erVolSum > 0 ? erChange / erVolSum : 0.0
er      := nz(er, 0.0)

[diPlus, diMinus, adx] = ta.dmi(adxLen, adxLen)
var bool adxOn_state = false
if adx > adxOn
    adxOn_state := true
else if adx < adxOff
    adxOn_state := false

slowBull = st3Bull
slowBear = st3Bear

voteER_long   = useER     and er > erThr
voteADX_long  = useADX    and adxOn_state
voteSlow_long = useSlowST and slowBull
voteER_short  = useER     and er > erThr
voteADX_short = useADX    and adxOn_state
voteSlow_short= useSlowST and slowBear
votesLong  = (voteER_long?1:0)  + (voteADX_long?1:0)  + (voteSlow_long?1:0)
votesShort = (voteER_short?1:0) + (voteADX_short?1:0) + (voteSlow_short?1:0)
enabledVotes = (useER?1:0) + (useADX?1:0) + (useSlowST?1:0)
effMinVotes  = math.min(minVotes, enabledVotes)
votesUnreachable = minVotes > enabledVotes
dirLong  = diPlus  > diMinus
dirShort = diMinus > diPlus
diLongOK  = not useDIgate or dirLong
diShortOK = not useDIgate or dirShort

voteLongPass  = enabledVotes == 0 ? true : votesLong  >= effMinVotes
voteShortPass = enabledVotes == 0 ? true : votesShort >= effMinVotes
regimeLongOK  = not useRegime or (voteLongPass  and diLongOK  and mtfBullOK)
regimeShortOK = not useRegime or (voteShortPass and diShortOK and mtfBearOK)
regimeOn = (voteLongPass and dirLong) or (voteShortPass and dirShort)

// ????????????????????????????????????????????????????????????????????????????
// 禮6  ???嚗銝?嚗誑?惜?典 bool ?遣 stage嚗?// ????????????????????????????????????????????????????????????????????????????
var bool  l1On = false
var bool  l2On = false
var bool  l3On = false
var bool  s1On = false
var bool  s2On = false
var bool  s3On = false
var int   entryBar  = na    // [?芣晾靽格迤3] ?典像?寥?蝵桃 na嚗?蝯?bar_index-0 瘙⊥? timeStop
var float entryPx   = na
var float entryRisk = na
var float trailExt  = na
var float trailStop = na
var float cooldownUntil = 0.0
var bool  tp1Done = false
var bool  tp2Done = false
var bool  gbTPDone = false   // [NEW-6] 撜啣澆???蝚砌?畾菔鋡?one-shot ??var float peakR = 0.0
var int   peakBar = 0
var float bankedQty = 0.0
var float openInitQty = 0.0
var bool  fadeArmed     = true
var int   lastFadeBar   = -100000
var float notL1 = 0.0
var float notL2 = 0.0
var float notL3 = 0.0
var float notS1 = 0.0
var float notS2 = 0.0
var float notS3 = 0.0

inLong  = strategy.position_size > 0
inShort = strategy.position_size < 0
inPos   = strategy.position_size != 0
posSize = math.abs(strategy.position_size)
avgPx   = strategy.position_avg_price

if not inPos
    l1On := false
    l2On := false
    l3On := false
    s1On := false
    s2On := false
    s3On := false
    entryRisk := na
    entryPx   := na
    entryBar  := na
    trailExt  := na
    trailStop := na
    tp1Done   := false
    tp2Done   := false
    gbTPDone  := false      // [NEW-6] ??撘鋡??蔭
    peakR     := 0.0
    peakBar   := bar_index
    bankedQty := 0.0
    openInitQty := 0.0
    fadeArmed := true
    notL1 := 0.0
    notL2 := 0.0
    notL3 := 0.0
    notS1 := 0.0
    notS2 := 0.0
    notS3 := 0.0

longStage  = (l1On?1:0) + (l2On?1:0) + (l3On?1:0)
shortStage = (s1On?1:0) + (s2On?1:0) + (s3On?1:0)
stage = inLong ? longStage : inShort ? shortStage : 0   // 璉??潘??? 禮9 ?典像閫貊雿輻

// ????????????????????????????????????????????????????????????????????????????
// 禮7  ??閮?嚗T-Core嚗?// ????????????????????????????????????????????????????????????????????????????
var float avgEq = na
avgEq := na(avgEq) ? strategy.equity : avgEq * eqBlendSmooth + strategy.equity * (1.0 - eqBlendSmooth)
sizeBase = eqBlendInit * strategy.initial_capital + (1.0 - eqBlendInit) * avgEq

vtScale = useVolTarget ? targetVol / instVolAnn : 1.0
convMult = useConvAdd and erThr > 0 ? math.min(math.max(er / erThr, 0.5), 1.0) : 1.0
wL2eff = wL2 * convMult
wL3eff = wL3 * convMult
totW    = wL1 + wL2 + wL3
var int capHits = 0

qtyFor(w) =>
    float notion = vtScale * sizeBase * w
    float nCap = totW > 0 ? sizeBase * maxGross * (w / totW) : sizeBase * maxGross
    bool  capped = notion > nCap
    notion := math.min(notion, nCap)
    float q = close > 0 ? notion / close : 0.0
    q := math.max(nz(q, 0.0), 0.0)
    [q, capped]

[qty1Raw, cap1] = qtyFor(wL1)
[qty2, cap2] = qtyFor(wL2eff)
[qty3, cap3] = qtyFor(wL3eff)

// [NEW-8] ?桃??賡憸券??銝?嚗??園???qty1 雿?qty1?(chandMult?atrChand) ??riskBudgetFrac?sizeBase??//   ?芯??券???L1)????sizeBase/chandMult/atrChand??蝛粹??qty ???孵?銝剜???//   ????not effRiskBudgetCap)???憪?qty1Raw嚗??寡??Ｘ?擐銝??initStopDist = chandMult * atrChand
riskCapQty   = (effRiskBudgetCap and initStopDist > 0) ? riskBudgetFrac * sizeBase / initStopDist : na
riskBudgetBindL1 = effRiskBudgetCap and not na(riskCapQty) and qty1Raw > riskCapQty
qty1 = riskBudgetBindL1 ? math.max(riskCapQty, 0.0) : qty1Raw

// ????????????????????????????????????????????????????????????????????????????
// 禮8  R-multiple ??Chandelier ratchet ??嚗?蝛粹??only-up / only-down嚗?// ????????????????????????????????????????????????????????????????????????????
rDenom  = na(entryRisk) ? (chandMult * atrChand) : entryRisk
rBasePx = na(entryPx)   ? avgPx : entryPx
R = inPos and rDenom > 0 ? (inLong ? (close - rBasePx) / rDenom : (rBasePx - close) / rDenom) : 0.0
if inPos
    if R > peakR
        peakR   := R
        peakBar := bar_index
barsSincePeak = inPos ? math.max(bar_index - peakBar, 0) : 0

multStepBase = not useRStep ? chandMult : (R < 1 ? chandMult : R < 2 ? trailMidR : trailTightR)
multStep = multStepBase
trailBreath = effDecorrGauge ? breathPctl : breathClamp
if effBreathTrail and useRStep and inPos and R >= 1
    float bt = multStepBase * trailBreath
    multStep := math.min(math.max(bt, trailTightR), chandMult)
if effCoherenceTrail and useRStep and inPos and R >= 1
    int coh = inLong ? coherenceLong : coherenceShort
    if coh >= 3
        multStep := math.min(multStep * cohRelaxK, chandMult)
    else if coh <= 1
        multStep := math.min(multStep, trailTightR)

beActive = (useBE and R >= kBE) or (useBEonTP1 and tp1Done)

breathMult = effBreathGB ? breathClamp : 1.0
stallFrac   = barsSincePeak * 1.0 / math.max(timeStopBars, 1)
stallShrink = effStallRatchet and timeStopBars > 0 ? math.min(math.max(1.0 - stallFrac, stallShrinkMin), 1.0) : 1.0
effGiveback= multBE * breathMult * stallShrink
peakFloorOn= effPeakRatchet and inPos and peakR > effGiveback

stairRungs   = (tp1Done ? 1 : 0) + (tp2Done ? 1 : 0)
tpStairOn    = effTPstair and inPos and stairRungs > 0
tpStairFloorL= rBasePx + stairRungs * multBE * rDenom
tpStairFloorS= rBasePx - stairRungs * multBE * rDenom

bankFrac      = openInitQty > 1e-9 ? math.min(bankedQty / openInitQty, 1.0) : 0.0
bankedFloorOn = effBankedFloor and inPos and bankFrac > 1e-9
bankedFloorL  = rBasePx + bankFrac * rDenom
bankedFloorS  = rBasePx - bankFrac * rDenom

// ?? [NEW-1] 頝典偕摨?ATR ?折?甇Ｘ??⊥? ?????????????????????????????????????????????
st3Band  = na(st3) ? atrChand : math.abs(close - st3)
useMSnow = effMultiScaleStop and beActive
atrScale = useMSnow ? math.max(atrChand, st3Band) : atrChand

// ???拙?踹祕??潘?靘?禮8 ratchet ??NEW-4 甇詨???剁?
beFloorL   = rBasePx + multBE * rDenom
beFloorS   = rBasePx - multBE * rDenom
peakFloorL = rBasePx + (peakR - effGiveback) * rDenom
peakFloorS = rBasePx - (peakR - effGiveback) * rDenom

if useChandelier and inLong
    trailExt  := na(trailExt) ? high : math.max(trailExt, high)
    rawStop    = trailExt - multStep * atrScale            // [NEW-1] 撠箏漲?唳嚗trScale
    trailStop := na(trailStop) ? rawStop : math.max(trailStop, rawStop)
    if beActive
        trailStop := math.max(trailStop, beFloorL)
    if tpStairOn
        trailStop := math.max(trailStop, tpStairFloorL)
    if bankedFloorOn
        trailStop := math.max(trailStop, bankedFloorL)
    if peakFloorOn
        trailStop := math.max(trailStop, peakFloorL)
else if useChandelier and inShort
    trailExt  := na(trailExt) ? low : math.min(trailExt, low)
    rawStop    = trailExt + multStep * atrScale            // [NEW-1] 撠箏漲?唳嚗trScale
    trailStop := na(trailStop) ? rawStop : math.min(trailStop, rawStop)
    if beActive
        trailStop := math.min(trailStop, beFloorS)
    if tpStairOn
        trailStop := math.min(trailStop, tpStairFloorS)
    if bankedFloorOn
        trailStop := math.min(trailStop, bankedFloorS)
    if peakFloorOn
        trailStop := math.min(trailStop, peakFloorS)

// ?? [NEW-4] 靽?唳甇詨?嚗??航?皜祆改???
var string floorSrcTxt = "??
floorSrcTxt := "??
if useFloorAttrib and inPos and not na(trailStop)
    if inLong
        float bestGap = 1e18
        if beActive and math.abs(trailStop - beFloorL) < bestGap
            bestGap := math.abs(trailStop - beFloorL)
            floorSrcTxt := "靽"
        if tpStairOn and math.abs(trailStop - tpStairFloorL) < bestGap
            bestGap := math.abs(trailStop - tpStairFloorL)
            floorSrcTxt := "?０"
        if bankedFloorOn and math.abs(trailStop - bankedFloorL) < bestGap
            bestGap := math.abs(trailStop - bankedFloorL)
            floorSrcTxt := "撌脣祕?暸"
        if peakFloorOn and math.abs(trailStop - peakFloorL) < bestGap
            bestGap := math.abs(trailStop - peakFloorL)
            floorSrcTxt := "撜啣澆???
        if bestGap > 1e17
            floorSrcTxt := "Chandelier"
    else
        float bestGap = 1e18
        if beActive and math.abs(trailStop - beFloorS) < bestGap
            bestGap := math.abs(trailStop - beFloorS)
            floorSrcTxt := "靽"
        if tpStairOn and math.abs(trailStop - tpStairFloorS) < bestGap
            bestGap := math.abs(trailStop - tpStairFloorS)
            floorSrcTxt := "?０"
        if bankedFloorOn and math.abs(trailStop - bankedFloorS) < bestGap
            bestGap := math.abs(trailStop - bankedFloorS)
            floorSrcTxt := "撌脣祕?暸"
        if peakFloorOn and math.abs(trailStop - peakFloorS) < bestGap
            bestGap := math.abs(trailStop - peakFloorS)
            floorSrcTxt := "撜啣澆???
        if bestGap > 1e17
            floorSrcTxt := "Chandelier"

// ????????????????????????????????????????????????????????????????????????????
// 禮9  ?箏閫貊嚗??蝔梧?頞典???箔蜓?箏嚗?// ????????????????????????????????????????????????????????????????????????????
trailHitLong  = useChandelier and inLong  and not na(trailStop) and close < trailStop
trailHitShort = useChandelier and inShort and not na(trailStop) and close > trailStop
twoSTRevLong  = inLong  and st1Bear and st2Bear
twoSTRevShort = inShort and st1Bull and st2Bull
tsScale     = effAdaptiveTS and erThr > 0 ? math.min(math.max(er / erThr, 0.5), 1.0) : 1.0
effTimeStop = math.max(math.round(timeStopBars * tsScale), 1)
tsAge         = na(entryBar) ? 0 : (bar_index - entryBar)
timeStopLong  = useTimeStop and inLong  and not na(entryBar) and tsAge >= effTimeStop and R < 1 and stage < 3
timeStopShort = useTimeStop and inShort and not na(entryBar) and tsAge >= effTimeStop and R < 1 and stage < 3

// ????????????????????????????????????????????????????????????????????????????
// 禮10  銝?瑁?嚗??箏敺脣嚗?璉????喳?甇伐?
// ????????????????????????????????????????????????????????????????????????????
var bool exitedThisBar = false
exitedThisBar := false

var float posLive = 0.0
posLive := posSize

bool fullExitNow = false

// [?芣晾靽格迤 1+2嚚ntrabar hardstop ????芣晾 + ?箏?芸?摨??包
liveStopLong  = useHardStop and inLong  and not na(trailStop[1])
liveStopShort = useHardStop and inShort and not na(trailStop[1])
if useHardStop and inLong and not na(trailStop)
    strategy.exit("hX-L", stop=trailStop, comment="HardStopL")
if useHardStop and inShort and not na(trailStop)
    strategy.exit("hX-S", stop=trailStop, comment="HardStopS")
// ?支葉?漱?菜葫嚗?朣?璉??? live stop(trailStop[1])
bool brokerStopHit = (liveStopLong and low <= trailStop[1]) or (liveStopShort and high >= trailStop[1])
bool blockPartials = brokerStopHit
if brokerStopHit
    exitedThisBar := true

// [NEW-5] 頝喟征皛瘛勗漲嚗rokerStopHit 璉?嚗誑 ATR 甇????靘?游??瑕?曉之??//   憭? low 頝忽 trailStop[1] ?撩??征??high ?忽?撩???啣? input(銴 atrChand)??float gapDepth = 1.0
if brokerStopHit and atrChand > 0 and not na(trailStop[1])
    float gp = liveStopLong ? (trailStop[1] - low) : (high - trailStop[1])
    gapDepth := math.max(gp / atrChand, 1.0)
gapWide = effGapGiveback and brokerStopHit and gapDepth > brakeK   // ?啣虜頝喟征?文?

// ??銝餃??A嚗handelier trailStop嚗?斤Ⅱ隤? ??if not exitedThisBar and trailHitLong
    strategy.close_all(comment="TrailL")
    fullExitNow := true
else if not exitedThisBar and trailHitShort
    strategy.close_all(comment="TrailS")
    fullExitNow := true

// ???箏 B嚗? ST ??摨? ??if not exitedThisBar and not fullExitNow and twoSTRevLong
    strategy.close_all(comment="2STrevL")
    fullExitNow := true
else if not exitedThisBar and not fullExitNow and twoSTRevShort
    strategy.close_all(comment="2STrevS")
    fullExitNow := true

// ???箏 C嚗???????if not exitedThisBar and not fullExitNow and (timeStopLong or timeStopShort)
    strategy.close_all(comment="TimeStop")
    fullExitNow := true

// [inline ?典像?蔭] ??單撅?close_all ?箏閫貊嚗rokerStopHit 頝臬?銝粥甇方???if fullExitNow
    l1On := false
    l2On := false
    l3On := false
    s1On := false
    s2On := false
    s3On := false
    entryRisk := na
    entryPx   := na
    entryBar  := na
    trailExt  := na
    trailStop := na
    tp1Done   := false
    tp2Done   := false
    gbTPDone  := false      // [NEW-6] ??撘鋡??蔭
    peakR     := 0.0
    peakBar   := bar_index
    bankedQty := 0.0
    openInitQty := 0.0
    fadeArmed := true
    notL1 := 0.0
    notL2 := 0.0
    notL3 := 0.0
    notS1 := 0.0
    notS2 := 0.0
    notS3 := 0.0
    exitedThisBar := true
    float effCooldown = effAdaptiveCooldown ? math.max(math.round(cooldownBars * breathClamp), 0) : cooldownBars
    cooldownUntil := bar_index + effCooldown
    posLive := 0.0

// [NEW-5] brokerStopHit 頝臬?銝粥 禮10 fullExit(?詨??芾?撟喳?銝?璉?禮6 ?蔭)嚗??箏敺??//   隞??冽迨閮剖??撣貉歲蝛箸???颱?銝?clamp(gapDepth,1,brakeK) ?曉之嚗?撅文?蝡?脯?if brokerStopHit
    float baseCd = effAdaptiveCooldown ? math.max(math.round(cooldownBars * breathClamp), 0) : cooldownBars
    float gapMult = gapWide ? math.min(gapDepth, brakeK) : 1.0
    cooldownUntil := bar_index + math.max(math.round(baseCd * gapMult), 0)

// ?? contiguous-stack ?臭?皜?隤?蝝撘?top-first drain嚗??
drainLong(reqQty, posAbs, n3, n2, n1) =>
    float want = math.min(math.max(nz(reqQty, 0.0), 0.0), posAbs)
    float done = 0.0
    float r3 = n3
    float r2 = n2
    float r1 = n1
    if r3 > 1e-9 and want - done > 1e-9
        float take = math.min(want - done, r3)
        if take > 1e-9
            strategy.close("L3", qty=take, comment="cut-L3")
            r3   := r3 - take
            done := done + take
    if r2 > 1e-9 and want - done > 1e-9
        float take = math.min(want - done, r2)
        if take > 1e-9
            strategy.close("L2", qty=take, comment="cut-L2")
            r2   := r2 - take
            done := done + take
    if r1 > 1e-9 and want - done > 1e-9
        float take = math.min(want - done, r1)
        if take > 1e-9
            strategy.close("L1", qty=take, comment="cut-L1")
            r1   := r1 - take
            done := done + take
    [done, r3, r2, r1, r3 > 1e-9, r2 > 1e-9, r1 > 1e-9]
drainShort(reqQty, posAbs, n3, n2, n1) =>
    float want = math.min(math.max(nz(reqQty, 0.0), 0.0), posAbs)
    float done = 0.0
    float r3 = n3
    float r2 = n2
    float r1 = n1
    if r3 > 1e-9 and want - done > 1e-9
        float take = math.min(want - done, r3)
        if take > 1e-9
            strategy.close("S3", qty=take, comment="cut-S3")
            r3   := r3 - take
            done := done + take
    if r2 > 1e-9 and want - done > 1e-9
        float take = math.min(want - done, r2)
        if take > 1e-9
            strategy.close("S2", qty=take, comment="cut-S2")
            r2   := r2 - take
            done := done + take
    if r1 > 1e-9 and want - done > 1e-9
        float take = math.min(want - done, r1)
        if take > 1e-9
            strategy.close("S1", qty=take, comment="cut-S1")
            r1   := r1 - take
            done := done + take
    [done, r3, r2, r1, r3 > 1e-9, r2 > 1e-9, r1 > 1e-9]

trancheTopLong(on3, on2, on1, n3, n2, n1) =>
    on3 ? n3 : on2 ? n2 : on1 ? n1 : 0.0
trancheTopShort(on3, on2, on1, n3, n2, n1) =>
    on3 ? n3 : on2 ? n2 : on1 ? n1 : 0.0

// ?? ?挾 R-multiple Partial TP ??
tpHitL1 = usePartialTP and not exitedThisBar and not blockPartials and inLong  and R >= tp1R and not tp1Done
tpHitL2 = usePartialTP and not exitedThisBar and not blockPartials and inLong  and R >= tp2R and not tp2Done
tpHitS1 = usePartialTP and not exitedThisBar and not blockPartials and inShort and R >= tp1R and not tp1Done
tpHitS2 = usePartialTP and not exitedThisBar and not blockPartials and inShort and R >= tp2R and not tp2Done
if tpHitL1
    [d, n3, n2, n1, o3, o2, o1] = drainLong(posLive * tp1Pct / 100.0, posLive, notL3, notL2, notL1)
    notL3 := n3
    notL2 := n2
    notL1 := n1
    l3On  := o3
    l2On  := o2
    l1On  := o1
    bankedQty := bankedQty + d
    posLive   := math.max(posLive - d, 0.0)
    tp1Done := true
if tpHitL2
    [d, n3, n2, n1, o3, o2, o1] = drainLong(posLive * tp2Pct / 100.0, posLive, notL3, notL2, notL1)
    notL3 := n3
    notL2 := n2
    notL1 := n1
    l3On  := o3
    l2On  := o2
    l1On  := o1
    bankedQty := bankedQty + d
    posLive   := math.max(posLive - d, 0.0)
    tp2Done := true
if tpHitS1
    [d, n3, n2, n1, o3, o2, o1] = drainShort(posLive * tp1Pct / 100.0, posLive, notS3, notS2, notS1)
    notS3 := n3
    notS2 := n2
    notS1 := n1
    s3On  := o3
    s2On  := o2
    s1On  := o1
    bankedQty := bankedQty + d
    posLive   := math.max(posLive - d, 0.0)
    tp1Done := true
if tpHitS2
    [d, n3, n2, n1, o3, o2, o1] = drainShort(posLive * tp2Pct / 100.0, posLive, notS3, notS2, notS1)
    notS3 := n3
    notS2 := n2
    notS1 := n1
    s3On  := o3
    s2On  := o2
    s1On  := o1
    bankedQty := bankedQty + d
    posLive   := math.max(posLive - d, 0.0)
    tp2Done := true

// ?? [NEW-6] 撜啣澆???蝚砌?畾菔鋡???撠?R 瘞港?甇?漱嚗??
gbTrigR     = multBE * 2.0
gbReady     = effGivebackTP and not exitedThisBar and not blockPartials and tp1Done and tp2Done and not gbTPDone and inPos and peakR > 0 and (peakR - R) >= gbTrigR
gbHitL      = gbReady and inLong  and (l1On or l2On or l3On)
gbHitS      = gbReady and inShort and (s1On or s2On or s3On)
if gbHitL
    [d, n3, n2, n1, o3, o2, o1] = drainLong(posLive * tp2Pct / 100.0, posLive, notL3, notL2, notL1)
    notL3 := n3
    notL2 := n2
    notL1 := n1
    l3On  := o3
    l2On  := o2
    l1On  := o1
    bankedQty := bankedQty + d
    posLive   := math.max(posLive - d, 0.0)
    gbTPDone  := true
if gbHitS
    [d, n3, n2, n1, o3, o2, o1] = drainShort(posLive * tp2Pct / 100.0, posLive, notS3, notS2, notS1)
    notS3 := n3
    notS2 := n2
    notS1 := n1
    s3On  := o3
    s2On  := o2
    s1On  := o1
    bankedQty := bankedQty + d
    posLive   := math.max(posLive - d, 0.0)
    gbTPDone  := true

// ???箏 D嚗T ???挾皜?cut嚗????cutL1 = usePartialST and not exitedThisBar and not blockPartials and inLong  and st1FlipDn and (l1On or l2On or l3On)
cutL2 = usePartialST and not exitedThisBar and not blockPartials and inLong  and st2FlipDn and (l2On or l3On)
cutS1 = usePartialST and not exitedThisBar and not blockPartials and inShort and st1FlipUp and (s1On or s2On or s3On)
cutS2 = usePartialST and not exitedThisBar and not blockPartials and inShort and st2FlipUp and (s2On or s3On)
if cutL1
    float tr = trancheTopLong(l3On, l2On, l1On, notL3, notL2, notL1)
    if tr > 1e-9
        [d, n3, n2, n1, o3, o2, o1] = drainLong(tr, posLive, notL3, notL2, notL1)
        notL3 := n3
        notL2 := n2
        notL1 := n1
        l3On  := o3
        l2On  := o2
        l1On  := o1
        posLive := math.max(posLive - d, 0.0)
if cutL2
    float tr = trancheTopLong(l3On, l2On, l1On, notL3, notL2, notL1)
    if tr > 1e-9
        [d, n3, n2, n1, o3, o2, o1] = drainLong(tr, posLive, notL3, notL2, notL1)
        notL3 := n3
        notL2 := n2
        notL1 := n1
        l3On  := o3
        l2On  := o2
        l1On  := o1
        posLive := math.max(posLive - d, 0.0)
if cutS1
    float tr = trancheTopShort(s3On, s2On, s1On, notS3, notS2, notS1)
    if tr > 1e-9
        [d, n3, n2, n1, o3, o2, o1] = drainShort(tr, posLive, notS3, notS2, notS1)
        notS3 := n3
        notS2 := n2
        notS1 := n1
        s3On  := o3
        s2On  := o2
        s1On  := o1
        posLive := math.max(posLive - d, 0.0)
if cutS2
    float tr = trancheTopShort(s3On, s2On, s1On, notS3, notS2, notS1)
    if tr > 1e-9
        [d, n3, n2, n1, o3, o2, o1] = drainShort(tr, posLive, notS3, notS2, notS1)
        notS3 := n3
        notS2 := n2
        notS1 := n1
        s3On  := o3
        s2On  := o2
        s1On  := o1
        posLive := math.max(posLive - d, 0.0)

// ???箏 E嚗egime-fade ?詨??駁◢????if not inPos or er >= erThr
    fadeArmed := true
fadeTrig    = effRegimeFade and not exitedThisBar and not blockPartials and erThr > 0 and er < erThr * fadeK
fadeReady   = fadeArmed and (bar_index - lastFadeBar) >= fadeCoolBars
fadeStageLong  = (l1On?1:0) + (l2On?1:0) + (l3On?1:0)
fadeStageShort = (s1On?1:0) + (s2On?1:0) + (s3On?1:0)
regimeFadeLong  = fadeTrig and inLong  and fadeStageLong  >= 2 and fadeReady
regimeFadeShort = fadeTrig and inShort and fadeStageShort >= 2 and fadeReady
if regimeFadeLong
    float tr = trancheTopLong(l3On, l2On, l1On, notL3, notL2, notL1)
    if tr > 1e-9
        [d, n3, n2, n1, o3, o2, o1] = drainLong(tr, posLive, notL3, notL2, notL1)
        notL3 := n3
        notL2 := n2
        notL1 := n1
        l3On  := o3
        l2On  := o2
        l1On  := o1
        posLive := math.max(posLive - d, 0.0)
    fadeArmed   := false
    lastFadeBar := bar_index
if regimeFadeShort
    float tr = trancheTopShort(s3On, s2On, s1On, notS3, notS2, notS1)
    if tr > 1e-9
        [d, n3, n2, n1, o3, o2, o1] = drainShort(tr, posLive, notS3, notS2, notS1)
        notS3 := n3
        notS2 := n2
        notS1 := n1
        s3On  := o3
        s2On  := o2
        s1On  := o1
        posLive := math.max(posLive - d, 0.0)
    fadeArmed   := false
    lastFadeBar := bar_index

// ???箏 F嚗elowAvg/aboveAvg ?怠惜皜Ⅳ嚗?挾??閮剝?嚗?belowStageLong  = (l1On?1:0) + (l2On?1:0) + (l3On?1:0)
aboveStageShort = (s1On?1:0) + (s2On?1:0) + (s3On?1:0)
belowAvgLong  = useBelowAvg and not exitedThisBar and not blockPartials and inLong  and belowStageLong  >= 2 and close < avgPx - kBuf * atrChand
aboveAvgShort = useBelowAvg and not exitedThisBar and not blockPartials and inShort and aboveStageShort >= 2 and close > avgPx + kBuf * atrChand
if belowAvgLong
    float tr = trancheTopLong(l3On, l2On, l1On, notL3, notL2, notL1)
    if tr > 1e-9
        [d, n3, n2, n1, o3, o2, o1] = drainLong(tr, posLive, notL3, notL2, notL1)
        notL3 := n3
        notL2 := n2
        notL1 := n1
        l3On  := o3
        l2On  := o2
        l1On  := o1
        posLive := math.max(posLive - d, 0.0)
if aboveAvgShort
    float tr = trancheTopShort(s3On, s2On, s1On, notS3, notS2, notS1)
    if tr > 1e-9
        [d, n3, n2, n1, o3, o2, o1] = drainShort(tr, posLive, notS3, notS2, notS1)
        notS3 := n3
        notS2 := n2
        notS1 := n1
        s3On  := o3
        s2On  := o2
        s1On  := o1
        posLive := math.max(posLive - d, 0.0)

// ????????????????????????????????????????????????????????????????????????????
// 禮11  ?脣嚗?蝛箏?潮??
// ????????????????????????????????????????????????????????????????????????????
canEnter = bar_index >= cooldownUntil and not exitedThisBar
curLongStage  = (l1On?1:0) + (l2On?1:0) + (l3On?1:0)
curShortStage = (s1On?1:0) + (s2On?1:0) + (s3On?1:0)
// [NEW-2] ?脣???孵榆蝣箄???entryDistOK = not effEntryDistGate or (not na(st1) and atrChand > 0 and math.abs(close - st1) <= kBuf * atrChand)
// 擐嚗T1 蝧餃? + regime gate(??MTF) + NEW-2 ?脣?孵榆??+ NEW-7 憭偕摨行?蝥折?
l1Cond = curLongStage == 0 and curShortStage == 0 and st1FlipUp and regimeLongOK  and entryDistOK and cohPersistLongOK  and canEnter
s1Cond = curLongStage == 0 and curShortStage == 0 and st1FlipDn and regimeShortOK and entryDistOK and cohPersistShortOK and canEnter
// ?Ⅳ嚗NEW-3] coherence ?Ⅳ靽∪艙??cohAddLongOK  = not effCoherenceAdd or coherenceLong  >= cohAddMin
cohAddShortOK = not effCoherenceAdd or coherenceShort >= cohAddMin
addOK  = not volBrakeOn and R > 0
l2Cond = curLongStage == 1 and l1On and inLong  and st2FlipUp and st1Bull and addOK and cohAddLongOK
l3Cond = curLongStage == 2 and l1On and l2On and inLong  and st3FlipUp and st1Bull and st2Bull and addOK and cohAddLongOK
s2Cond = curShortStage == 1 and s1On and inShort and st2FlipDn and st1Bear and addOK and cohAddShortOK
s3Cond = curShortStage == 2 and s1On and s2On and inShort and st3FlipDn and st1Bear and st2Bear and addOK and cohAddShortOK

if l1Cond
    strategy.entry("L1", strategy.long, qty=qty1, comment="L1")
    entryRisk := chandMult * atrChand
    entryPx   := close
    trailExt  := high
    trailStop := na
    entryBar  := bar_index
    peakR     := 0.0
    peakBar   := bar_index
    gbTPDone  := false
    bankedQty := 0.0
    openInitQty := qty1
    fadeArmed := true
    l1On := true
    notL1 := qty1
if l2Cond
    strategy.entry("L2", strategy.long, qty=qty2, comment="L2")
    l2On := true
    notL2 := qty2
    openInitQty := openInitQty + qty2
if l3Cond
    strategy.entry("L3", strategy.long, qty=qty3, comment="L3")
    l3On := true
    notL3 := qty3
    openInitQty := openInitQty + qty3
if s1Cond
    strategy.entry("S1", strategy.short, qty=qty1, comment="S1")
    entryRisk := chandMult * atrChand
    entryPx   := close
    trailExt  := low
    trailStop := na
    entryBar  := bar_index
    peakR     := 0.0
    peakBar   := bar_index
    gbTPDone  := false
    bankedQty := 0.0
    openInitQty := qty1
    fadeArmed := true
    s1On := true
    notS1 := qty1
if s2Cond
    strategy.entry("S2", strategy.short, qty=qty2, comment="S2")
    s2On := true
    notS2 := qty2
    openInitQty := openInitQty + qty2
if s3Cond
    strategy.entry("S3", strategy.short, qty=qty3, comment="S3")
    s3On := true
    notS3 := qty3
    openInitQty := openInitQty + qty3

if cap1 or cap2 or cap3
    capHits += 1

// 璉 fresh 瘣?stage嚗? 禮12 閬死?? 禮14 stage==opentrades 撠董雿輻??stageLive = inLong ? ((l1On?1:0) + (l2On?1:0) + (l3On?1:0)) : inShort ? ((s1On?1:0) + (s2On?1:0) + (s3On?1:0)) : 0

// ????????????????????????????????????????????????????????????????????????????
// 禮12  閬死???典 global scope嚗?// ????????????????????????????????????????????????????????????????????????????
c1 = st1Bull ? color.new(color.green, 0)  : color.new(color.red, 0)
c2 = st2Bull ? color.new(color.green, 30) : color.new(color.red, 30)
c3 = st3Bull ? color.new(color.green, 55) : color.new(color.red, 55)
plot(showST ? st1 : na, "ST1", color=c1, linewidth=1)
plot(showST ? st2 : na, "ST2", color=c2, linewidth=1)
plot(showST ? st3 : na, "ST3", color=c3, linewidth=2)
plot(showAvg and stageLive >= 1 ? avgPx : na, "AvgCost", color=color.new(color.yellow, 0), linewidth=1, style=plot.style_linebr)
plot(showStop and inPos ? trailStop : na, "TrailStop", color=color.new(color.orange, 0), linewidth=1, style=plot.style_linebr)

bgReg = showBg and regimeOn ? (dirLong ? color.new(color.green, 93) : color.new(color.red, 93)) : na
bgStg = showBg and inPos ? (inLong ? color.new(color.teal, 90 - stageLive * 6) : color.new(color.maroon, 90 - stageLive * 6)) : na
bgcolor(na(bgStg) ? bgReg : bgStg)

plotshape(showSignals and l1Cond, "L1", shape.triangleup,   location.belowbar, color.new(color.lime, 0),   size=size.tiny,   text="L1")
plotshape(showSignals and l2Cond, "L2", shape.triangleup,   location.belowbar, color.new(color.green, 0),  size=size.small,  text="L2")
plotshape(showSignals and l3Cond, "L3", shape.triangleup,   location.belowbar, color.new(color.teal, 0),   size=size.normal, text="L3")
plotshape(showSignals and s1Cond, "S1", shape.triangledown, location.abovebar, color.new(color.orange, 0), size=size.tiny,   text="S1")
plotshape(showSignals and s2Cond, "S2", shape.triangledown, location.abovebar, color.new(color.red, 0),    size=size.small,  text="S2")
plotshape(showSignals and s3Cond, "S3", shape.triangledown, location.abovebar, color.new(color.maroon, 0), size=size.normal, text="S3")
tpAny  = tpHitL1 or tpHitL2 or tpHitS1 or tpHitS2 or gbHitL or gbHitS
cutAny = cutL1 or cutL2 or cutS1 or cutS2
fadeAny= regimeFadeLong or regimeFadeShort
plotshape(showSignals and tpAny,  "TP",   shape.circle,   location.abovebar, color.new(color.aqua, 0),   size=size.tiny, text="TP")
plotshape(showSignals and cutAny, "Cut",  shape.diamond,  location.abovebar, color.new(color.purple, 0), size=size.tiny, text="cut")
plotshape(showSignals and fadeAny,"Fade", shape.xcross,   location.belowbar, color.new(color.fuchsia, 0),size=size.tiny, text="fade")
fullExitMark = trailHitLong or trailHitShort or twoSTRevLong or twoSTRevShort or timeStopLong or timeStopShort or brokerStopHit
plotshape(showSignals and fullExitMark, "OUT", shape.xcross, location.abovebar, color.new(color.red, 0), size=size.tiny, text="X")

// ????????????????????????????????????????????????????????????????????????????
// 禮13  ???銵冽嚗銝? table嚗?漱???其葉?隤???靘?
// ????????????????????????????????????????????????????????????????????????????
regimeTxt = regimeOn ? (dirLong ? "頞典繚憭? : dirShort ? "頞典繚蝛? : "頞典") : "?斗/Range"
posTxt    = inLong ? "憭 蝚? + str.tostring(stageLive) + "畾? : inShort ? "蝛箏 蝚? + str.tostring(stageLive) + "畾? : "?∪?
stopTxt   = inPos and not na(trailStop) ? str.tostring(trailStop, format.mintick) : "??
distR     = inPos and not na(trailStop) and atrChand > 0 ? math.abs(close - trailStop) / atrChand : na
distTxt   = na(distR) ? "?? : str.tostring(distR, "#.0") + " ATR"
exposureRaw = useVolTarget ? vtScale * totW : totW
exposureEff = math.min(exposureRaw, maxGross)
vtTxt     = useVolTarget ? str.tostring(exposureEff, "#.00") + "x (?格?" + str.tostring(targetVol * 100, "#") + "%)" : "?箏?甈?"
ivTxt     = str.tostring(instVolAnn * 100, "#.0") + "%"
tpStateTxt = (tp1Done ? "TP1撌脰鋡? : "TP1?芸") + " / " + (tp2Done ? "TP2撌脰鋡? : "TP2?芸") + (gbTPDone ? " / ???質?" : "")
tpLockTxt  = (tp1Done and useBEonTP1 ? " 繚撌脤?靽" : "") + (tpStairOn ? " 繚?０?唳蝚? + str.tostring(stairRungs) + "蝝? : "") + (bankedFloorOn ? " 繚撌脣祕?暸" + str.tostring(bankFrac * 100, "#") + "%" : "")
tpTxt     = tpStateTxt + tpLockTxt
voteTxt   = "憭? + str.tostring(votesLong) + " 蝛? + str.tostring(votesShort) + " (??? + str.tostring(effMinVotes) + ")" + (votesUnreachable ? " 繚?瑼餃歇蝮? : "")
peakLockTxt = peakFloorOn ? "?????? + (effBreathGB ? " 瘜Ｗ??" + str.tostring(breathMult, "#.0") : "") + (effStallRatchet and stallShrink < 0.999 ? " 撟湧翩?嗥??" + str.tostring(stallShrink, "#.0") : "") : "??????
peakTxt   = inPos ? "撜啣? + str.tostring(peakR, "#.0") + "R 繚 " + peakLockTxt : "??
cohNow    = inLong ? coherenceLong : inShort ? coherenceShort : 0
trailSrcVal = effDecorrGauge ? breathPctl : breathClamp
trailBreathTxt = effBreathTrail ? (effDecorrGauge ? " 繚?曉?雿?蜆? : " 繚瘜Ｗ??澆?") + str.tostring(trailSrcVal, "#.0") : ""
trailCohTxt = effCoherenceTrail ? (cohNow >= 3 ? " 繚銝?游漲撘??曉祝)" : cohNow <= 1 ? " 繚銝?游漲撘??嗥?)" : " 繚銝?游漲銝?) : ""
trailMSTxt  = (useMSnow and st3Band > atrChand) ? " 繚頝典偕摨?ST3 band)" : ""
trailTxt  = inPos ? str.tostring(multStep, "#.0") + "?ATR" + trailBreathTxt + trailCohTxt + trailMSTxt : "??
cdRemain  = math.max(cooldownUntil - bar_index, 0)
cdTxt     = (cdRemain > 0 ? "?瑕銝??? + str.tostring(cdRemain, "#") + "璉? : "撠梁?") + (effAdaptiveCooldown ? " (?芷?? + str.tostring(breathClamp, "#.0") + ")" : "")
stallTxt  = inPos ? "?趙" + str.tostring(barsSincePeak) + "璉? + (effStallRatchet ? (stallShrink < 0.999 ? " 繚?銵啁垠(?唳?嗥?)" : " 繚?隞") : "") : "??
distGateTxt = effEntryDistGate ? ("?Ｚ??" + str.tostring(kBuf, "#.0") + "ATR ?? + (not na(st1) and atrChand > 0 ? " (?曇?" + str.tostring(math.abs(close - st1) / atrChand, "#.0") + "ATR)" : "")) : "??(銝?瞈?"
floorAttribTxt = (useFloorAttrib and inPos and not na(trailStop)) ? floorSrcTxt : "??
// NEW-7 憭偕摨行?蝥抒???憿舐內憭征?拇?????矽閮嚗?persistTxt = effCohPersistGate ? ("??? + str.tostring(cohPersistMin) + "撠箏漲???" + str.tostring(cohPersistBars) + "璉?(?曉?" + str.tostring(cohRunLong) + "/蝛? + str.tostring(cohRunShort) + ")") : "??(銝?瞈?"
// NEW-8 憸券?????riskBudgetTxt = effRiskBudgetCap ? ("?桃??? + str.tostring(riskBudgetFrac * 100, "#.0") + "%?箸?" + (riskBudgetBindL1 ? " 繚撌脩葬?? : " 繚?芰?摰?)) : "??(銝?)"
modLine1  = usePureA ? "蝝蝺??券?脤?璈??)" : ("????" + (effPeakRatchet?"??:"??) + " 瘜Ｗ???:" + (effBreathGB?"??:"??) + " 撟湧翩?唳:" + (effStallRatchet?"??:"??))
modLine2  = usePureA ? "?? : ("?０靽:" + (effTPstair?"??:"??) + " 撌脣祕?暸:" + (effBankedFloor?"??:"??) + " 瘜Ｗ?trail:" + (effBreathTrail?"??:"??))
modLine3  = usePureA ? "?? : ("銝?游漲:" + (effCoherenceTrail?"??:"??) + " ?餌??閬?" + (effDecorrGauge?"??:"??) + " ?芷???" + (effAdaptiveCooldown?"??:"??))
modLine4  = usePureA ? "?? : ("Regime-fade:" + (effRegimeFade?"??:"??) + " ?芷????" + (effAdaptiveTS?"??:"??) + " MTF??" + (effMTFgate?"??:"??))
modLine5  = usePureA ? "?? : ("頝典偕摨行迫??" + (effMultiScaleStop?"??:"??) + " ?脣?孵榆??" + (effEntryDistGate?"??:"??) + " ?Ⅳ靽∪艙??" + (effCoherenceAdd?"??:"??))
modLine6  = usePureA ? "?? : ("頝喟征?駁◢??" + (effGapGiveback?"??:"??) + " ???質?:" + (effGivebackTP?"??:"??) + " ???折?:" + (effCohPersistGate?"??:"??) + " 憸券??:" + (effRiskBudgetCap?"??:"??))
bankedPctH = openInitQty > 1e-9 ? bankedQty / openInitQty * 100.0 : 0.0
claimedPctH= (tp1Done ? tp1Pct : 0.0) + (tp2Done ? tp2Pct : 0.0)

var table dash = table.new(position.top_right, 2, 23, border_width=1, frame_color=color.new(color.gray, 40), frame_width=1)
if showTable and barstate.islast
    bgH = color.new(color.blue, 20)
