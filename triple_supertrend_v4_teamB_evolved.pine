// ????????????????????????????????????????????????????????????????????????????
// 禮14  ?日甈?撌亦??剁?votes / stage=opentrades 撠董 / floor / cap / TP ??/ 靽∪艙 /
//      peakR / ?質?% / 瘜Ｗ??? / ?０ / coherence / 撌脣祕?暸?唳 / ?芷???/ ?曉?雿?/ ?趙 /
//      effTS / 頝典偕摨血??/ ?脣??
//      stage=opentrades 撠董??stageLive(璉 fresh)嚗??璉??? 禮6 璉? stale stage ??//      strategy.opentrades 銝??渲炊?梁撣喋?// ????????????????????????????????????????????????????????????????????????????
bankedPct  = openInitQty > 1e-9 ? bankedQty / openInitQty * 100.0 : 0.0
claimedPct = (tp1Done ? tp1Pct : 0.0) + (tp2Done ? tp2Pct : 0.0)
effCooldownDbg = effAdaptiveCooldown ? math.max(math.round(cooldownBars * breathClamp), 0) : cooldownBars
var table dbg = table.new(position.bottom_right, 2, 23, border_width=1)
if showDebug and barstate.islast
    db = color.new(color.gray, 0)
    table.cell(dbg, 0, 0, "ER", text_color=color.white, bgcolor=db)
    table.cell(dbg, 1, 0, str.tostring(er, "#.00"), text_color=color.white, bgcolor=db)
    table.cell(dbg, 0, 1, "ADX", text_color=color.white, bgcolor=db)
    table.cell(dbg, 1, 1, str.tostring(adx, "#.0"), text_color=color.white, bgcolor=db)
    table.cell(dbg, 0, 2, "votesL/S(eff)", text_color=color.white, bgcolor=db)
    table.cell(dbg, 1, 2, str.tostring(votesLong) + "/" + str.tostring(votesShort) + " (?? + str.tostring(effMinVotes) + ")", text_color=color.white, bgcolor=db)
    table.cell(dbg, 0, 3, "stage=opentr", text_color=color.white, bgcolor=db)
    chk = stageLive == strategy.opentrades
    table.cell(dbg, 1, 3, str.tostring(stageLive) + "=" + str.tostring(strategy.opentrades), text_color=color.white, bgcolor=chk ? db : color.new(color.red, 0))
    table.cell(dbg, 0, 4, "?質?%/摰?迂%", text_color=color.white, bgcolor=db)
    table.cell(dbg, 1, 4, str.tostring(bankedPct, "#.0") + "/" + str.tostring(claimedPct, "#.0"), text_color=color.white, bgcolor=db)
    table.cell(dbg, 0, 5, "capHits/floor", text_color=color.white, bgcolor=db)
    table.cell(dbg, 1, 5, str.tostring(capHits) + "/" + str.tostring(floorHits), text_color=color.white, bgcolor=db)
    table.cell(dbg, 0, 6, "TP1/2 done", text_color=color.white, bgcolor=db)
    table.cell(dbg, 1, 6, (tp1Done?"T":"F") + "/" + (tp2Done?"T":"F"), text_color=color.white, bgcolor=db)
    table.cell(dbg, 0, 7, "convMult", text_color=color.white, bgcolor=db)
    table.cell(dbg, 1, 7, str.tostring(convMult, "#.00"), text_color=color.white, bgcolor=db)
    table.cell(dbg, 0, 8, "peakR/effGB", text_color=color.white, bgcolor=db)
    table.cell(dbg, 1, 8, str.tostring(peakR, "#.0") + "/" + str.tostring(effGiveback, "#.00"), text_color=color.white, bgcolor=db)
    table.cell(dbg, 0, 9, "breath/stair", text_color=color.white, bgcolor=db)
    table.cell(dbg, 1, 9, str.tostring(breathMult, "#.00") + "/" + str.tostring(stairRungs), text_color=color.white, bgcolor=db)
    table.cell(dbg, 0, 10, "coh/multStep", text_color=color.white, bgcolor=db)
    table.cell(dbg, 1, 10, str.tostring(cohNow) + "/" + str.tostring(multStep, "#.00"), text_color=color.white, bgcolor=db)
    table.cell(dbg, 0, 11, "bankFr/floorON", text_color=color.white, bgcolor=db)
    table.cell(dbg, 1, 11, str.tostring(bankFrac, "#.00") + "/" + (bankedFloorOn?"T":"F"), text_color=color.white, bgcolor=db)
    table.cell(dbg, 0, 12, "atrRank/stall", text_color=color.white, bgcolor=db)
    table.cell(dbg, 1, 12, str.tostring(nz(atrPctRank, 0.0), "#") + "/" + str.tostring(barsSincePeak) + "繚" + str.tostring(stallShrink, "#.0"), text_color=color.white, bgcolor=db)
    table.cell(dbg, 0, 13, "effTS/pers/effCD", text_color=color.white, bgcolor=db)
    table.cell(dbg, 1, 13, str.tostring(effTimeStop) + "/" + str.tostring(persistBars) + "/" + str.tostring(effCooldownDbg), text_color=color.white, bgcolor=db)
    table.cell(dbg, 0, 14, "msStop/floorSrc", text_color=color.white, bgcolor=db)
    table.cell(dbg, 1, 14, (msActive?"ST3撖?:"敹隹TR") + "/" + activeFloorTxt, text_color=color.white, bgcolor=db)
    table.cell(dbg, 0, 15, "entGate/cohAdd", text_color=color.white, bgcolor=db)
    table.cell(dbg, 1, 15, (effEntryDistGate?"ON":"off") + "/" + (effCoherenceAdd?"ON":"off"), text_color=color.white, bgcolor=db)
    table.cell(dbg, 0, 16, "?rAcc/midCfm", text_color=color.white, bgcolor=db)
    table.cell(dbg, 1, 16, (effErAccelAdd?"ON":"off") + "(?" + str.tostring(erSlope, "#.00") + " 鈭?" + str.tostring(erAccel2, "#.00") + ")/" + (effMidConfirm?"ON":"off"), text_color=color.white, bgcolor=db)
    table.cell(dbg, 0, 17, "??E2vote/E3sp繚??, text_color=color.white, bgcolor=db)
    table.cell(dbg, 1, 17, (effAdaptiveMinVotes?"ON":"off") + (lowVolRegime?"(雿郭<"+str.tostring(lowVolPctile,"#")+"繚+"+str.tostring(extraVoteLowVol)+")":"") + "/" + (effAddSpacing?"ON":"off") + "(?? + str.tostring(addSpace) + "璉瑁?" + str.tostring(math.min(bar_index - lastAddBar, 9999)) + "繚?? + str.tostring(e3BlockedAdds) + ")", text_color=color.white, bgcolor=db)
    table.cell(dbg, 0, 18, "??F1spK/F2?瑟郎", text_color=color.white, bgcolor=db)
    table.cell(dbg, 1, 18, (effAddSpaceVol?"ON?"+str.tostring(spaceVolK,"#.00"):"off") + "/" + (effVoteFade?"ON":"off") + "(?? + str.tostring(voteFadeCuts) + (voteFadeArmed?"繚甇西?":"繚敺???) + ")", text_color=color.white, bgcolor=db)
    table.cell(dbg, 0, 19, "???1??G2?琿?, text_color=color.white, bgcolor=db)
    table.cell(dbg, 1, 19, (effAdxSlopeAdd?"ON":"off") + "(?ADX" + str.tostring(adxSlope, "#.0") + "繚?? + str.tostring(g1BlockedAdds) + ")/" + (effDrawVel?"ON":"off") + "(?? + str.tostring(dvCuts) + "繚?? + str.tostring(dvRate, "#.00") + "?? + str.tostring(dvThr, "#.00") + (dvArmed?"繚甇西?":"繚敺???) + ")", text_color=color.white, bgcolor=db)
    table.cell(dbg, 0, 20, "???1繚DI?/H2銵?", text_color=color.white, bgcolor=db)
    table.cell(dbg, 1, 20, (effDiSlopeGate?"ON":"off") + "(?憭? + str.tostring(diSlopeLong, "#.0") + "繚?? + str.tostring(h1BlockedEntries) + ")/" + (effVolShockTrail?"ON":"off") + "(頨? + str.tostring(volShockNow, "#") + "?? + str.tostring(volShockJumpFrac*100.0, "#") + "繚蝺? + str.tostring(volShockHits) + ")", text_color=color.white, bgcolor=db)
    table.cell(dbg, 0, 21, "?1?圈悅/I2???, text_color=color.white, bgcolor=db)
    table.cell(dbg, 1, 21, (effFreshGate?"ON":"off") + "(蝒? + str.tostring(i1FreshWin) + "繚?? + str.tostring(i1BlockedEntries) + ")/" + (effCohDiverge?"ON":"off") + "(coh" + str.tostring(cohDirNow) + "<" + str.tostring(cohDirPast) + "繚?? + str.tostring(i2Cuts) + (cohDvgArmed?"繚甇西?":"繚敺???) + ")", text_color=color.white, bgcolor=db)
    table.cell(dbg, 0, 22, "?3?單/cut-flat", text_color=color.white, bgcolor=db)
    table.cell(dbg, 1, 22, (effPropGate?"ON":"off") + "(?? + str.tostring(j3BlockedEntries) + ")/??蝝航?" + str.tostring(cutToFlatHits) + (cutToFlatNow?"繚?祆?":""), text_color=color.white, bgcolor=cutToFlatNow ? color.new(color.red, 0) : db)
