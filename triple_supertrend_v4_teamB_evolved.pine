    table.cell(dash, 0, 25, "cut-to-flat ??(P1)", text_color=txc, bgcolor=bgH, text_size=size.small)
    table.cell(dash, 1, 25, cutFlatTxt, text_color=txc, bgcolor=cutToFlatNow ? color.new(color.red, 25) : usePureA ? color.new(color.gray, 20) : bgV, text_size=size.small)
    // 蝚西???嚗停?啗牧??靽?????銝泵????霈??蝣潘?
    table.cell(dash, 0, 26, "??", text_color=txc, bgcolor=bgH, text_size=size.small)
