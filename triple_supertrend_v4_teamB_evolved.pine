    table.cell(dash, 0, 12, "?孵?銝?游漲", text_color=txc, bgcolor=bgH, text_size=size.small)
    table.cell(dash, 1, 12, inPos ? str.tostring(cohNow) + "/3 " + (cohNow >= 3 ? "(銝偕摨血??)" : cohNow <= 1 ? "(敹怠偕摨血歇?)" : "(銝剜?") : "??, text_color=txc, bgcolor=inPos and cohNow >= 3 ? color.new(color.green, 35) : inPos and cohNow <= 1 ? color.new(color.orange, 35) : bgV, text_size=size.small)
