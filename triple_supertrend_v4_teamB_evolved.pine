    table.cell(dash, 0, 23, "撠?/??(7/8繚F/G)", text_color=txc, bgcolor=bgH, text_size=size.small)
    table.cell(dash, 1, 23, modLine7, text_color=txc, bgcolor=usePureA ? color.new(color.gray, 20) : color.new(color.fuchsia, 35), text_size=size.small)
