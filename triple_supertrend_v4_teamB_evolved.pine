//     撖怠?鳴?openBarInPos 隞?禮6 璉? posSize ?文?(reductions ?翰?改??芸??? drain 瘙⊥?)??//   [Pine v5 蝖祉?? ?砍???global scope ?函??:= 撖怠??var(drainLong/Short 蝝撘??舀憭惜 var)??// ????????????????????????????????????????????????????????????????????????????
liveStageLongNow  = (l1On?1:0) + (l2On?1:0) + (l3On?1:0)
liveStageShortNow = (s1On?1:0) + (s2On?1:0) + (s3On?1:0)
openBarInPos      = posSize > 1e-9        // 禮6 璉?撖阡??其?(???禮10 drain 銋??翰??
cutToFlatNow      = not exitedThisBar and openBarInPos and liveStageLongNow == 0 and liveStageShortNow == 0
var int cutToFlatHits = 0                 // [甇詨?閫皜柵 蝝航?韏?cut-to-flat ??頝臬????賂?靘?walk-forward ?單?撽?
if cutToFlatNow
    // 瘥 fullExitNow 銋??湧?蝵??怠??嚗???璅飛?嗚?璇???蔭嚗?霅?銝璉?禮6 not inPos
    //   ??園?蝵株??祆?撣喳?銝?湛?銝璉絲?喳??瑕?ot inPos(P2)???脰風銝???脣??    l1On := false
    l2On := false
    l3On := false
    s1On := false
    s2On := false
    s3On := false
    entryRisk := na
    entryPx   := na
    entryBar  := na
    trailExt  := na
    trailStop := na
    tp1Done   := false
    tp2Done   := false
    peakR     := 0.0
    peakBar   := bar_index
    bankedQty := 0.0
    openInitQty := 0.0
    fadeArmed := true        // [regime-fade] ?蔭
    lastAddBar := -100000    // [E3] ?Ⅳ??閮??券?蝵?    voteFadeArmed := true    // [F2] ?梯?蟡冽銵圈霅瑟??蔭
    lastVoteFadeBar := -100000  // [F2繚CFix-8] ??閮??其?雿菟?蝵?    dvArmed := true          // [G2] 撜啣澆???霅瑟??蔭
    lastDvBar := -100000     // [G2繚CFix-8] ??閮??其?雿菟?蝵?    cohDvgArmed := true      // [I2] 頝典偕摨行???Ｗ憸券霅瑟??蔭
    lastCohDvgBar := -100000 // [I2] ??閮??其?雿菟?蝵?    notL1 := 0.0
    notL2 := 0.0
    notL3 := 0.0
    notS1 := 0.0
    notS2 := 0.0
    notS3 := 0.0
    posLive := 0.0
    exitedThisBar := true
    cutToFlatHits += 1
    float effCooldownCut = effAdaptiveCooldown ? math.max(math.round(cooldownBars * breathClamp), 0) : cooldownBars
    cooldownUntil := bar_index + effCooldownCut

// ????????????????????????????????????????????????????????????????????????????
// 禮11  ?脣嚗?蝛箏?潮??擐憟?regime gate嚗?蝣澆? winners-add-only + vol-brake嚗?//      ??禮10 靽? stage ???嚗1Cond(stage==0) ??蝣?l1On==true) 瘞詨???⊿?蝝?甇颯?//      brokerStopHit 璉?exitedThisBar=true ???祆?銝脣(canEnter ??not exitedThisBar)??// ????????????????????????????????????????????????????????????????????????????
canEnter = bar_index >= cooldownUntil and not exitedThisBar
// ?脣 stage ??敺誑??0 皜? fresh l*On/s*On ?單?????瘣?stage ?斗嚗?????禮6 璉?
//   stale stage?1Cond/s1Cond 銝血?撠? stage==0 ??瘙⊥??脰風??curLongStage  = (l1On?1:0) + (l2On?1:0) + (l3On?1:0)
curShortStage = (s1On?1:0) + (s2On?1:0) + (s3On?1:0)
// [NEW-A2] ?脣???孵榆蝣箄???擐 |close?t1| ??kBuf?atrChand嚗???kBuf/atrChand ?嗆憓?input嚗?//   ?芸??蝧餉????芣銵??脤??殷??蕪?Ｚ??云??餈賡?/餈賜征?柴?蝛粹?ffEntryDistGate 撌脣 usePureA??//   na 摰?嚗t1/atrChand 隞颱? na ??atrChand<=0 ???餅?(???銵)嚗??璈?隤日???entryDistOK = not effEntryDistGate or na(st1) or na(atrChand) or atrChand <= 0 or math.abs(close - st1) <= kBuf * atrChand
// [?EW-C2] 銝剖偕摨阡脣蝣箄???擐??瘙葉撠箏漲 ST2 ??嚗? st2Bull / 蝛?st2Bear嚗?//   鋆?regime gate ?葉撠箏漲?孵??脤?(銝巨 ER/ADX/ST3 銝 ST2)????st2Bull/st2Bear ?嗆憓?input??//   憭征?∪??雿擐?ffMidConfirm 撌脣 usePureA嚗????拇? OK ??true(???銵)??midConfirmLongOK  = not effMidConfirm or st2Bull
midConfirmShortOK = not effMidConfirm or st2Bear
// [???EW-H1] DI ?孵榆?蝣箄??脣??擐??瘙?撌?diSpread ???榆???券＊???//   (?孵??芸??芸援閫??? diSpreadLong=diPlus?iMinus?征?∪? diSpreadShort=diMinus?iPlus??//   ??DI 瘞湔???diPlus>diMinus ?臬??)/A2(頝)/C2(銝剖偕摨行?偌皞?/E2(?梯??賊?)甇?漱嚗1 ????賣??//   銴?Ｘ? diPlus/diMinus 銋?[1]嚗?啣???? input嚗皛臬葆 diSlopeHystBand ?望??(adxOn?dxOff) 瘣曄?
//   (??G1 ??繚?身 0 ????>=0)??蝛箏?潮?雿擐?ffDiSlopeGate ??usePureA??//   ??摰?嚗iSlope=?嗅? diSpread ??nz(??璉?diSpread, ?嗅?)嚗?璉??0(銝炊?斗????diSlopeHystBand   = diSlopeHystFrac * math.max(adxOn - adxOff, 0.0)
diSpreadLong      = diPlus  - diMinus
diSpreadShort     = diMinus - diPlus
diSlopeLong       = diSpreadLong  - nz(diSpreadLong[1],  diSpreadLong)
diSlopeShort      = diSpreadShort - nz(diSpreadShort[1], diSpreadShort)
diSlopeLongOK     = not effDiSlopeGate or diSlopeLong  >= -diSlopeHystBand
diSlopeShortOK    = not effDiSlopeGate or diSlopeShort >= -diSlopeHystBand
// [?EW-I1] ST 蝧餉??圈悅摨行??※皜脣??閬?擐頝?ST1 ?餈?甈∪??蕃頧???N 璉??//   N=clamp(round(len1?i1FreshFrac),1,persistBars) ?望??len1 瘣曄?繚?嗆憓?? input?? A2(蝛粹?
//   頝)甇?漱嚗2 ?頧?憭??1 ?蕃頧???憭?(??蝬???蝛箏???蕃頧????//   ??摰?嚗蕃頧???-100000??璈? (bar_index ??flipBar) 璆萄之????銝銵?靽??? i1FreshFrac 憭批潔?霅?銝????i1FreshWin    = math.min(math.max(math.round(len1 * i1FreshFrac), 1), persistBars)
freshLongOK   = not effFreshGate or (bar_index - st1FlipUpBar) <= i1FreshWin
freshShortOK  = not effFreshGate or (bar_index - st1FlipDnBar) <= i1FreshWin
// [?EW-J3] 頝典偕摨衣蕃頧?剜?脣??閬??蝯??敹怎?瑽蕃? persistBars 閬??扳?蝡?//   憭?st3FlipUpBar <= st2FlipUpBar <= st1FlipUpBar 銝????刻? persistBars 蝒(?勗???湔)??//   蝛粹?????冽??撠箏漲蝧餉?璉???+ persistBars嚗?啣???? input?? C2(ST2 瘞湔?繚????)
//   甇?漱?? I1(ST1 ?桀偕摨衣蕃敺???甇?漱??蝛粹?雿擐?ffPropGate ??usePureA??//   ??摰?嚗遙銝蝧餉?璉??箏???甇斗??撠箏漲撠蝧駁?)??剝?銝?蝡???銝銵?靽?)??propWinOK     = persistBars > 0
propLongFresh = (bar_index - st3FlipUpBar) <= persistBars and (bar_index - st2FlipUpBar) <= persistBars and (bar_index - st1FlipUpBar) <= persistBars
propShortFresh= (bar_index - st3FlipDnBar) <= persistBars and (bar_index - st2FlipDnBar) <= persistBars and (bar_index - st1FlipDnBar) <= persistBars
propLongOK    = not effPropGate or (propWinOK and propLongFresh and st3FlipUpBar <= st2FlipUpBar and st2FlipUpBar <= st1FlipUpBar)
propShortOK   = not effPropGate or (propWinOK and propShortFresh and st3FlipDnBar <= st2FlipDnBar and st2FlipDnBar <= st1FlipDnBar)
// 擐嚗T1 蝧餃? + regime gate嚗 MTF ?Ｙ?瑽??漲嚗? ?孵榆??A2) + 銝剖偕摨衣Ⅱ隤?(C2) + H1 DI ? + I1 ?圈悅摨?+ J3 ?單?孵?
//   [P2繚cut-to-flat ??瘙⊥??脰風] 憿? AND not inPos嚗雿踵璉? 禮10 drain ?暑 stage ? 0嚗?//     ?芾??詨??其? strategy.position_size 隞????祆???鈭支?銝璉???)嚗??桀銝銵???
//     ?? stop-and-reverse(intrabar ??)撟賡??其??? P1 cut-to-flat ?瑕??敶Ｘ???撠迂靽嚗?//     ?瑕????餅??批??脯?not inPos ??璉雿?迤甇賊?喳??nPos=position_size!=0(禮6)??l1Cond = curLongStage == 0 and curShortStage == 0 and not inPos and st1FlipUp and regimeLongOK  and canEnter and entryDistOK and midConfirmLongOK  and diSlopeLongOK  and freshLongOK  and propLongOK
s1Cond = curLongStage == 0 and curShortStage == 0 and not inPos and st1FlipDn and regimeShortOK and canEnter and entryDistOK and midConfirmShortOK and diSlopeShortOK and freshShortOK and propShortOK
// [H1/I1/J3 甇詨?閫皜柵 蝝航???∟府??舀銵??柴?鋡怨府???芥??脣甈⊥(蝝?皜研銵?寡?)??//   ?勗??箏? = 擐?園????冽?蝡????函??斗鋡急??? walk-forward ?圾??鋡急?擐?????蝺扼?var int h1BlockedEntries = 0
var int i1BlockedEntries = 0
var int j3BlockedEntries = 0
entryBaseLong  = curLongStage == 0 and curShortStage == 0 and not inPos and st1FlipUp and regimeLongOK  and canEnter and entryDistOK and midConfirmLongOK
entryBaseShort = curShortStage == 0 and curLongStage == 0 and not inPos and st1FlipDn and regimeShortOK and canEnter and entryDistOK and midConfirmShortOK
if effDiSlopeGate and ((entryBaseLong and diSlopeLong < -diSlopeHystBand) or (entryBaseShort and diSlopeShort < -diSlopeHystBand))
    h1BlockedEntries += 1
if effFreshGate and ((entryBaseLong and (bar_index - st1FlipUpBar) > i1FreshWin) or (entryBaseShort and (bar_index - st1FlipDnBar) > i1FreshWin))
    i1BlockedEntries += 1
if effPropGate and ((entryBaseLong and not (propWinOK and propLongFresh and st3FlipUpBar <= st2FlipUpBar and st2FlipUpBar <= st1FlipUpBar)) or (entryBaseShort and not (propWinOK and propShortFresh and st3FlipDnBar <= st2FlipDnBar and st2FlipDnBar <= st1FlipDnBar)))
    j3BlockedEntries += 1
// ?Ⅳ嚗?畾萄歇瘚桃?(R>0)?隅?Ｗ??T ?亙?蝧餃????芾孛??vol-brake嚗?瘜Ｗ???嚗?//   [NEW-A3] 銝?游漲?Ⅳ靽∪艙??addOK ???撅砌蒂??AND coherence>=2嚗? coherenceLong / 蝛?coherenceShort嚗?//   [?EW-C1] ER ??漲?Ⅳ????AND (er >= nz(er[1], er))(??芣??????er[1] ?嗆憓?input??蝣?erThr??//   [??NEW-E3] ?Ⅳ???餃?????AND (bar_index ??lastAddBar ??addSpace)?ddSpace ?望??len1/persistBars
//     瘣曄?(?嗆憓隤輸?)嚗??芾?銵??????桃???蝛箏?典?銝 lastAddBar(???⊥???∪?)??//   [??NEW-F1] 瘜Ｗ??芷??蝣潮?頝?addSpace 銋?spaceVolK(雿郭???瑯?瘜Ｗ?蝮桃)??clamp ??蝯???//   [???EW-G1] ADX ???蝣箄??Ⅳ????AND (ta.change(adx) ???皛臬葆)???冽??adx?? C1(ER 銝?榆??甇?漱??//   鈭???convMult(隤?size)甇?漱嚗3 ??瑽1 ??ER ??1 ??ADX 撘瑕漲??3/F1 ??摨?頝onvMult ?偌皞?蝛粹??addCohLongOK  = not effCoherenceAdd or coherenceLong  >= 2
addCohShortOK = not effCoherenceAdd or coherenceShort >= 2
// [?EW-C1 + ?梯?靽格迤 CFix-2] ER 銝?榆??撣嗆扔撠皛荔?er >= er[1] ??erHystFrac?erThr??//   erHystFrac=0 ????>=(??A 蝑)嚗?0 蝯血璉??楨銵??芣??＊???賣?銵凝撠?瑼?//   nz(er[1],er) ??摰?(擐???銵?嚗???er/erThr嚗?蝛箏?典?銝 er 憭拍?∪???erHystBand    = erHystFrac * erThr                          // ?脫趙撣嗥?撠?(?詨? erThr 撠箏漲?楊???芷??
addErAccelOK  = not effErAccelAdd or er >= nz(er[1], er) - erHystBand
// [E3] ???撠?蝣潮?頝?璉?嚗?Ｘ? len1/persistBars 瘣曄???啣??航矽??addSpaceBase  = math.min(math.max(len1, 2), persistBars)
// [??NEW-F1] 瘜Ｗ??芷??頝??賂?雿郭??atrPctRank 撠?????1 ?????瘜Ｗ?(atrPctRank 憭?????1 蝮桃??//   spaceVolK=clamp(1+(50?trPctRank)/100, spcVolLo, spcVolHi)嚗?璈?atrPctRank na ???50????1(蝑??)??//   ??math.round 敺?clamp ??[2, persistBars] 蝬剜???瑽?銝????冽??atrPctRank(禮4)嚗?? spcVolLo/Hi??spaceVolK     = effAddSpaceVol ? math.min(math.max(1.0 + (50.0 - nz(atrPctRank, 50.0)) / 100.0, spcVolLo), spcVolHi) : 1.0
addSpace      = math.min(math.max(math.round(addSpaceBase * spaceVolK), 2), persistBars)   // ?芷??隞?clamp ??蝯???addSpacingOK  = not effAddSpacing or (bar_index - lastAddBar) >= addSpace
// [???EW-G1] ADX ???蝣箄??Ⅳ??閬?頞典撘瑕漲銝?榆???券＊???ta.change(adx) >= ?皛臬葆)??//   ??C1(ER 銝?榆??甇?漱嚗R ???DX ?撥摨血??賬??冽??adx 銋?[1]嚗?啣???? input嚗皛臬葆??//   ?Ｘ? (adxOn?dxOff) 瘣曄?(adxSlopeHystFrac?撟??身 0 ????>=0)?dx ?⊥??憭征?梁?? adx???//   ??摰?嚗a.change(adx)=adx?z(adx[1],adx)嚗?璉??0(銝炊?斗????adxSlopeHystBand = adxSlopeHystFrac * math.max(adxOn - adxOff, 0.0)   // ?脫趙撣嗥?撠?(?詨??Ｘ??脫趙撣嗅祝撠箏漲)
adxSlope         = adx - nz(adx[1], adx)                              // ADX 銝?榆??頞典撘瑕漲?)
addAdxSlopeOK    = not effAdxSlopeAdd or adxSlope >= -adxSlopeHystBand
addOKLong  = not volBrakeOn and R > 0 and addCohLongOK  and addErAccelOK and addSpacingOK and addAdxSlopeOK
addOKShort = not volBrakeOn and R > 0 and addCohShortOK and addErAccelOK and addSpacingOK and addAdxSlopeOK
// [?梯?靽格迤 CFix-3繚E3/F1 甇詨?閫皜柵 蝝航???⊿?頝??砍?曇???鋡?addSpace ????Ⅳ甈⊥??//   蝝?皜?銝鈭斗?銵)嚗?隞?= 閰脣惜?園??Ⅳ???冽?蝡? addSpacingOK ??false ?◤??//   ?∠? F1 敺?spacingBlocked ?寧?芷????addSpace(????瑼颱???嚗雁??e3BlockedAdds 甇詨?甇?Ⅱ??//   靘?walk-forward ?圾?◤??頝冽??亙??Ⅳ?臬憭?扳?銵?????踹? E3/F1 隤斗捏?喳偏??var int e3BlockedAdds = 0
spacingBlocked = effAddSpacing and (bar_index - lastAddBar) < addSpace
addBaseLong2  = curLongStage == 1 and l1On and inLong  and st2FlipUp and st1Bull and not volBrakeOn and R > 0 and addCohLongOK  and addErAccelOK and addAdxSlopeOK
addBaseLong3  = curLongStage == 2 and l1On and l2On and inLong  and st3FlipUp and st1Bull and st2Bull and not volBrakeOn and R > 0 and addCohLongOK  and addErAccelOK and addAdxSlopeOK
addBaseShort2 = curShortStage == 1 and s1On and inShort and st2FlipDn and st1Bear and not volBrakeOn and R > 0 and addCohShortOK and addErAccelOK and addAdxSlopeOK
addBaseShort3 = curShortStage == 2 and s1On and s2On and inShort and st3FlipDn and st1Bear and st2Bear and not volBrakeOn and R > 0 and addCohShortOK and addErAccelOK and addAdxSlopeOK
if spacingBlocked and (addBaseLong2 or addBaseLong3 or addBaseShort2 or addBaseShort3)
    e3BlockedAdds += 1
// [G1 甇詨?閫皜柵 蝝航????ADX ????舀銵?鋡?ADX ??∪?????Ⅳ甈⊥(蝝?皜研銵?寡?)??//   璇辣 = 閰脣惜?園??Ⅳ???冽?蝡??恍?頝??? addAdxSlopeOK ??false ?◤?? walk-forward ?圾 G1
//   鋡急??Ⅳ??????瑟?西? C1 ?梁?(?亥◤???嗾銋???C1 ??蝝?閫皜???var int g1BlockedAdds = 0
adxBlocked = effAdxSlopeAdd and adxSlope < -adxSlopeHystBand
g1BaseLong2  = curLongStage == 1 and l1On and inLong  and st2FlipUp and st1Bull and not volBrakeOn and R > 0 and addCohLongOK  and addErAccelOK and addSpacingOK
g1BaseLong3  = curLongStage == 2 and l1On and l2On and inLong  and st3FlipUp and st1Bull and st2Bull and not volBrakeOn and R > 0 and addCohLongOK  and addErAccelOK and addSpacingOK
g1BaseShort2 = curShortStage == 1 and s1On and inShort and st2FlipDn and st1Bear and not volBrakeOn and R > 0 and addCohShortOK and addErAccelOK and addSpacingOK
g1BaseShort3 = curShortStage == 2 and s1On and s2On and inShort and st3FlipDn and st1Bear and st2Bear and not volBrakeOn and R > 0 and addCohShortOK and addErAccelOK and addSpacingOK
if adxBlocked and (g1BaseLong2 or g1BaseLong3 or g1BaseShort2 or g1BaseShort3)
    g1BlockedAdds += 1
l2Cond = curLongStage == 1 and l1On and inLong  and st2FlipUp and st1Bull and addOKLong
l3Cond = curLongStage == 2 and l1On and l2On and inLong  and st3FlipUp and st1Bull and st2Bull and addOKLong
s2Cond = curShortStage == 1 and s1On and inShort and st2FlipDn and st1Bear and addOKShort
s3Cond = curShortStage == 2 and s1On and s2On and inShort and st3FlipDn and st1Bear and st2Bear and addOKShort

if l1Cond
    strategy.entry("L1", strategy.long, qty=qty1, comment="L1")
    entryRisk := chandMult * atrChand   // ???祕??甇Ｘ?頝??R ??
    entryPx   := close
    trailExt  := high
    trailStop := na
    entryBar  := bar_index
    peakR     := 0.0
    peakBar   := bar_index               // ?啣???趙閮???    bankedQty := 0.0
    openInitQty := qty1
    fadeArmed := true
    voteFadeArmed := true    // [F2] ?梯?蟡冽銵圈霅瑟??蔭(?啣甇西?)
    lastVoteFadeBar := -100000  // [F2繚CFix-8] ?啣??閮??券?蝵?    dvArmed := true          // [G2] 撜啣澆???霅瑟??蔭(?啣甇西?)
    lastDvBar := -100000     // [G2繚CFix-8] ?啣??閮??券?蝵?    lastAddBar := bar_index   // [E3] 擐???Ⅳ??閮???    l1On := true
    notL1 := qty1   // 閮?閰脣惜銝?⊥嚗? TP/cut/fade 蝝蝎曄Ⅱ撠董
if l2Cond
    strategy.entry("L2", strategy.long, qty=qty2, comment="L2")
    l2On := true
    notL2 := qty2
    openInitQty := openInitQty + qty2
    lastAddBar := bar_index   // [E3] ?Ⅳ敺?圈?頝??
if l3Cond
    strategy.entry("L3", strategy.long, qty=qty3, comment="L3")
    l3On := true
    notL3 := qty3
    openInitQty := openInitQty + qty3
    lastAddBar := bar_index   // [E3] ?Ⅳ敺?圈?頝??
if s1Cond
    strategy.entry("S1", strategy.short, qty=qty1, comment="S1")
    entryRisk := chandMult * atrChand   // ???祕??甇Ｘ?頝??R ??
    entryPx   := close
    trailExt  := low
    trailStop := na
    entryBar  := bar_index
    peakR     := 0.0
    peakBar   := bar_index               // ?啣???趙閮???    bankedQty := 0.0
    openInitQty := qty1
    fadeArmed := true
    voteFadeArmed := true    // [F2] ?梯?蟡冽銵圈霅瑟??蔭(?啣甇西?)
    lastVoteFadeBar := -100000  // [F2繚CFix-8] ?啣??閮??券?蝵?    dvArmed := true          // [G2] 撜啣澆???霅瑟??蔭(?啣甇西?)
    lastDvBar := -100000     // [G2繚CFix-8] ?啣??閮??券?蝵?    lastAddBar := bar_index   // [E3] 擐???Ⅳ??閮???    s1On := true
    notS1 := qty1
if s2Cond
    strategy.entry("S2", strategy.short, qty=qty2, comment="S2")
    s2On := true
    notS2 := qty2
    openInitQty := openInitQty + qty2
    lastAddBar := bar_index   // [E3] ?Ⅳ敺?圈?頝??
if s3Cond
    strategy.entry("S3", strategy.short, qty=qty3, comment="S3")
    s3On := true
    notS3 := qty3
    openInitQty := openInitQty + qty3
    lastAddBar := bar_index   // [E3] ?Ⅳ敺?圈?頝??

// nCap ??閮嚗??vol-target ?臬鋡急?獢蹂???頝荔?
if cap1 or cap2 or cap3
    capHits += 1

// 璉 fresh 瘣?stage嚗?0 皜?+ 禮11 ?Ⅳ敺?蝯?l*On/s*On ?遣嚗? 禮12 閬死?? 禮14
//   stage==opentrades 撠董雿輻?? ??stage ?箸?擐?靘?禮9 timeStop 甇?Ⅱ閮?)嚗＊蝷?撠董
//   ?寧 stageLive(璉 fresh)隞亙??璉?祕撅斗??//   閮鳴?brokerStopHit 璉?銝剖歇撟喳?雿?strategy.position_size 閬?銝璉??? flat嚗??祆?
//   inLong/inShort 隞?true?tageLive 隞＊蝷箸?鈭文?撅斗嚗??詨?敺?蝞? opentrades 銝?湛?閰脫?
//   禮14 銝炊?梁撣喉?銝?璉?Ⅱ隤?flat 敺?禮6 ?芰摰?蔭??蝑敺押?stageLive = inLong ? ((l1On?1:0) + (l2On?1:0) + (l3On?1:0)) : inShort ? ((s1On?1:0) + (s2On?1:0) + (s3On?1:0)) : 0

// [NEW-A4] ?詨????拙?蹂?皞飛??蝝閫皜祆扼鈭斗?銵?寡?嚗?瘥????唳撖阡? binding ??//   憭征?∪?嚗???擃??蝺??征??雿??蝺?嚗??梁??蝺?輻?靘??迂嚗? walk-forward
//   ?斗???唳?臬敺 binding(?臬?????冽??*FloorL/S ??effGiveback嚗?啣? input??floorBE_L    = beActive ? rBasePx + multBE * rDenom : na
floorBE_S    = beActive ? rBasePx - multBE * rDenom : na
floorPeak_L  = peakFloorOn ? rBasePx + (peakR - effGiveback) * rDenom : na
floorPeak_S  = peakFloorOn ? rBasePx - (peakR - effGiveback) * rDenom : na
floorStair_L = tpStairOn ? tpStairFloorL : na
floorStair_S = tpStairOn ? tpStairFloorS : na
floorBank_L  = bankedFloorOn ? bankedFloorL : na
floorBank_S  = bankedFloorOn ? bankedFloorS : na
// ??祕??蝺?binding)?唳靘?嚗??格?蝺??擃征?格?蝺??雿?var string activeFloorTxt = "??
activeFloorTxt := "??
if inPos
    float best = na
    string src = "蝝rail"
    if inLong
        if not na(floorBE_L) and (na(best) or floorBE_L > best)
            best := floorBE_L
            src  := "BE靽"
        if not na(floorStair_L) and (na(best) or floorStair_L > best)
            best := floorStair_L
            src  := "?０?唳"
        if not na(floorBank_L) and (na(best) or floorBank_L > best)
            best := floorBank_L
            src  := "撌脣祕?暸"
        if not na(floorPeak_L) and (na(best) or floorPeak_L > best)
            best := floorPeak_L
            src  := "撜啣?撟湧翩??"
    else
        if not na(floorBE_S) and (na(best) or floorBE_S < best)
            best := floorBE_S
            src  := "BE靽"
        if not na(floorStair_S) and (na(best) or floorStair_S < best)
            best := floorStair_S
            src  := "?０?唳"
        if not na(floorBank_S) and (na(best) or floorBank_S < best)
            best := floorBank_S
            src  := "撌脣祕?暸"
        if not na(floorPeak_S) and (na(best) or floorPeak_S < best)
            best := floorPeak_S
            src  := "撜啣?撟湧翩??"
    activeFloorTxt := src

