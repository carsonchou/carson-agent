// [?EW-I2] 頝典偕摨行???Ｗ??憸券銝甈⊥扯風甈?+ ?撠??????脫趙嚗??regime-fade嚗?var bool  cohDvgArmed     = true
var int   lastCohDvgBar   = -100000
// ?惜銝?⊥閮董嚗? Partial TP / cut / regime-fade 蝝蝎曄Ⅱ撠董嚗脣撖怠????扎lat 甇賊嚗?var float notL1 = 0.0
var float notL2 = 0.0
var float notL3 = 0.0
var float notS1 = 0.0
var float notS2 = 0.0
var float notS3 = 0.0

inLong  = strategy.position_size > 0
inShort = strategy.position_size < 0
inPos   = strategy.position_size != 0
posSize = math.abs(strategy.position_size)
avgPx   = strategy.position_avg_price

// ?箏蝯?敺??單飛?塚?瘨迨??銝?鞈港?銝璉辣?莎?
//   entryBar ?寥?蝵桃 na嚗?a)?撟喳摰?蔭??霈???嚗?b)timeStop 隞?na(entryBar) 摰?嚗?//   ?? bar_index-0 撠厭???啁征?炊閮???if not inPos
    l1On := false
    l2On := false
