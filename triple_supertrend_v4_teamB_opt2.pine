showDebug   = input.bool(false, "憿舐內?日甈?votes/floor/cap/TP/peakR 撠董)", group=gViz)

// ????????????????????????????????????????????????????????????????????????????
// 禮2  銝惜 SuperTrend嚗銝?箇??望?瘣曄?嚗a.supertrend ? [value,direction]嚗?//     direction < 0 ?箏???// ????????????????????????????????????????????????????????????????????????????
len1 = baseLen
len2 = math.max(math.round(baseLen * midMult), 2)
len3 = math.max(math.round(baseLen * slowMult), 3)
[st1, dir1] = ta.supertrend(f1, len1)
[st2, dir2] = ta.supertrend(f2, len2)
[st3, dir3] = ta.supertrend(f3, len3)

st1Bull = dir1 < 0
st2Bull = dir2 < 0
st3Bull = dir3 < 0
st1Bear = not st1Bull
st2Bear = not st2Bull
st3Bear = not st3Bull
// 蝧餉?鈭辣嚗??格?暺???
st1FlipUp   = st1Bull and not st1Bull[1]
st2FlipUp   = st2Bull and not st2Bull[1]
st3FlipUp   = st3Bull and not st3Bull[1]
st1FlipDn   = st1Bear and not st1Bear[1]
st2FlipDn   = st2Bear and not st2Bear[1]
st3FlipDn   = st3Bear and not st3Bear[1]

// ????????????????????????????????????????????????????????????????????????????
// 禮3  ATR% 甇???皞???????瑼颱?敺撠?嚗?頝典???蝝情??
// ????????????????????????????????????????????????????????????????????????????
atrAdx   = ta.atr(adxLen)
atrChand = ta.atr(chandLen)
atrPct   = atrAdx / close              // ATR%嚗撠??箸?嚗?
// ????????????????????????????????????????????????????????????????????????????
// 禮4  瘜Ｗ??摯閮?撟游??撠?嚗? VT-Core ??
//     instVolAnn嚗僑??郭???冽??甇????relVol嚗撠葉雿嚗?澆???頠?// ????????????????????????????????????????????????????????????????????????????
logRet      = math.log(close / close[1])
stdevDaily  = ta.stdev(logRet, volLen)
volAnnATR   = atrPct       * math.sqrt(barsPerYear)   // ATR% 撟游?
volAnnStd   = stdevDaily   * math.sqrt(barsPerYear)   // ?梢 std 撟游?
instVolAnn  = volEstMode == "Stdev" ? volAnnStd : volAnnATR
// ?詨??????頨怨? brakeLen 璉僑?郭??雿??嚗楊???芷???踹?蝯? floor 憭梁?
// fallback 0.02 ?箝僑??2%??蝝?摰絲暺??詨??仃????撽?摰?潘??撣 magic bp嚗?volFloor    = ta.percentile_linear_interpolation(instVolAnn, brakeLen, 5)
volFloor   := na(volFloor) ? 0.02 : math.max(volFloor, 0.001)
instVolAnn := math.max(nz(instVolAnn, volFloor), volFloor)
// ??頠皞?instVolAnn ?詨??園?葉雿
volMedian   = ta.median(instVolAnn, brakeLen)
volMedian  := na(volMedian) ? instVolAnn : math.max(volMedian, volFloor)
relVol      = instVolAnn / volMedian
volBrakeOn  = useVolBrake and relVol > brakeK     // true=擃郭???怠??Ⅳ
var int floorHits = 0
if instVolAnn <= volFloor + 1e-12
    floorHits += 1

// ????????????????????????????????????????????????????????????????????????????
// 禮5  Regime ??嚗R / ADX ?脫趙 / ST3 ?Ｘ??嚗? ?巨?券??脤?甇?// ????????????????????????????????????????????????????????????????????????????
// Kaufman ??瘥??駁?日嚗?erChange = math.abs(close - close[erLen])
erVolSum = math.sum(math.abs(close - close[1]), erLen)
er       = erVolSum > 0 ? erChange / erVolSum : 0.0
er      := nz(er, 0.0)

// ADX / DI嚗皛舫??曉潘?
[diPlus, diMinus, adx] = ta.dmi(adxLen, adxLen)
var bool adxOn_state = false
if adx > adxOn
    adxOn_state := true
else if adx < adxOff
    adxOn_state := false

// ST3 ?Ｘ??
slowBull = st3Bull
slowBear = st3Bear

// ?巨嚗?蟡函??舐蝡??????巨銝??亙?瘥???嚗?voteER_long   = useER     and er > erThr
voteADX_long  = useADX    and adxOn_state
voteSlow_long = useSlowST and slowBull
voteER_short  = useER     and er > erThr
voteADX_short = useADX    and adxOn_state
voteSlow_short= useSlowST and slowBear
votesLong  = (voteER_long?1:0)  + (voteADX_long?1:0)  + (voteSlow_long?1:0)
votesShort = (voteER_short?1:0) + (voteADX_short?1:0) + (voteSlow_short?1:0)
// 撌脣??函巨?賂????瑼?= min(minVotes, ?蟡冽)嚗??蟡典??甇?enabledVotes = (useER?1:0) + (useADX?1:0) + (useSlowST?1:0)
effMinVotes  = math.min(minVotes, enabledVotes)
votesUnreachable = minVotes > enabledVotes   // ?瑼?> ?舫?蟡冽 ??撌脤??clamp嚗?銵冽?內
// ?孵?蟡剁?憭征?湔?∪?嚗??臭?撌桃嚗?DI ?孵????dirLong  = diPlus  > diMinus
dirShort = diMinus > diPlus
diLongOK  = not useDIgate or dirLong
diShortOK = not useDIgate or dirShort

// ?巨???文?嚗??函巨??0 ??? ST 撠(true)嚗???Ｚ炊???香
voteLongPass  = enabledVotes == 0 ? true : votesLong  >= effMinVotes
voteShortPass = enabledVotes == 0 ? true : votesShort >= effMinVotes
regimeLongOK  = not useRegime or (voteLongPass  and diLongOK)
regimeShortOK = not useRegime or (voteShortPass and diShortOK)
// regime 撘瑕摹嚗??/?銵冽嚗?隞颱??孵???瑼餉???trend-on
regimeOn = (voteLongPass and dirLong) or (voteShortPass and dirShort)

// ????????????????????????????????????????????????????????????????????????????
// 禮6  ???嚗銝?嚗誑?惜?典 bool ?遣 stage嚗?蝯???皜?頝喳惜嚗?//     銝?撘?l3On?2On?1On嚗?嚗? s3On?2On?1On嚗征嚗???禮10 contiguous-stack
//     皜?隤?霅?stage 瘞貊??? 0/1/2/3嚗摮文?/?游惜??// ????????????????????????????????????????????????????????????????????????????
var bool  l1On = false
var bool  l2On = false
var bool  l3On = false
var bool  s1On = false
var bool  s2On = false
var bool  s3On = false
var int   entryBar  = 0
var float entryPx   = na    // 擐?嚗 ?箸??典?嚗??典?蝣潭?蝘鳴?
var float entryRisk = na    // ???脣??甇Ｘ?頝嚗 ??嚗? chandMult?atrChand
var float trailExt  = na    // 璆萄潛敞蝛?high/low嚗?var float trailStop = na
var float cooldownUntil = 0.0
// Partial TP one-shot ??銝甈⊥改??箏/???蔭嚗?var bool  tp1Done = false
var bool  tp2Done = false
// ?惜銝?⊥閮董嚗? Partial TP / cut / regime-fade 蝝蝎曄Ⅱ撠董嚗脣撖怠????扎lat 甇賊嚗?var float notL1 = 0.0
var float notL2 = 0.0
var float notL3 = 0.0
var float notS1 = 0.0
var float notS2 = 0.0
var float notS3 = 0.0
// [?菜3] ? high-water R嚗陸??R嚗?not inPos / clearAll 甇賊
var float peakR = 0.0

inLong  = strategy.position_size > 0
inShort = strategy.position_size < 0
inPos   = strategy.position_size != 0
posSize = math.abs(strategy.position_size)
avgPx   = strategy.position_avg_price

// ?箏蝯?敺??單飛?塚?瘨迨??銝?鞈港?銝璉辣?莎?
if not inPos
    l1On := false
    l2On := false
    l3On := false
    s1On := false
    s2On := false
    s3On := false
    entryRisk := na
    entryPx   := na
    trailExt  := na
    trailStop := na
    tp1Done   := false
    tp2Done   := false
    notL1 := 0.0
    notL2 := 0.0
    notL3 := 0.0
    notS1 := 0.0
    notS2 := 0.0
    notS3 := 0.0
    peakR := 0.0

longStage  = (l1On?1:0) + (l2On?1:0) + (l3On?1:0)
shortStage = (s1On?1:0) + (s2On?1:0) + (s3On?1:0)
stage = inLong ? longStage : inShort ? shortStage : 0

// ????????????????????????????????????????????????????????????????????????????
// 禮7  ??閮?嚗T-Core嚗僑?郭?璅? ??? ??蝮賣?獢?clamp ??qty嚗?//     qty = (targetVol / instVolAnn) * equity * weight / close
//     [?菜2] ?Ⅳ撅斗????clamp(er/erThr,0.5,1.0)嚗R 靽∪艙??
// ????????????????????????????????????????????????????????????????????????????
// 頝臬?靘陷?嚗??鞈?像皛?equity 瘛瑕?雿 sizing ?箸?嚗?銴頝臬??曉之
// 撟單?靽 0.99/0.01 ?迨 0.5/0.5 瘛瑕??箏?撽?銋楝敺??Ｗ虜?賂????渡??magic number
var float avgEq = na
avgEq := na(avgEq) ? strategy.equity : avgEq * 0.99 + strategy.equity * 0.01
sizeBase = 0.5 * strategy.initial_capital + 0.5 * avgEq

// vol-target 瘥?嚗?????摰????改?瘥?=1嚗?vtScale = useVolTarget ? targetVol / instVolAnn : 1.0
// [?菜2] ER 靽∪艙靽嚗??嚗lamp 0.5~1.0嚗????冽?Ⅳ撅?L2/L3嚗???L1 銝葬??convMult = useConvAdd and erThr > 0 ? math.min(math.max(er / erThr, 0.5), 1.0) : 1.0
wL2eff = wL2 * convMult
wL3eff = wL3 * convMult
totW    = wL1 + wL2 + wL3          // 蝮賣?獢踹??誑?甈?(銝靽∪艙蝮格)?箏皞?靽?銝?蝛拙?
var int capHits = 0

// ?桐??箏嚗策摰惜甈? ???格?? ???府撅文???瑽▼銝? clamp ??qty(??/?aN)
qtyFor(w) =>
    float notion = vtScale * sizeBase * w
    // 閰脣惜???啁??銝?嚗蜇瑽▼???格???靘???
    float nCap = totW > 0 ? sizeBase * maxGross * (w / totW) : sizeBase * maxGross
    bool  capped = notion > nCap
    notion := math.min(notion, nCap)
    float q = close > 0 ? notion / close : 0.0
    q := math.max(nz(q, 0.0), 0.0)
    [q, capped]

[qty1, cap1] = qtyFor(wL1)
[qty2, cap2] = qtyFor(wL2eff)
[qty3, cap3] = qtyFor(wL3eff)

// ????????????????????????????????????????????????????????????????????????????
// 禮8  R-multiple ??Chandelier ratchet ??嚗?蝛粹??only-up / only-down嚗?//     R ?? = entryRisk嚗脣??銋?chandMult?atrChand ??甇Ｘ?頝嚗?//     [?嗆?3] entryPx/rBasePx 銋 L1 敹 L2/L3 ?券?游??◤閫詨?嚗 ?摰祕摮敹?//     [?菜3] peakR high-water + ??? peak-anchored ?唳
// ????????????????????????????????????????????????????????????????????????????
rDenom  = na(entryRisk) ? (chandMult * atrChand) : entryRisk   // ?祕??甇Ｘ?頝
rBasePx = na(entryPx)   ? avgPx : entryPx
R = inPos and rDenom > 0 ? (inLong ? (close - rBasePx) / rDenom : (rBasePx - close) / rDenom) : 0.0
// [?菜3] 蝬剛風?撜啣?R嚗igh-water嚗?脖??嚗ot inPos 撌脫 禮6 甇賊嚗?if inPos
    peakR := math.max(peakR, R)
// R ?０?嚗祝?葉??嚗隤踵蝺??曉之?喳偏??瑕椰撠橘?
multStep = not useRStep ? chandMult : (R < 1 ? chandMult : R < 2 ? trailMidR : trailTightR)

// [?菜1] TP1 ?質?敺??詨??撥?嗡??穿?蝑??BE 閫貊??歇?質????
beActive = (useBE and R >= kBE) or (useBEonTP1 and tp1Done)
// [?菜3] Peak-R giveback ?唳嚗?? peak-anchored嚗?givebackR 銴 multBE
//   憭嚗敹???敺???rBasePx + (peakR ??givebackR)?rDenom嚗陸?澆???givebackR ?喲?嚗?//   ? peakR > givebackR ??撖西釭?唳嚗?????典?銝嚗?蝛箏?∪???givebackR    = multBE
peakFloorOK  = usePeakRatchet and peakR > givebackR
peakFloorLong  = rBasePx + (peakR - givebackR) * rDenom
peakFloorShort = rBasePx - (peakR - givebackR) * rDenom

if useChandelier and inLong
    trailExt  := na(trailExt) ? high : math.max(trailExt, high)
    rawStop    = trailExt - multStep * atrChand
    trailStop := na(trailStop) ? rawStop : math.max(trailStop, rawStop)   // ratchet ?芷脖??
    if beActive
        trailStop := math.max(trailStop, rBasePx + multBE * rDenom)
    if peakFloorOK
        trailStop := math.max(trailStop, peakFloorLong)                   // [?菜3] ????喳偏?唳
else if useChandelier and inShort
    trailExt  := na(trailExt) ? low : math.min(trailExt, low)
    rawStop    = trailExt + multStep * atrChand
    trailStop := na(trailStop) ? rawStop : math.min(trailStop, rawStop)   // ratchet ?芷脖??
    if beActive
        trailStop := math.min(trailStop, rBasePx - multBE * rDenom)
    if peakFloorOK
        trailStop := math.min(trailStop, peakFloorShort)                  // [?菜3] ????喳偏?唳

// ????????????????????????????????????????????????????????????????????????????
// 禮9  ?箏閫貊嚗??蝔梧?頞典???箔蜓?箏嚗ime-stop ?俎?菜5]ER ?芷??
// ????????????????????????????????????????????????????????????????????????????
trailHitLong  = useChandelier and inLong  and not na(trailStop) and close < trailStop
trailHitShort = useChandelier and inShort and not na(trailStop) and close > trailStop
// ?賡摨?嚗翰+銝?ST ????嚗? ST 蝧餃?嚗?twoSTRevLong  = inLong  and st1Bear and st2Bear
twoSTRevShort = inShort and st1Bull and st2Bull
// [?菜5] ER ?芷??time-stop嚗ffTimeStop = timeStopBars ? clamp(er/erThr,0.5,1.0)
//   ER 頞?嚗??斗嚗?渲?敹恬?ER 頞?嚗?賣撘瑁隅?Ｗ摨瑕?瑼?蝯西?憭???erTimeScale  = useERTimeStop and erThr > 0 ? math.min(math.max(er / erThr, 0.5), 1.0) : 1.0
effTimeStop  = math.max(1, math.round(timeStopBars * erTimeScale))
timeStopLong  = useTimeStop and inLong  and (bar_index - entryBar) >= effTimeStop and R < 1 and stage < 3
timeStopShort = useTimeStop and inShort and (bar_index - entryBar) >= effTimeStop and R < 1 and stage < 3

// ????????????????????????????????????????????????????????????????????????????
// 禮10  銝?瑁?嚗??箏敺脣嚗?璉????喳?甇伐?
// ????????????????????????????????????????????????????????????????????????????
var bool exitedThisBar = false
exitedThisBar := false

clearAll() =>
    l1On := false
    l2On := false
    l3On := false
    s1On := false
    s2On := false
    s3On := false
    entryRisk := na
    entryPx   := na
    trailExt  := na
    trailStop := na
    tp1Done   := false
    tp2Done   := false
    notL1 := 0.0
    notL2 := 0.0
    notL3 := 0.0
    notS1 := 0.0
    notS2 := 0.0
    notS3 := 0.0
    peakR := 0.0

// 鈭斗??蝝????殷??脰歲蝛綽??支葉閫貊嚗?斤Ⅱ隤?頞典?箏隞銵???
if useHardStop and inLong and not na(trailStop)
    strategy.exit("hX-L", stop=trailStop, comment="HardStopL")
else if useHardStop and inShort and not na(trailStop)
    strategy.exit("hX-S", stop=trailStop, comment="HardStopS")

// ??銝餃??A嚗handelier trailStop嚗?斤Ⅱ隤? ??if trailHitLong
    strategy.close_all(comment="TrailL")
    clearAll()
    exitedThisBar := true
    cooldownUntil := bar_index + cooldownBars
else if trailHitShort
    strategy.close_all(comment="TrailS")
    clearAll()
    exitedThisBar := true
    cooldownUntil := bar_index + cooldownBars

// ???箏 B嚗? ST ??摨? ??if not exitedThisBar and twoSTRevLong
    strategy.close_all(comment="2STrevL")
    clearAll()
    exitedThisBar := true
    cooldownUntil := bar_index + cooldownBars
else if not exitedThisBar and twoSTRevShort
    strategy.close_all(comment="2STrevS")
    clearAll()
    exitedThisBar := true
    cooldownUntil := bar_index + cooldownBars

// ???箏 C嚗??????俎?菜5]ER ?芷??湧漲嚗???if not exitedThisBar and (timeStopLong or timeStopShort)
    strategy.close_all(comment="TimeStop")
    clearAll()
    exitedThisBar := true
    cooldownUntil := bar_index + cooldownBars

// ?? contiguous-stack ?臭?皜?隤?top-first drain + ?芣晾?遣嚗?????????????????????
//   銝?撘?憭征?∪?嚗?l3On ??l2On ??l1On嚗?蝣澆惜瘞訾??恍?詨?撅文??剁???//   ??????敺? reduceLong/reduceShort嚗?摰?newest-first嚗3?2?1嚗??殷???
//   銝撅斗???銝撅歹?皜??晞擗??柴?撱?bool嚗? top-first 靽?畾??摨?銝??
//   憛怠? ??銝?撘????1嚗BasePx/entryPx 銋嚗???L2/L3 ?券?游??◤閫詨?嚗???L1
//   鋡怠???游皜??賢 禮6 not inPos 蝯??蔭嚗? R ?箸??冽????賡望??扳??典?撖血??詨???//   reduceLong/Short嚗???摰?qty嚗?蝮賡雿???霅瘀???/?aN嚗??撖阡?????reduceLong(reqQty) =>
    float want = math.min(math.max(nz(reqQty, 0.0), 0.0), posSize)
    float done = 0.0
    if l3On and want - done > 1e-9
        float take = math.min(want - done, notL3)
        if take > 1e-9
            strategy.close("L3", qty=take, comment="cut-L3")
            notL3 := notL3 - take
            done  := done + take
    if l2On and want - done > 1e-9
        float take = math.min(want - done, notL2)
        if take > 1e-9
            strategy.close("L2", qty=take, comment="cut-L2")
            notL2 := notL2 - take
            done  := done + take
    if l1On and want - done > 1e-9
        float take = math.min(want - done, notL1)
        if take > 1e-9
            strategy.close("L1", qty=take, comment="cut-L1")
            notL1 := notL1 - take
            done  := done + take
    // ?勗擗??桅?撱箏??bool嚗op-first 靽????嚗3On?2On?1On嚗?    l3On := notL3 > 1e-9
    l2On := notL2 > 1e-9
    l1On := notL1 > 1e-9
    done
reduceShort(reqQty) =>
    float want = math.min(math.max(nz(reqQty, 0.0), 0.0), posSize)
    float done = 0.0
    if s3On and want - done > 1e-9
        float take = math.min(want - done, notS3)
        if take > 1e-9
            strategy.close("S3", qty=take, comment="cut-S3")
            notS3 := notS3 - take
            done  := done + take
    if s2On and want - done > 1e-9
        float take = math.min(want - done, notS2)
        if take > 1e-9
            strategy.close("S2", qty=take, comment="cut-S2")
            notS2 := notS2 - take
            done  := done + take
    if s1On and want - done > 1e-9
        float take = math.min(want - done, notS1)
        if take > 1e-9
            strategy.close("S1", qty=take, comment="cut-S1")
            notS1 := notS1 - take
            done  := done + take
    s3On := notS3 > 1e-9
    s2On := notS2 > 1e-9
    s1On := notS1 > 1e-9
    done

// cutTopLong/Short嚗?????怠?游惜????tranche嚗???惜?嚗??stale嚗??∪惜 noop??cutTopLong() =>
    float tranche = l3On ? notL3 : l2On ? notL2 : l1On ? notL1 : 0.0
    if tranche > 1e-9
        reduceLong(tranche)
    true
cutTopShort() =>
    float tranche = s3On ? notS3 : s2On ? notS2 : s1On ? notS1 : 0.0
    if tranche > 1e-9
        reduceShort(tranche)
    true

// ?? A-3嚗?頞??挾 R-multiple Partial TP嚗蜇?其??瘥?蝎曄Ⅱ?質?嚗? contiguous-stack嚗??
//   ?? B嚗 ??strategy.close(id, qty_percent) ?芸像閰?id 畾??曉?瘥?撖阡??質????澆恐蝔晞?//   ?祉?隞乓蜇?其??瘥?????tpQty嚗漱 reduceLong/Short newest-first ?質?嚗蒂?望???撱?//   bool嚗蝙 stage=opentrades ??銝偶銝撅歹?L1 ? L2/L3 ?箸?敺?鋡怨孛????tpHitL1 = usePartialTP and not exitedThisBar and inLong  and R >= tp1R and not tp1Done
tpHitL2 = usePartialTP and not exitedThisBar and inLong  and R >= tp2R and not tp2Done
tpHitS1 = usePartialTP and not exitedThisBar and inShort and R >= tp1R and not tp1Done
tpHitS2 = usePartialTP and not exitedThisBar and inShort and R >= tp2R and not tp2Done
if tpHitL1
    reduceLong(posSize * tp1Pct / 100.0)
    tp1Done := true
if tpHitL2
    reduceLong(posSize * tp2Pct / 100.0)
    tp2Done := true
if tpHitS1
    reduceShort(posSize * tp1Pct / 100.0)
    tp1Done := true
if tpHitS2
    reduceShort(posSize * tp2Pct / 100.0)
    tp2Done := true

// ???箏 D嚗T ???挾皜?cut嚗??蝬?contiguous-stack top-first嚗偶銝撅??香嚗?//   cutL2/cutS2 閬??喳????Ⅳ撅文?湛?l2On or l3On嚗?蝣箔? ST2 頝臬?銝?刻孛?敹?L1??cutL1 = usePartialST and not exitedThisBar and inLong  and st1FlipDn and (l1On or l2On or l3On)
cutL2 = usePartialST and not exitedThisBar and inLong  and st2FlipDn and (l2On or l3On)
cutS1 = usePartialST and not exitedThisBar and inShort and st1FlipUp and (s1On or s2On or s3On)
cutS2 = usePartialST and not exitedThisBar and inShort and st2FlipUp and (s2On or s3On)
if cutL1
    cutTopLong()
if cutL2
    cutTopLong()
if cutS1
    cutTopShort()
if cutS2
    cutTopShort()

// ???箏 E嚗?菜4] Regime-fade ?詨??駁◢?迎??箏?游?蝔望?菜2嚗?閮剝?嚗? ablation嚗???//   ?葉 er < erThr?fadeK嚗縑敹菜??嚗? ???怠?蝣澆惜銝 tranche嚗??敹?L1嚗tage?? 靽?嚗?//   撣蝯?嚗 ??regime gate ?芰恣?脣嚗??葉頞典憭望?頧?湔敹??嚗迨?箝縑敹菜????//   皜Ⅳ????er/erThr/cutTop ??嚗?啣??航矽?芰摨佗?fadeK ?箏銝閫貊靽嚗?閮剝?嚗?fadeTrig = useRegimeFade and not exitedThisBar and er < erThr * fadeK and stage >= 2
fadeLong  = fadeTrig and inLong
fadeShort = fadeTrig and inShort
if fadeLong
    cutTopLong()
if fadeShort
    cutTopShort()

// ???箏 F嚗elowAvg/aboveAvg ?怠惜皜Ⅳ嚗?挾??閮剝?嚗??撟喟??詨??? ??//   蝬?contiguous-stack嚗?????怠?游惜????tranche嚗op-first嚗?靽??詨? L1 頝撠橘?
//   stage>=2 璇辣蝣箔??喳?????蝣澆惜?臬?嚗1 瘞訾?鋡急迨頝臬?閫詨???belowAvgLong  = useBelowAvg and not exitedThisBar and inLong  and stage >= 2 and close < avgPx - kBuf * atrChand
aboveAvgShort = useBelowAvg and not exitedThisBar and inShort and stage >= 2 and close > avgPx + kBuf * atrChand
if belowAvgLong
    cutTopLong()
if aboveAvgShort
    cutTopShort()

// ????????????????????????????????????????????????????????????????????????????
// 禮11  ?脣嚗?蝛箏?潮??擐憟?regime gate嚗?蝣澆? winners-add-only + vol-brake嚗?//      ??禮10 靽? stage ???嚗1Cond(stage==0) ??蝣?l1On==true) 瘞詨???⊿?蝝?甇颯?// ????????????????????????????????????????????????????????????????????????????
canEnter = bar_index >= cooldownUntil and not exitedThisBar
// 擐嚗T1 蝧餃? + regime gate
l1Cond = stage == 0 and st1FlipUp and regimeLongOK  and canEnter
s1Cond = stage == 0 and st1FlipDn and regimeShortOK and canEnter
// ?Ⅳ嚗?畾萄歇瘚桃?(R>0)?隅?Ｗ??T ?亙?蝧餃????芾孛??vol-brake嚗?瘜Ｗ???嚗?addOK  = not volBrakeOn and R > 0
l2Cond = stage == 1 and l1On and inLong  and st2FlipUp and st1Bull and addOK
l3Cond = stage == 2 and l1On and l2On and inLong  and st3FlipUp and st1Bull and st2Bull and addOK
s2Cond = stage == 1 and s1On and inShort and st2FlipDn and st1Bear and addOK
s3Cond = stage == 2 and s1On and s2On and inShort and st3FlipDn and st1Bear and st2Bear and addOK

if l1Cond
    strategy.entry("L1", strategy.long, qty=qty1, comment="L1")
    entryRisk := chandMult * atrChand   // ???祕??甇Ｘ?頝??R ??
    entryPx   := close
    trailExt  := high
    trailStop := na
    entryBar  := bar_index
    peakR     := 0.0                    // [?菜3] ?啣陸??R 甇賊
    l1On := true
    notL1 := qty1                       // 閮?閰脣惜銝?⊥嚗? TP/cut/fade 蝝蝎曄Ⅱ撠董
if l2Cond
    strategy.entry("L2", strategy.long, qty=qty2, comment="L2")
    l2On := true
    notL2 := qty2
if l3Cond
    strategy.entry("L3", strategy.long, qty=qty3, comment="L3")
    l3On := true
    notL3 := qty3
if s1Cond
    strategy.entry("S1", strategy.short, qty=qty1, comment="S1")
    entryRisk := chandMult * atrChand
    entryPx   := close
    trailExt  := low
    trailStop := na
    entryBar  := bar_index
    peakR     := 0.0                    // [?菜3] ?啣陸??R 甇賊
    s1On := true
    notS1 := qty1
if s2Cond
    strategy.entry("S2", strategy.short, qty=qty2, comment="S2")
    s2On := true
    notS2 := qty2
if s3Cond
    strategy.entry("S3", strategy.short, qty=qty3, comment="S3")
    s3On := true
    notS3 := qty3

// nCap ??閮嚗??vol-target ?臬鋡急?獢蹂???頝荔?
if cap1 or cap2 or cap3
    capHits += 1

// ????????????????????????????????????????????????????????????????????????????
// 禮12  閬死???典 global scope嚗?// ????????????????????????????????????????????????????????????????????????????
c1 = st1Bull ? color.new(color.green, 0)  : color.new(color.red, 0)
c2 = st2Bull ? color.new(color.green, 30) : color.new(color.red, 30)
c3 = st3Bull ? color.new(color.green, 55) : color.new(color.red, 55)
plot(showST ? st1 : na, "ST1", color=c1, linewidth=1)
plot(showST ? st2 : na, "ST2", color=c2, linewidth=1)
plot(showST ? st3 : na, "ST3", color=c3, linewidth=2)
plot(showAvg and stage >= 1 ? avgPx : na, "AvgCost", color=color.new(color.yellow, 0), linewidth=1, style=plot.style_linebr)
plot(showStop and inPos ? trailStop : na, "TrailStop", color=color.new(color.orange, 0), linewidth=1, style=plot.style_linebr)

// ?嚗egime ?孵?(瘛? + ??畾?頛楛)
bgReg = showBg and regimeOn ? (dirLong ? color.new(color.green, 93) : color.new(color.red, 93)) : na
bgStg = showBg and inPos ? (inLong ? color.new(color.teal, 90 - stage * 6) : color.new(color.maroon, 90 - stage * 6)) : na
bgcolor(na(bgStg) ? bgReg : bgStg)

plotshape(showSignals and l1Cond, "L1", shape.triangleup,   location.belowbar, color.new(color.lime, 0),   size=size.tiny,   text="L1")
plotshape(showSignals and l2Cond, "L2", shape.triangleup,   location.belowbar, color.new(color.green, 0),  size=size.small,  text="L2")
plotshape(showSignals and l3Cond, "L3", shape.triangleup,   location.belowbar, color.new(color.teal, 0),   size=size.normal, text="L3")
plotshape(showSignals and s1Cond, "S1", shape.triangledown, location.abovebar, color.new(color.orange, 0), size=size.tiny,   text="S1")
plotshape(showSignals and s2Cond, "S2", shape.triangledown, location.abovebar, color.new(color.red, 0),    size=size.small,  text="S2")
plotshape(showSignals and s3Cond, "S3", shape.triangledown, location.abovebar, color.new(color.maroon, 0), size=size.normal, text="S3")
tpAny  = tpHitL1 or tpHitL2 or tpHitS1 or tpHitS2
cutAny = cutL1 or cutL2 or cutS1 or cutS2
fadeAny = fadeLong or fadeShort
plotshape(showSignals and tpAny,  "TP",  shape.circle,  location.abovebar, color.new(color.aqua, 0),    size=size.tiny, text="TP")
plotshape(showSignals and cutAny, "Cut", shape.diamond, location.abovebar, color.new(color.purple, 0),  size=size.tiny, text="cut")
plotshape(showSignals and fadeAny,"Fade",shape.xcross,  location.abovebar, color.new(color.fuchsia, 0), size=size.tiny, text="fade")
fullExit = trailHitLong or trailHitShort or twoSTRevLong or twoSTRevShort or timeStopLong or timeStopShort
plotshape(showSignals and fullExit, "OUT", shape.xcross, location.abovebar, color.new(color.red, 0), size=size.tiny, text="X")

// ????????????????????????????????????????????????????????????????????????????
// 禮13  ???銵冽嚗銝? table嚗?漱??隤儔? + ?桐?嚗?10 ??// ????????????????????????????????????????????????????????????????????????????
regimeTxt = regimeOn ? (dirLong ? "頞典?脣?" : dirShort ? "頞典?潛征" : "頞典") : "?斗/Range"
posTxt    = inLong ? "憭?L" + str.tostring(stage) : inShort ? "蝛?S" + str.tostring(stage) : "?∪?
stopTxt   = inPos and not na(trailStop) ? str.tostring(trailStop, format.mintick) : "??
distR     = inPos and not na(trailStop) and atrChand > 0 ? math.abs(close - trailStop) / atrChand : na
distTxt   = na(distR) ? "?? : str.tostring(distR, "#.0") + " ATR"
// vol-target ??嚗?璅??芯? equity 瘥?vtScale?totW嚗?銝?嚗?exposureRaw = useVolTarget ? vtScale * totW : totW
exposureEff = math.min(exposureRaw, maxGross)
vtTxt     = useVolTarget ? str.tostring(exposureEff, "#.00") + "x (?格?" + str.tostring(targetVol * 100, "#") + "%)" : "?箏?甈?"
ivTxt     = str.tostring(instVolAnn * 100, "#.0") + "%"
tpTxt     = (tp1Done ? "TP1?? : "TP1繚") + " " + (tp2Done ? "TP2?? : "TP2繚") + (tp1Done and useBEonTP1 ? " ??BE" : "")
voteTxt   = str.tostring(votesLong) + "/" + str.tostring(votesShort) + " ?? + str.tostring(effMinVotes) + (votesUnreachable ? " ?lamp" : "")
// [?菜3] 撜啣?R ?????輻???peakTxt   = inPos ? str.tostring(peakR, "#.0") + "R" + (peakFloorOK ? " ??rat" : "") : "??

var table dash = table.new(position.top_right, 2, 10, border_width=1, frame_color=color.new(color.gray, 40), frame_width=1)
if showTable and barstate.islast
    bgH = color.new(color.blue, 20)
    bgV = color.new(color.black, 25)
    txc = color.white
    table.cell(dash, 0, 0, "撣???, text_color=txc, bgcolor=bgH, text_size=size.small)
    table.cell(dash, 1, 0, regimeTxt, text_color=txc, bgcolor=regimeOn ? color.new(color.green, 40) : color.new(color.orange, 40), text_size=size.small)
    table.cell(dash, 0, 1, "????挾", text_color=txc, bgcolor=bgH, text_size=size.small)
    table.cell(dash, 1, 1, posTxt, text_color=txc, bgcolor=inLong ? color.new(color.green, 45) : inShort ? color.new(color.red, 45) : bgV, text_size=size.small)
    table.cell(dash, 0, 2, "????, text_color=txc, bgcolor=bgH, text_size=size.small)
    table.cell(dash, 1, 2, stopTxt, text_color=txc, bgcolor=bgV, text_size=size.small)
    table.cell(dash, 0, 3, "頝???, text_color=txc, bgcolor=bgH, text_size=size.small)
    table.cell(dash, 1, 3, distTxt, text_color=txc, bgcolor=bgV, text_size=size.small)
    table.cell(dash, 0, 4, "瘜Ｗ???", text_color=txc, bgcolor=bgH, text_size=size.small)
    table.cell(dash, 1, 4, vtTxt, text_color=txc, bgcolor=bgV, text_size=size.small)
    table.cell(dash, 0, 5, "撟游?瘜Ｗ?", text_color=txc, bgcolor=bgH, text_size=size.small)
    table.cell(dash, 1, 5, ivTxt + (volBrakeOn ? " ??頠? : ""), text_color=txc, bgcolor=volBrakeOn ? color.new(color.red, 40) : bgV, text_size=size.small)
    table.cell(dash, 0, 6, "?桀? R", text_color=txc, bgcolor=bgH, text_size=size.small)
    table.cell(dash, 1, 6, inPos ? str.tostring(R, "#.0") + "R" : "??, text_color=txc, bgcolor=inPos and R >= 0 ? color.new(color.green, 50) : inPos ? color.new(color.red, 50) : bgV, text_size=size.small)
    table.cell(dash, 0, 7, "撜啣嘶/????, text_color=txc, bgcolor=bgH, text_size=size.small)
    table.cell(dash, 1, 7, peakTxt, text_color=txc, bgcolor=peakFloorOK ? color.new(color.green, 40) : bgV, text_size=size.small)
    table.cell(dash, 0, 8, "甇Ｙ??脣漲", text_color=txc, bgcolor=bgH, text_size=size.small)
    table.cell(dash, 1, 8, inPos ? tpTxt : "??, text_color=txc, bgcolor=bgV, text_size=size.small)
    table.cell(dash, 0, 9, "?巨L/S", text_color=txc, bgcolor=bgH, text_size=size.small)
    table.cell(dash, 1, 9, voteTxt, text_color=txc, bgcolor=votesUnreachable ? color.new(color.orange, 30) : bgV, text_size=size.small)

