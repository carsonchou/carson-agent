modLine1  = usePureA ? "蝝蝺??券?脤?璈??)" : ("????" + (effPeakRatchet?"??:"??) + " 瘜Ｗ???:" + (effBreathGB?"??:"??) + " 撟湧翩?唳:" + (effStallRatchet?"??:"??))
modLine2  = usePureA ? "?? : ("?０靽:" + (effTPstair?"??:"??) + " 撌脣祕?暸:" + (effBankedFloor?"??:"??) + " 瘜Ｗ?trail:" + (effBreathTrail?"??:"??))
