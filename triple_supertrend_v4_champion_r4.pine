    table.cell(dash, 0, 13, "撜啣澆?皛?撟湧翩", text_color=txc, bgcolor=bgH, text_size=size.small)
    table.cell(dash, 1, 13, stallTxt, text_color=txc, bgcolor=inPos and effStallRatchet and stallShrink < 0.999 ? color.new(color.orange, 35) : bgV, text_size=size.small)
    table.cell(dash, 0, 14, "ER?(?ER繚鈭?)", text_color=txc, bgcolor=bgH, text_size=size.small)
    table.cell(dash, 1, 14, str.tostring(er, "#.00") + " (?" + str.tostring(erSlope, "#.00") + (erSlope >= 0 ? " ?? : " ??) + " 繚鈭?" + str.tostring(erAccel2, "#.00") + ")", text_color=txc, bgcolor=inPos and effErAccelAdd and erSlope < 0 ? color.new(color.orange, 35) : bgV, text_size=size.small)
