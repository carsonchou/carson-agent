regimeTxt = regimeOn ? (dirLong ? "頞典繚憭? : dirShort ? "頞典繚蝛? : "頞典") : "?斗/Range"
posTxt    = inLong ? "憭 蝚? + str.tostring(stageLive) + "畾? : inShort ? "蝛箏 蝚? + str.tostring(stageLive) + "畾? : "?∪?
