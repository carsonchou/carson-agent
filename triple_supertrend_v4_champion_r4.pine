// 銝?trail ?芷????銝剜??剛?嚗?multStep + ?澆靘? + 銝?游漲 + 頝典偕摨?cohNow    = inLong ? coherenceLong : inShort ? coherenceShort : 0
trailSrcVal = effDecorrGauge ? breathPctl : breathClamp
trailBreathTxt = effBreathTrail ? (effDecorrGauge ? " 繚?曉?雿?蜆? : " 繚瘜Ｗ??澆?") + str.tostring(trailSrcVal, "#.0") : ""
trailCohTxt = effCoherenceTrail ? (cohNow >= 3 ? " 繚銝?游漲撘??曉祝)" : cohNow <= 1 ? " 繚銝?游漲撘??嗥?)" : " 繚銝?游漲銝?) : ""
msActive   = effMultiScaleStop and beActive and st3Band > atrChand
trailMSTxt = effMultiScaleStop ? (msActive ? " 繚頝典偕摨血??ST3撖?" : " 繚頝典偕摨?敹隹TR銝餃?)") : ""
trailTxt  = inPos ? str.tostring(multStep, "#.0") + "?ATR" + trailBreathTxt + trailCohTxt + trailMSTxt : "??
// ?脣?瑕???銝剜??剛?嚗?cdRemain  = math.max(cooldownUntil - bar_index, 0)
cdTxt     = (cdRemain > 0 ? "?瑕銝??? + str.tostring(cdRemain, "#") + "璉? : "撠梁?") + (effAdaptiveCooldown ? " (?芷?? + str.tostring(breathClamp, "#.0") + ")" : "")
// 撜啣澆?皛?頞典撟湧翩???銝剜??剛?嚗?stallTxt  = inPos ? "?趙" + str.tostring(barsSincePeak) + "璉? + (effStallRatchet ? (stallShrink < 0.999 ? " 繚?銵啁垠(?唳?嗥?)" : " 繚?隞") : "") : "??
// ?脣????NEW-A2 / NEW-A3 / ?1 / ?2 / ??E2 銝剜??剛?嚗?entryGateTxt = (effEntryDistGate ? "?孵榆?????? + str.tostring(kBuf, "#.0") + "ATR)" : "?孵榆????) + " ??" + (effMidConfirm ? "銝剖偕摨衣Ⅱ隤??? : "銝剖偕摨衣Ⅱ隤???) + " ??" + (effAdaptiveMinVotes ? "?芷?巨???? + (lowVolRegime ? "(雿郭+" + str.tostring(extraVoteLowVol) + ")" : "") : "?芷?巨????)
// ?Ⅳ????A3 蝯? / C1 ?(?恍皛? / E3 ??(??F1 ?芷??嚗?erAccelGateTxt = effErAccelAdd ? "ER?漲:???ER?? + (erHystFrac > 0 ? "?? + str.tostring(erHystBand, "#.00") : "0") + ")" : "ER?漲:??
spaceGateTxt   = effAddSpacing ? "???????? + str.tostring(addSpace) + "璉? + (effAddSpaceVol ? "繚瘜Ｗ??" + str.tostring(spaceVolK, "#.0") : "") + "繚?? + str.tostring(e3BlockedAdds) + ")" : "??????
addGateTxt   = (effCoherenceAdd ? "銝?游?蝣???????)" : "銝?游?蝣???) + " ??" + erAccelGateTxt + " ??" + spaceGateTxt
