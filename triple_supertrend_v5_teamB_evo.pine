showSignals = input.bool(true, "憿舐內?脣?湔?閮?, group=gViz)
showBg      = input.bool(true, "憿舐內 Regime / ?挾???, group=gViz)
showTable   = input.bool(true, "憿舐內?喃?閫???銵冽", group=gViz)
showDebug   = input.bool(false, "憿舐內?日甈?votes/floor/cap/TP 撠董/peakR/?質?%/?澆/?０/??唳)", group=gViz)

// ?? 瘥?????蝝蝺?撘瑕?????脤??菜嚗???10 ????????????????????
effPeakRatchet = usePeakRatchet and not usePureA
effRegimeFade  = useRegimeFade  and not usePureA
effAdaptiveTS  = useAdaptiveTS  and not usePureA
effMTFgate     = useMTFgate     and not usePureA
effBreathGB    = useBreathGiveback and not usePureA   // [SUPREME-1] ?澆撘???
effTPstair     = useTPstairBE   and not usePureA       // [SUPREME-2] ?０?唳嚗? usePureA 蝝?嚗??箇?銝情?敹???選?
effBreathRStep = useBreathRStep and not usePureA       // [NEW-1] ?澆撘?R ?０?蝺?
effBankedExempt= useBankedExempt and not usePureA      // [NEW-2] 撌脰鋡???+ ER ??time-stop
effFadeDepth   = useFadeDepth   and not usePureA        // [NEW-3] fade 瘛勗漲?惜
effCostAwareBE = useCostAwareBE and not usePureA        // [NEW-4] ?? BE ?唳銝?

// ????????????????????????????????????????????????????????????????????????????
// 禮2  銝惜 SuperTrend嚗銝?箇??望?瘣曄?嚗a.supertrend ? [value,direction]嚗?//     direction < 0 ?箏???// ????????????????????????????????????????????????????????????????????????????
len1 = baseLen
len2 = math.max(math.round(baseLen * midMult), 2)
len3 = math.max(math.round(baseLen * slowMult), 3)
[st1, dir1] = ta.supertrend(f1, len1)
[st2, dir2] = ta.supertrend(f2, len2)
[st3, dir3] = ta.supertrend(f3, len3)

st1Bull = dir1 < 0
st2Bull = dir2 < 0
st3Bull = dir3 < 0
st1Bear = not st1Bull
st2Bear = not st2Bull
st3Bear = not st3Bull
// 蝧餉?鈭辣嚗??格?暺???
st1FlipUp   = st1Bull and not st1Bull[1]
st2FlipUp   = st2Bull and not st2Bull[1]
st3FlipUp   = st3Bull and not st3Bull[1]
st1FlipDn   = st1Bear and not st1Bear[1]
st2FlipDn   = st2Bear and not st2Bear[1]
st3FlipDn   = st3Bear and not st3Bear[1]

// [?菜5] ST3 蝧餃?敺?瘣餅??賂??Ｙ?瑽??漲嚗?璉閮? request.security ?鼓憸券嚗?var int st3BullBars = 0
var int st3BearBars = 0
st3BullBars := st3Bull ? nz(st3BullBars[1]) + 1 : 0
st3BearBars := st3Bear ? nz(st3BearBars[1]) + 1 : 0
// persistBars ?望??len3 瘣曄???clamp ??[3, mtfCapBars]嚗tfCapBars ?箸憓?勗漲嚗?persistBars  = math.min(math.max(len3, 3), mtfCapBars)
mtfBullOK    = not effMTFgate or (st3Bull and st3BullBars >= persistBars)
mtfBearOK    = not effMTFgate or (st3Bear and st3BearBars >= persistBars)

// ????????????????????????????????????????????????????????????????????????????
// 禮3  ATR% 甇???皞???????瑼颱?敺撠?嚗?頝典???蝝情??
// ????????????????????????????????????????????????????????????????????????????
atrAdx   = ta.atr(adxLen)
atrChand = ta.atr(chandLen)
atrPct   = atrAdx / close              // ATR%嚗撠??箸?嚗?
// ????????????????????????????????????????????????????????????????????????????
// 禮4  瘜Ｗ??摯閮?撟游??撠?嚗? VT-Core ??
//     instVolAnn嚗僑??郭???冽??甇????relVol嚗撠葉雿嚗?澆???頠??澆
// ????????????????????????????????????????????????????????????????????????????
logRet      = math.log(close / close[1])
stdevDaily  = ta.stdev(logRet, volLen)
volAnnATR   = atrPct       * math.sqrt(barsPerYear)   // ATR% 撟游?
volAnnStd   = stdevDaily   * math.sqrt(barsPerYear)   // ?梢 std 撟游?
instVolAnn  = volEstMode == "Stdev" ? volAnnStd : volAnnATR
// ?詨??????頨怨? brakeLen 璉僑?郭??雿??嚗楊???芷???踹?蝯? floor 憭梁?
volFloor    = ta.percentile_linear_interpolation(instVolAnn, brakeLen, 5)
volFloor   := na(volFloor) ? 0.02 : math.max(volFloor, 0.001)
instVolAnn := math.max(nz(instVolAnn, volFloor), volFloor)
// ??頠??澆?箸?嚗nstVolAnn ?詨??園?葉雿
volMedian   = ta.median(instVolAnn, brakeLen)
volMedian  := na(volMedian) ? instVolAnn : math.max(volMedian, volFloor)
relVol      = instVolAnn / volMedian
volBrakeOn  = useVolBrake and relVol > brakeK     // true=擃郭???怠??Ⅳ
var int floorHits = 0
if instVolAnn <= volFloor + 1e-12
    floorHits += 1

// ????????????????????????????????????????????????????????????????????????????
// 禮5  Regime ??嚗R / ADX ?脫趙 / ST3 ?Ｘ??嚗? ?巨?券??脤?甇?靽格迤3)
// ????????????????????????????????????????????????????????????????????????????
// Kaufman ??瘥??駁?日嚗 math.sum ??math.sum嚗?erChange = math.abs(close - close[erLen])
erVolSum = math.sum(math.abs(close - close[1]), erLen)
er       = erVolSum > 0 ? erChange / erVolSum : 0.0
er      := nz(er, 0.0)

// ADX / DI嚗皛舫??曉潘?
[diPlus, diMinus, adx] = ta.dmi(adxLen, adxLen)
var bool adxOn_state = false
if adx > adxOn
    adxOn_state := true
else if adx < adxOff
    adxOn_state := false

// ST3 ?Ｘ??
slowBull = st3Bull
slowBear = st3Bear

// ?巨嚗?蟡函??舐蝡??????巨銝??亙?瘥???嚗?voteER_long   = useER     and er > erThr
voteADX_long  = useADX    and adxOn_state
voteSlow_long = useSlowST and slowBull
voteER_short  = useER     and er > erThr
voteADX_short = useADX    and adxOn_state
voteSlow_short= useSlowST and slowBear
votesLong  = (voteER_long?1:0)  + (voteADX_long?1:0)  + (voteSlow_long?1:0)
votesShort = (voteER_short?1:0) + (voteADX_short?1:0) + (voteSlow_short?1:0)
// [靽格迤3] 撌脣??函巨?賂????瑼?= min(minVotes, ?蟡冽)嚗??蟡典??甇?enabledVotes = (useER?1:0) + (useADX?1:0) + (useSlowST?1:0)
effMinVotes  = math.min(minVotes, enabledVotes)
votesUnreachable = minVotes > enabledVotes   // ?瑼?> ?舫?蟡冽 ??撌脤??clamp嚗?銵冽?內
// ?孵?蟡剁?憭征?湔?∪?嚗??臭?撌桃嚗?DI ?孵????靽格迤3)
dirLong  = diPlus  > diMinus
dirShort = diMinus > diPlus
diLongOK  = not useDIgate or dirLong
diShortOK = not useDIgate or dirShort

// ?巨???文?嚗??函巨??0 ??? ST 撠(true)嚗???Ｚ炊???香(靽格迤3)
voteLongPass  = enabledVotes == 0 ? true : votesLong  >= effMinVotes
voteShortPass = enabledVotes == 0 ? true : votesShort >= effMinVotes
// [?菜5] MTF ?Ｙ?瑽??漲?蔥?仿???gate嚗ND嚗?閮剝?靘?ablation嚗ffMTFgate 撌脣 usePureA嚗?regimeLongOK  = not useRegime or (voteLongPass  and diLongOK  and mtfBullOK)
regimeShortOK = not useRegime or (voteShortPass and diShortOK and mtfBearOK)
// regime 撘瑕摹嚗??/?銵冽嚗?隞颱??孵???瑼餉???trend-on
regimeOn = (voteLongPass and dirLong) or (voteShortPass and dirShort)

// ????????????????????????????????????????????????????????????????????????????
// 禮6  ???嚗銝?嚗誑?惜?典 bool ?遣 stage嚗?蝯???皜?頝喳惜嚗?//     銝?撘?l3On?2On?1On嚗?嚗? s3On?2On?1On嚗征嚗???禮10 contiguous-stack
//     皜?隤?霅?stage 瘞貊??? 0/1/2/3嚗摮文?/?游惜??//     禮6 ??stage ?箸?擐潘?靘?禮9 timeStop 甇?Ⅱ閮?嚗???皜??風甈??Ⅳ/憿舐內/撠董銝敺?//     ?寧 fresh 瘣?stage嚗?0/禮11/禮12+ ?望?蝯?l*On ?遣嚗??? stale stage??// ????????????????????????????????????????????????????????????????????????????
var bool  l1On = false
var bool  l2On = false
var bool  l3On = false
var bool  s1On = false
var bool  s2On = false
var bool  s3On = false
var int   entryBar  = 0
var float entryPx   = na    // 擐?嚗 ?箸??典?嚗??典?蝣潭?蝘鳴?
var float entryRisk = na    // [靽格迤1] ???脣??甇Ｘ?頝嚗 ??嚗? chandMult?atrChand
var float trailExt  = na    // 璆萄潛敞蝛?high/low嚗?var float trailStop = na
var float cooldownUntil = 0.0
// Partial TP one-shot ??銝甈⊥改??箏/???蔭嚗?var bool  tp1Done = false
var bool  tp2Done = false
// [?菜3] ? high-water R嚗eak-anchored ????嚗ot inPos / clearAll 甇賊
var float peakR = 0.0
// [?梯?靽格迤] TP 蝝航?撖阡??質????脣蝮賡?嚗??敞閮鋡? vs 摰?迂%??撣?var float bankedQty = 0.0
var float openInitQty = 0.0
// [?菜4] regime-fade 銝甈⊥扯風甈?+ ?撠??????脫趙嚗?蝯?瑼駁?餈????嚗?var bool  fadeArmed     = true
var int   lastFadeBar   = -100000
// ?惜銝?⊥閮董嚗? Partial TP / cut / regime-fade 蝝蝎曄Ⅱ撠董嚗脣撖怠????扎lat 甇賊嚗?var float notL1 = 0.0
var float notL2 = 0.0
var float notL3 = 0.0
var float notS1 = 0.0
var float notS2 = 0.0
var float notS3 = 0.0

inLong  = strategy.position_size > 0
inShort = strategy.position_size < 0
inPos   = strategy.position_size != 0
posSize = math.abs(strategy.position_size)
avgPx   = strategy.position_avg_price

// ?箏蝯?敺??單飛?塚?瘨迨??銝?鞈港?銝璉辣?莎???[reset 蝻箏靽格迤] 鋆?entryBar:=0
if not inPos
    l1On := false
    l2On := false
    l3On := false
    s1On := false
    s2On := false
    s3On := false
    entryRisk := na
    entryPx   := na
    trailExt  := na
    trailStop := na
    entryBar  := 0     // [reset 蝻箏靽格迤] ?典像?喳??湧?蝵?entryBar嚗????瞏楊
    tp1Done   := false
    tp2Done   := false
    peakR     := 0.0
    bankedQty := 0.0
    openInitQty := 0.0
    fadeArmed := true
    notL1 := 0.0
    notL2 := 0.0
    notL3 := 0.0
    notS1 := 0.0
    notS2 := 0.0
    notS3 := 0.0

longStage  = (l1On?1:0) + (l2On?1:0) + (l3On?1:0)
shortStage = (s1On?1:0) + (s2On?1:0) + (s3On?1:0)
stage = inLong ? longStage : inShort ? shortStage : 0   // 璉? stage嚗? 禮9 timeStop 閮?嚗?
// ????????????????????????????????????????????????????????????????????????????
// 禮7  ??閮?嚗T-Core嚗僑?郭?璅? ??? ??蝮賣?獢?clamp ??qty嚗?//     qty = (targetVol / instVolAnn) * equity * weight / close
//     [?菜2] ?Ⅳ撅斗????clamp(er/erThr,0.5,1.0)嚗R 靽∪艙??
// ????????????????????????????????????????????????????????????????????????????
// 頝臬?靘陷?嚗??鞈?像皛?equity 瘛瑕?雿 sizing ?箸?嚗?銴頝臬??曉之
var float avgEq = na
avgEq := na(avgEq) ? strategy.equity : avgEq * 0.99 + strategy.equity * 0.01
sizeBase = 0.5 * strategy.initial_capital + 0.5 * avgEq

// vol-target 瘥?嚗?????摰????改?瘥?=1嚗?vtScale = useVolTarget ? targetVol / instVolAnn : 1.0
// [?菜2] ER 靽∪艙靽嚗??嚗lamp 0.5~1.0嚗????冽?Ⅳ撅?L2/L3嚗???L1 銝葬??convMult = useConvAdd and erThr > 0 ? math.min(math.max(er / erThr, 0.5), 1.0) : 1.0
wL2eff = wL2 * convMult
wL3eff = wL3 * convMult
totW    = wL1 + wL2 + wL3          // 蝮賣?獢踹??誑?甈?(銝靽∪艙蝮格)?箏皞?靽?銝?蝛拙?
var int capHits = 0

// ?桐??箏嚗策摰惜甈? ???格?? ???府撅文???瑽▼銝? clamp ??qty(??/?aN)
qtyFor(w) =>
    float notion = vtScale * sizeBase * w
    float nCap = totW > 0 ? sizeBase * maxGross * (w / totW) : sizeBase * maxGross
    bool  capped = notion > nCap
    notion := math.min(notion, nCap)
    float q = close > 0 ? notion / close : 0.0
    q := math.max(nz(q, 0.0), 0.0)
    [q, capped]

[qty1, cap1] = qtyFor(wL1)
[qty2, cap2] = qtyFor(wL2eff)
[qty3, cap3] = qtyFor(wL3eff)

// ????????????????????????????????????????????????????????????????????????????
// 禮8  R-multiple ??Chandelier ratchet ??嚗?蝛粹??only-up / only-down嚗?//     [靽格迤1] R ?? = entryRisk嚗脣??銋?chandMult?atrChand ??甇Ｘ?頝嚗?//     ?唳??嚗ath.max ??蝺?嚗 ?０ ??BE ??SUPREME-2 ?０?唳 ???澆/peakR ????唳
// ????????????????????????????????????????????????????????????????????????????
rDenom  = na(entryRisk) ? (chandMult * atrChand) : entryRisk   // ?祕??甇Ｘ?頝
rBasePx = na(entryPx)   ? avgPx : entryPx
R = inPos and rDenom > 0 ? (inLong ? (close - rBasePx) / rDenom : (rBasePx - close) / rDenom) : 0.0
// [?菜3] ?湔? high-water R嚗?脖??嚗ot inPos 撌脫 禮6 甇賊嚗?if inPos
    peakR := math.max(peakR, R)

// [NEW-1] ?澆撘?R ?０?蝺?嚗?瘜Ｗ??嗅 trailTightR??瘜Ｗ??曉祝??trailMidR嚗 瘝?嚗?//   breathFrac = clamp((relVol-1)/(brakeK-1),0,1)嚗ffTightR = trailTightR + (trailMidR-trailTightR)?breathFrac
breathFrac = brakeK > 1.0 ? math.min(math.max((relVol - 1.0) / (brakeK - 1.0), 0.0), 1.0) : 0.0
effTightR  = effBreathRStep ? trailTightR + (trailMidR - trailTightR) * breathFrac : trailTightR
// R ?０?嚗祝?葉??嚗隤踵蝺??曉之?喳偏??瑕椰撠橘?嚗?蝺??臬??multStep = not useRStep ? chandMult : (R < 1 ? chandMult : R < 2 ? trailMidR : effTightR)

// [?菜1] TP1 ?質?敺??詨??撥?嗡??穿?蝑??BE 閫貊??歇?質????
beActive = (useBE and R >= kBE) or (useBEonTP1 and tp1Done)

// ?? [SUPREME-1] ?澆撘???嚗ffGiveback = multBE ? clamp(relVol,1.0,brakeK)嚗??A嚗??
breathMult = effBreathGB ? math.min(math.max(relVol, 1.0), brakeK) : 1.0
effGiveback= multBE * breathMult
// [?菜3] Peak-R ???唳嚗???peakR 撌脩?銝?effGiveback 銋?????peakR>effGiveback嚗?peakFloorOn= effPeakRatchet and inPos and peakR > effGiveback

// ?? [NEW-4] ?/皛?? BE ?唳瘥挾?砍??????? A嚗??
//   ?拇銝?嚗?澆雿?嚗頞?commission(%?close) + ?抵? slippage(tick?mintick)??//   瘥挾?砍???stepUpL/S = max(multBE?rDenom, frictionFloorPx)嚗??????multBE?rDenom??frictionFloorPx = 2.0 * (strategy.commission.percent / 100.0) * close + 2.0 * slippage * syminfo.mintick
beStepUp        = effCostAwareBE ? math.max(multBE * rDenom, frictionFloorPx) : multBE * rDenom
costFloorActive = effCostAwareBE and frictionFloorPx > multBE * rDenom and inPos

// ?? [SUPREME-2] TP ?０撘??砍?選?瘥鋡?畾萄?蹂???beStepUp嚗??A嚗 NEW-4 ??嚗??
stairRungs   = (tp1Done ? 1 : 0) + (tp2Done ? 1 : 0)
tpStairOn    = effTPstair and inPos and stairRungs > 0
tpStairFloorL= rBasePx + stairRungs * beStepUp
tpStairFloorS= rBasePx - stairRungs * beStepUp

if useChandelier and inLong
    trailExt  := na(trailExt) ? high : math.max(trailExt, high)
    rawStop    = trailExt - multStep * atrChand
    trailStop := na(trailStop) ? rawStop : math.max(trailStop, rawStop)   // ratchet ?芷脖??
    if beActive
        trailStop := math.max(trailStop, rBasePx + beStepUp)               // BE ?唳嚗 NEW-4 ??嚗?    if tpStairOn
        trailStop := math.max(trailStop, tpStairFloorL)                    // [SUPREME-2] ?０?唳
    if peakFloorOn
        trailStop := math.max(trailStop, rBasePx + (peakR - effGiveback) * rDenom)   // [?菜3+SUPREME-1] ?澆????唳
else if useChandelier and inShort
    trailExt  := na(trailExt) ? low : math.min(trailExt, low)
    rawStop    = trailExt + multStep * atrChand
    trailStop := na(trailStop) ? rawStop : math.min(trailStop, rawStop)   // ratchet ?芷脖??
    if beActive
        trailStop := math.min(trailStop, rBasePx - beStepUp)               // BE ?唳(?∪?)
    if tpStairOn
        trailStop := math.min(trailStop, tpStairFloorS)                    // [SUPREME-2] ?０?唳(?∪?)
    if peakFloorOn
        trailStop := math.min(trailStop, rBasePx - (peakR - effGiveback) * rDenom)   // [?菜3+SUPREME-1] ?澆????唳(?∪?)

// ????????????????????????????????????????????????????????????????????????????
// 禮9  ?箏閫貊嚗??蝔梧?頞典???箔蜓?箏嚗elowAvg ?孵?畾萎??舫?嚗?//     [?菜6] time-stop 璉靘?ER ?芷??[NEW-2] 撌脰鋡???+ ER ??//     閮鳴??祆挾?典像閫貊??禮10 隞颱? reductions 銋?閰摯嚗?撘 禮6 璉? stage ??甇?Ⅱ??// ????????????????????????????????????????????????????????????????????????????
trailHitLong  = useChandelier and inLong  and not na(trailStop) and close < trailStop
trailHitShort = useChandelier and inShort and not na(trailStop) and close > trailStop
// ?賡摨?嚗翰+銝?ST ????嚗? ST 蝧餃?嚗?twoSTRevLong  = inLong  and st1Bear and st2Bear
twoSTRevShort = inShort and st1Bull and st2Bull
// [?菜6] ER ?芷??time-stop 璉嚗???er/erThr/timeStopBars嚗?啣? input嚗ffAdaptiveTS 撌脣 usePureA嚗?tsScale     = effAdaptiveTS and erThr > 0 ? math.min(math.max(er / erThr, 0.5), 1.0) : 1.0
// [NEW-2] ER ???芾鋡? er<erThr?0.5嚗縑敹萄援頝楛嚗??? 0.5 ???tsAccel     = effBankedExempt and erThr > 0 and er < erThr * 0.5 ? 0.5 : 1.0
effTimeStop = math.max(math.round(timeStopBars * tsScale * tsAccel), 1)
// [NEW-2] 撌脰鋡?tp1Done)?詨?????time-stop嚗歇撖衣 1R 銝府鋡怎甇餃??tsExemptLong  = effBankedExempt and tp1Done
tsExemptShort = effBankedExempt and tp1Done
timeStopLong  = useTimeStop and inLong  and not tsExemptLong  and (bar_index - entryBar) >= effTimeStop and R < 1 and stage < 3
timeStopShort = useTimeStop and inShort and not tsExemptShort and (bar_index - entryBar) >= effTimeStop and R < 1 and stage < 3

// ????????????????????????????????????????????????????????????????????????????
// 禮10  銝?瑁?嚗??箏敺脣嚗?璉????喳?甇伐?
// ????????????????????????????????????????????????????????????????????????????
var bool exitedThisBar = false
exitedThisBar := false

// ?? [BLOCKER-1/2/3 ?勗??孵?靽格迤] ??摨??暑?????? stale 敹怎 ??
//   隞?posLive 餈質馱??璉?擗雿?瘥活 drain 敺?文祕??鈭日? d)嚗??箸???drain ??//   posAbs 銝? + TP ?質??箸嚗???stage-gate ?寧? fresh l*On/s*On ?單?????瘣?stage??var float posLive = 0.0
posLive := posSize   // 璉?隞亙祕?雿?憪?嚗?甈?drain 敺 global scope ??撖阡??漱??d

// [Pine v5 蝖祉?? 雿輻??蝢拙撘??舀撖怠?撅?global) scope 霈??//   ?寧 global scope?ullExitNow ?? + ?葉銝畾?inline ?蔭??銝??典撘?鋆??mutation??bool fullExitNow = false

// 鈭斗??蝝????殷??脰歲蝛綽??支葉閫貊嚗?斤Ⅱ隤?頞典?箏隞銵???
if useHardStop and inLong and not na(trailStop)
    strategy.exit("hX-L", stop=trailStop, comment="HardStopL")
else if useHardStop and inShort and not na(trailStop)
    strategy.exit("hX-S", stop=trailStop, comment="HardStopS")

// ??銝餃??A嚗handelier trailStop嚗?斤Ⅱ隤? ??if trailHitLong
    strategy.close_all(comment="TrailL")
    fullExitNow := true
else if trailHitShort
    strategy.close_all(comment="TrailS")
    fullExitNow := true

// ???箏 B嚗? ST ??摨? ??if not fullExitNow and twoSTRevLong
    strategy.close_all(comment="2STrevL")
    fullExitNow := true
else if not fullExitNow and twoSTRevShort
    strategy.close_all(comment="2STrevS")
    fullExitNow := true

// ???箏 C嚗???????if not fullExitNow and (timeStopLong or timeStopShort)
    strategy.close_all(comment="TimeStop")
    fullExitNow := true

// [inline ?典像?蔭] ?誨??clearAll() ?賢?嚗 global scope ?孵神?典? var嚗?瘜?
if fullExitNow
    l1On := false
    l2On := false
    l3On := false
    s1On := false
    s2On := false
    s3On := false
    entryRisk := na
    entryPx   := na
    trailExt  := na
    trailStop := na
    entryBar  := 0     // [reset 蝻箏靽格迤] ?典像頝臬??郊?蔭 entryBar
    tp1Done   := false
    tp2Done   := false
    peakR     := 0.0
    bankedQty := 0.0
    openInitQty := 0.0
    fadeArmed := true
    notL1 := 0.0
    notL2 := 0.0
    notL3 := 0.0
    notS1 := 0.0
    notS2 := 0.0
    notS3 := 0.0
    exitedThisBar := true
    cooldownUntil := bar_index + cooldownBars
    posLive := 0.0     // [BLOCKER-2] ?典像敺?璉擗雿飛?塚?敺? drain 銝???TP ?箸?喟 0

// ?? contiguous-stack ?臭?皜?隤?蝝撘?top-first drain + global-scope 閫???神嚗??
//   [Pine v5 蝖祉?? 蝝撘????撅文????典??誑??喳??霈?撠撘?????//   ??????[done, ?啣??捌?, ?啣?棺?] tuple嚗??mutation 銝敺 global scope 閫???神??//   隤儔嚗ewest-first(L3?2?1) ???摰?撅斗???撅扎畾???遣?典 bool嚗?//   銝?撘?l3On?2On?1On ??top-first ??蝡?L1(rBasePx/entryPx 銋)敹 L2/L3 ?券?游??◤閫詨???drainLong(reqQty, posAbs, n3, n2, n1) =>
    float want = math.min(math.max(nz(reqQty, 0.0), 0.0), posAbs)
    float done = 0.0
    float r3 = n3
    float r2 = n2
    float r1 = n1
    if r3 > 1e-9 and want - done > 1e-9
        float take = math.min(want - done, r3)
        if take > 1e-9
            strategy.close("L3", qty=take, comment="cut-L3")
            r3   := r3 - take
            done := done + take
    if r2 > 1e-9 and want - done > 1e-9
        float take = math.min(want - done, r2)
        if take > 1e-9
            strategy.close("L2", qty=take, comment="cut-L2")
            r2   := r2 - take
            done := done + take
    if r1 > 1e-9 and want - done > 1e-9
        float take = math.min(want - done, r1)
        if take > 1e-9
            strategy.close("L1", qty=take, comment="cut-L1")
            r1   := r1 - take
            done := done + take
    [done, r3, r2, r1, r3 > 1e-9, r2 > 1e-9, r1 > 1e-9]
drainShort(reqQty, posAbs, n3, n2, n1) =>
    float want = math.min(math.max(nz(reqQty, 0.0), 0.0), posAbs)
    float done = 0.0
    float r3 = n3
    float r2 = n2
    float r1 = n1
    if r3 > 1e-9 and want - done > 1e-9
        float take = math.min(want - done, r3)
        if take > 1e-9
            strategy.close("S3", qty=take, comment="cut-S3")
            r3   := r3 - take
            done := done + take
    if r2 > 1e-9 and want - done > 1e-9
        float take = math.min(want - done, r2)
        if take > 1e-9
            strategy.close("S2", qty=take, comment="cut-S2")
            r2   := r2 - take
            done := done + take
    if r1 > 1e-9 and want - done > 1e-9
        float take = math.min(want - done, r1)
        if take > 1e-9
            strategy.close("S1", qty=take, comment="cut-S1")
            r1   := r1 - take
            done := done + take
    [done, r3, r2, r1, r3 > 1e-9, r2 > 1e-9, r1 > 1e-9]

// trancheTopLong/Short嚗??賢?嚗??喋???怠?游惜???柴???cutTop ????tranche
trancheTopLong(on3, on2, on1, n3, n2, n1) =>
    on3 ? n3 : on2 ? n2 : on1 ? n1 : 0.0
trancheTopShort(on3, on2, on1, n3, n2, n1) =>
    on3 ? n3 : on2 ? n2 : on1 ? n1 : 0.0

// ?? ?挾 R-multiple Partial TP嚗擗雿?posLive?瘥?蝎曄Ⅱ?質?嚗LOCKER-2 靽格迤嚗??
//   tpQty 銝敺誑 posLive(???嗅??拚??其?)?箏?賂?drain ??posAbs 銝?鈭血 posLive嚗?甈∟鋡?//   敺?posLive-=d?P2 ?芸?隞乓P1 ?質?敺葬撠??拚??其???嚗畾萄?閮偶銝???蜇?其???//   ?詨? L1 ??contiguous-stack newest-first + posAbs clamp ??靽風銝◤頞?撟單???tpHitL1 = usePartialTP and not exitedThisBar and inLong  and R >= tp1R and not tp1Done
tpHitL2 = usePartialTP and not exitedThisBar and inLong  and R >= tp2R and not tp2Done
tpHitS1 = usePartialTP and not exitedThisBar and inShort and R >= tp1R and not tp1Done
tpHitS2 = usePartialTP and not exitedThisBar and inShort and R >= tp2R and not tp2Done
if tpHitL1
    [d, n3, n2, n1, o3, o2, o1] = drainLong(posLive * tp1Pct / 100.0, posLive, notL3, notL2, notL1)
    notL3 := n3
    notL2 := n2
    notL1 := n1
    l3On  := o3
    l2On  := o2
    l1On  := o1
    bankedQty := bankedQty + d
    posLive   := math.max(posLive - d, 0.0)
    tp1Done := true
if tpHitL2
    [d, n3, n2, n1, o3, o2, o1] = drainLong(posLive * tp2Pct / 100.0, posLive, notL3, notL2, notL1)
    notL3 := n3
    notL2 := n2
    notL1 := n1
    l3On  := o3
    l2On  := o2
    l1On  := o1
    bankedQty := bankedQty + d
    posLive   := math.max(posLive - d, 0.0)
    tp2Done := true
if tpHitS1
    [d, n3, n2, n1, o3, o2, o1] = drainShort(posLive * tp1Pct / 100.0, posLive, notS3, notS2, notS1)
    notS3 := n3
    notS2 := n2
    notS1 := n1
    s3On  := o3
    s2On  := o2
    s1On  := o1
    bankedQty := bankedQty + d
    posLive   := math.max(posLive - d, 0.0)
    tp1Done := true
if tpHitS2
    [d, n3, n2, n1, o3, o2, o1] = drainShort(posLive * tp2Pct / 100.0, posLive, notS3, notS2, notS1)
    notS3 := n3
    notS2 := n2
    notS1 := n1
    s3On  := o3
    s2On  := o2
    s1On  := o1
    bankedQty := bankedQty + d
    posLive   := math.max(posLive - d, 0.0)
    tp2Done := true

// ???箏 D嚗T ???挾皜?cut嚗??蝬?contiguous-stack top-first嚗偶銝撅??香嚗?//   閫貊 bool 撌脖誑 fresh l*On/s*On ?斗(??stale stage)嚗rain ??posAbs 銝??寧 posLive??cutL1 = usePartialST and not exitedThisBar and inLong  and st1FlipDn and (l1On or l2On or l3On)
cutL2 = usePartialST and not exitedThisBar and inLong  and st2FlipDn and (l2On or l3On)
cutS1 = usePartialST and not exitedThisBar and inShort and st1FlipUp and (s1On or s2On or s3On)
cutS2 = usePartialST and not exitedThisBar and inShort and st2FlipUp and (s2On or s3On)
if cutL1
    float tr = trancheTopLong(l3On, l2On, l1On, notL3, notL2, notL1)
    if tr > 1e-9
        [d, n3, n2, n1, o3, o2, o1] = drainLong(tr, posLive, notL3, notL2, notL1)
        notL3 := n3
        notL2 := n2
        notL1 := n1
        l3On  := o3
        l2On  := o2
        l1On  := o1
        posLive := math.max(posLive - d, 0.0)
if cutL2
    float tr = trancheTopLong(l3On, l2On, l1On, notL3, notL2, notL1)
    if tr > 1e-9
        [d, n3, n2, n1, o3, o2, o1] = drainLong(tr, posLive, notL3, notL2, notL1)
        notL3 := n3
        notL2 := n2
        notL1 := n1
        l3On  := o3
        l2On  := o2
        l1On  := o1
        posLive := math.max(posLive - d, 0.0)
if cutS1
    float tr = trancheTopShort(s3On, s2On, s1On, notS3, notS2, notS1)
    if tr > 1e-9
        [d, n3, n2, n1, o3, o2, o1] = drainShort(tr, posLive, notS3, notS2, notS1)
        notS3 := n3
        notS2 := n2
        notS1 := n1
        s3On  := o3
        s2On  := o2
        s1On  := o1
        posLive := math.max(posLive - d, 0.0)
if cutS2
    float tr = trancheTopShort(s3On, s2On, s1On, notS3, notS2, notS1)
    if tr > 1e-9
        [d, n3, n2, n1, o3, o2, o1] = drainShort(tr, posLive, notS3, notS2, notS1)
        notS3 := n3
        notS2 := n2
        notS1 := n1
        s3On  := o3
        s2On  := o2
        s1On  := o1
        posLive := math.max(posLive - d, 0.0)

// ???箏 E嚗?菜4] Regime-fade ?詨??駁◢?迎??箏?游?蝔望?菜2 ?脣靽∪艙?Ⅳ嚗???//   [BLOCKER-1 靽格迤] 隞乓迨??fresh l*On/s*On ?單?????瘣?stage ??>=2 霅瑟?嚗?蝯???禮6
//   璉? stale stage嚗?璉? TP/cut ?祕?惜??2?? 敺?stale stage==2 ?炊隞?fade ??l2On/l3On
//   撌?false ????L1 ??rain ?敹?L1??冽暑 stage 敺?fade ??迨?颱???蝣澆惜?典??雿?//   [NEW-3] ?惜?賊 ER 撏抵?瘛勗漲??嚗epth>0.66 ??2 撅扎??1 撅歹?嚗?蝚?2 撅文?瘣?stage 隞?=2??if not inPos or er >= erThr
    fadeArmed := true   // ER ??頞?摰?瑼?erThr ???唳郎鋆??脫趙撣塚?
fadeTrig    = effRegimeFade and not exitedThisBar and erThr > 0 and er < erThr * fadeK
fadeReady   = fadeArmed and (bar_index - lastFadeBar) >= fadeCoolBars
fadeStageLong  = (l1On?1:0) + (l2On?1:0) + (l3On?1:0)
fadeStageShort = (s1On?1:0) + (s2On?1:0) + (s3On?1:0)
regimeFadeLong  = fadeTrig and inLong  and fadeStageLong  >= 2 and fadeReady
regimeFadeShort = fadeTrig and inShort and fadeStageShort >= 2 and fadeReady
// [NEW-3] 撏抵?瘛勗漲 ???惜?賂?1 ??2嚗?effFadeDepth ??????1
fadeDepth     = (erThr * fadeK) > 0 ? math.min(math.max((erThr * fadeK - er) / (erThr * fadeK), 0.0), 1.0) : 0.0
fadeTranches  = effFadeDepth and fadeDepth > 0.66 ? 2 : 1
var int lastFadeCut = 0   // ?祆?撖阡??惜?賂?靘?銵冽/debug 憿舐內嚗?lastFadeCut := 0
if regimeFadeLong
    float tr = trancheTopLong(l3On, l2On, l1On, notL3, notL2, notL1)
    if tr > 1e-9
        [d, n3, n2, n1, o3, o2, o1] = drainLong(tr, posLive, notL3, notL2, notL1)
        notL3 := n3
        notL2 := n2
        notL1 := n1
        l3On  := o3
        l2On  := o2
        l1On  := o1
        posLive := math.max(posLive - d, 0.0)
        lastFadeCut := lastFadeCut + 1
    // [NEW-3] 蝚砌?撅歹??迨?颱???蝣澆惜?典嚗暑 stage 隞?=2嚗? 瘞訾??敹?L1
    if fadeTranches >= 2 and ((l2On?1:0) + (l3On?1:0)) >= 1 and ((l1On?1:0) + (l2On?1:0) + (l3On?1:0)) >= 2
        float tr2 = trancheTopLong(l3On, l2On, l1On, notL3, notL2, notL1)
        if tr2 > 1e-9
            [d2, m3, m2, m1, p3, p2, p1] = drainLong(tr2, posLive, notL3, notL2, notL1)
            notL3 := m3
            notL2 := m2
            notL1 := m1
            l3On  := p3
            l2On  := p2
            l1On  := p1
            posLive := math.max(posLive - d2, 0.0)
            lastFadeCut := lastFadeCut + 1
    fadeArmed   := false
    lastFadeBar := bar_index
if regimeFadeShort
    float tr = trancheTopShort(s3On, s2On, s1On, notS3, notS2, notS1)
    if tr > 1e-9
        [d, n3, n2, n1, o3, o2, o1] = drainShort(tr, posLive, notS3, notS2, notS1)
        notS3 := n3
        notS2 := n2
        notS1 := n1
        s3On  := o3
        s2On  := o2
        s1On  := o1
        posLive := math.max(posLive - d, 0.0)
        lastFadeCut := lastFadeCut + 1
    if fadeTranches >= 2 and ((s2On?1:0) + (s3On?1:0)) >= 1 and ((s1On?1:0) + (s2On?1:0) + (s3On?1:0)) >= 2
        float tr2 = trancheTopShort(s3On, s2On, s1On, notS3, notS2, notS1)
        if tr2 > 1e-9
            [d2, m3, m2, m1, p3, p2, p1] = drainShort(tr2, posLive, notS3, notS2, notS1)
            notS3 := m3
            notS2 := m2
            notS1 := m1
            s3On  := p3
            s2On  := p2
            s1On  := p1
            posLive := math.max(posLive - d2, 0.0)
            lastFadeCut := lastFadeCut + 1
    fadeArmed   := false
    lastFadeBar := bar_index

// ???箏 F嚗elowAvg/aboveAvg ?怠惜皜Ⅳ嚗?挾??閮剝?嚗??撟喟??詨??? ??//   [BLOCKER-1 靽格迤] stage>=2 霅瑟??寧甇文 fresh l*On/s*On ?單????暑 stage??belowStageLong  = (l1On?1:0) + (l2On?1:0) + (l3On?1:0)
aboveStageShort = (s1On?1:0) + (s2On?1:0) + (s3On?1:0)
belowAvgLong  = useBelowAvg and not exitedThisBar and inLong  and belowStageLong  >= 2 and close < avgPx - kBuf * atrChand
aboveAvgShort = useBelowAvg and not exitedThisBar and inShort and aboveStageShort >= 2 and close > avgPx + kBuf * atrChand
if belowAvgLong
    float tr = trancheTopLong(l3On, l2On, l1On, notL3, notL2, notL1)
    if tr > 1e-9
        [d, n3, n2, n1, o3, o2, o1] = drainLong(tr, posLive, notL3, notL2, notL1)
        notL3 := n3
        notL2 := n2
        notL1 := n1
        l3On  := o3
        l2On  := o2
        l1On  := o1
        posLive := math.max(posLive - d, 0.0)
if aboveAvgShort
    float tr = trancheTopShort(s3On, s2On, s1On, notS3, notS2, notS1)
    if tr > 1e-9
        [d, n3, n2, n1, o3, o2, o1] = drainShort(tr, posLive, notS3, notS2, notS1)
        notS3 := n3
        notS2 := n2
        notS1 := n1
        s3On  := o3
        s2On  := o2
        s1On  := o1
        posLive := math.max(posLive - d, 0.0)

// ????????????????????????????????????????????????????????????????????????????
// 禮11  ?脣嚗?蝛箏?潮??擐憟?regime gate嚗?蝣澆? winners-add-only + vol-brake嚗?//      [BLOCKER-3 靽格迤] 擐??蝣?stage ??敺誑??0 皜? fresh l*On/s*On ?單?????
//      瘣?stage(curLongStage/curShortStage)?斗嚗?撅?bool ??(皜?)敹怎嚗??刻瘣賬?// ????????????????????????????????????????????????????????????????????????????
canEnter = bar_index >= cooldownUntil and not exitedThisBar
curLongStage  = (l1On?1:0) + (l2On?1:0) + (l3On?1:0)
curShortStage = (s1On?1:0) + (s2On?1:0) + (s3On?1:0)
// 擐嚗T1 蝧餃? + regime gate嚗[?菜5] MTF ?Ｙ?瑽??漲嚗歇雿萄 regimeLongOK/ShortOK嚗?l1Cond = curLongStage == 0 and curShortStage == 0 and st1FlipUp and regimeLongOK  and canEnter
s1Cond = curLongStage == 0 and curShortStage == 0 and st1FlipDn and regimeShortOK and canEnter
// ?Ⅳ嚗?畾萄歇瘚桃?(R>0)?隅?Ｗ??T ?亙?蝧餃????芾孛??vol-brake嚗?瘜Ｗ???嚗?addOK  = not volBrakeOn and R > 0
l2Cond = curLongStage == 1 and l1On and inLong  and st2FlipUp and st1Bull and addOK
l3Cond = curLongStage == 2 and l1On and l2On and inLong  and st3FlipUp and st1Bull and st2Bull and addOK
s2Cond = curShortStage == 1 and s1On and inShort and st2FlipDn and st1Bear and addOK
s3Cond = curShortStage == 2 and s1On and s2On and inShort and st3FlipDn and st1Bear and st2Bear and addOK

if l1Cond
    strategy.entry("L1", strategy.long, qty=qty1, comment="L1")
    entryRisk := chandMult * atrChand   // [靽格迤1] ???祕??甇Ｘ?頝??R ??
    entryPx   := close
    trailExt  := high
    trailStop := na
    entryBar  := bar_index
    peakR     := 0.0
    bankedQty := 0.0
    openInitQty := qty1
    fadeArmed := true
    l1On := true
    notL1 := qty1   // 閮?閰脣惜銝?⊥嚗? TP/cut/fade 蝝蝎曄Ⅱ撠董
if l2Cond
    strategy.entry("L2", strategy.long, qty=qty2, comment="L2")
    l2On := true
    notL2 := qty2
    openInitQty := openInitQty + qty2
if l3Cond
    strategy.entry("L3", strategy.long, qty=qty3, comment="L3")
    l3On := true
    notL3 := qty3
    openInitQty := openInitQty + qty3
if s1Cond
    strategy.entry("S1", strategy.short, qty=qty1, comment="S1")
    entryRisk := chandMult * atrChand   // [靽格迤1] ???祕??甇Ｘ?頝??R ??
    entryPx   := close
    trailExt  := low
    trailStop := na
    entryBar  := bar_index
    peakR     := 0.0
    bankedQty := 0.0
    openInitQty := qty1
    fadeArmed := true
    s1On := true
    notS1 := qty1
if s2Cond
    strategy.entry("S2", strategy.short, qty=qty2, comment="S2")
    s2On := true
    notS2 := qty2
    openInitQty := openInitQty + qty2
if s3Cond
    strategy.entry("S3", strategy.short, qty=qty3, comment="S3")
    s3On := true
    notS3 := qty3
    openInitQty := openInitQty + qty3

// nCap ??閮嚗??vol-target ?臬鋡急?獢蹂???頝荔?
if cap1 or cap2 or cap3
    capHits += 1

// [stageLive 撠董] 璉 fresh 瘣?stage嚗?0 皜?+ 禮11 ?Ⅳ敺?蝯?l*On/s*On ?遣嚗? 禮12
//   閬死?? 禮14 stage=opentrades 撠董雿輻嚗??文?璉?????strategy.opentrades 銝??渲炊?晞?stageLive = inLong ? ((l1On?1:0) + (l2On?1:0) + (l3On?1:0)) : inShort ? ((s1On?1:0) + (s2On?1:0) + (s3On?1:0)) : 0

// ????????????????????????????????????????????????????????????????????????????
// 禮12  閬死???典 global scope嚗＊蝷??銝敺 stageLive 璉 fresh嚗?// ????????????????????????????????????????????????????????????????????????????
c1 = st1Bull ? color.new(color.green, 0)  : color.new(color.red, 0)
c2 = st2Bull ? color.new(color.green, 30) : color.new(color.red, 30)
c3 = st3Bull ? color.new(color.green, 55) : color.new(color.red, 55)
plot(showST ? st1 : na, "ST1", color=c1, linewidth=1)
plot(showST ? st2 : na, "ST2", color=c2, linewidth=1)
plot(showST ? st3 : na, "ST3", color=c3, linewidth=2)
plot(showAvg and stageLive >= 1 ? avgPx : na, "AvgCost", color=color.new(color.yellow, 0), linewidth=1, style=plot.style_linebr)
plot(showStop and inPos ? trailStop : na, "TrailStop", color=color.new(color.orange, 0), linewidth=1, style=plot.style_linebr)

// ?嚗egime ?孵?(瘛? + ??畾?頛楛嚗誑 stageLive ??璉?祕撅斗)
bgReg = showBg and regimeOn ? (dirLong ? color.new(color.green, 93) : color.new(color.red, 93)) : na
bgStg = showBg and inPos ? (inLong ? color.new(color.teal, 90 - stageLive * 6) : color.new(color.maroon, 90 - stageLive * 6)) : na
bgcolor(na(bgStg) ? bgReg : bgStg)

plotshape(showSignals and l1Cond, "L1", shape.triangleup,   location.belowbar, color.new(color.lime, 0),   size=size.tiny,   text="L1")
plotshape(showSignals and l2Cond, "L2", shape.triangleup,   location.belowbar, color.new(color.green, 0),  size=size.small,  text="L2")
plotshape(showSignals and l3Cond, "L3", shape.triangleup,   location.belowbar, color.new(color.teal, 0),   size=size.normal, text="L3")
plotshape(showSignals and s1Cond, "S1", shape.triangledown, location.abovebar, color.new(color.orange, 0), size=size.tiny,   text="S1")
plotshape(showSignals and s2Cond, "S2", shape.triangledown, location.abovebar, color.new(color.red, 0),    size=size.small,  text="S2")
plotshape(showSignals and s3Cond, "S3", shape.triangledown, location.abovebar, color.new(color.maroon, 0), size=size.normal, text="S3")
tpAny  = tpHitL1 or tpHitL2 or tpHitS1 or tpHitS2
cutAny = cutL1 or cutL2 or cutS1 or cutS2
fadeAny= regimeFadeLong or regimeFadeShort
plotshape(showSignals and tpAny,  "TP",   shape.circle,   location.abovebar, color.new(color.aqua, 0),   size=size.tiny, text="TP")
plotshape(showSignals and cutAny, "Cut",  shape.diamond,  location.abovebar, color.new(color.purple, 0), size=size.tiny, text="cut")
plotshape(showSignals and fadeAny,"Fade", shape.xcross,   location.belowbar, color.new(color.fuchsia, 0),size=size.tiny, text="fade")
fullExitMark = trailHitLong or trailHitShort or twoSTRevLong or twoSTRevShort or timeStopLong or timeStopShort
plotshape(showSignals and fullExitMark, "OUT", shape.xcross, location.abovebar, color.new(color.red, 0), size=size.tiny, text="X")

// ????????????????????????????????????????????????????????????????????????????
// 禮13  ???銵冽嚗銝? table嚗?漱??隤儔? + ?桐?嚗?14 ??//      ????挾隞?stageLive(璉 fresh) 憿舐內嚗陸?嘶 ?怠?詨嚗迫?脣漲?恍?璇舀挾?賂?
//      ?菜????渡 R/F/T/M/B/S/X/K/D/C嚗?0 摮?撠? 10 ???堆???// ????????????????????????????????????????????????????????????????????????????
regimeTxt = regimeOn ? (dirLong ? "頞典?脣?" : dirShort ? "頞典?潛征" : "頞典") : "?斗/Range"
posTxt    = inLong ? "憭?L" + str.tostring(stageLive) : inShort ? "蝛?S" + str.tostring(stageLive) : "?∪?
stopTxt   = inPos and not na(trailStop) ? str.tostring(trailStop, format.mintick) : "??
distR     = inPos and not na(trailStop) and atrChand > 0 ? math.abs(close - trailStop) / atrChand : na
distTxt   = na(distR) ? "?? : str.tostring(distR, "#.0") + " ATR"
exposureRaw = useVolTarget ? vtScale * totW : totW
exposureEff = math.min(exposureRaw, maxGross)
vtTxt     = useVolTarget ? str.tostring(exposureEff, "#.00") + "x (?格?" + str.tostring(targetVol * 100, "#") + "%)" : "?箏?甈?"
ivTxt     = str.tostring(instVolAnn * 100, "#.0") + "%"
tpTxt     = (tp1Done ? "TP1?? : "TP1繚") + " " + (tp2Done ? "TP2?? : "TP2繚") + (tp1Done and useBEonTP1 ? " ??BE" : "") + (tpStairOn ? " ?? + str.tostring(stairRungs) : "")
voteTxt   = str.tostring(votesLong) + "/" + str.tostring(votesShort) + " ?? + str.tostring(effMinVotes) + (votesUnreachable ? " ?lamp" : "")
// [?菜3+SUPREME-1+NEW-1] peakR + ????+ ?澆? + R ?０?澆?蝺?
peakTxt   = inPos ? str.tostring(peakR, "#.0") + "R" + (peakFloorOn ? " ?? : "") + (peakFloorOn and effBreathGB ? "~" + str.tostring(breathMult, "#.0") : "") + (effBreathRStep and R >= 2 ? " X" + str.tostring(effTightR, "#.0") : "") : "??
// ?菜璅∠?????蝝蝺?憿舐內???箇???嚗=????F=fade T=?芷?S M=MTF B=?澆??
//   S=?０BE X=?澆R?０ K=撌脰鋡???D=fade瘛勗漲 C=??唳
modTxt    = usePureA ? "蝝蝺? : ((effPeakRatchet?"R":"繚") + (effRegimeFade?"F":"繚") + (effAdaptiveTS?"T":"繚") + (effMTFgate?"M":"繚") + (effBreathGB?"B":"繚") + (effTPstair?"S":"繚") + (effBreathRStep?"X":"繚") + (effBankedExempt?"K":"繚") + (effFadeDepth?"D":"繚") + (effCostAwareBE?"C":"繚"))
// [NEW ?? 撌脰鋡???/ fade ?祆??惜??/ ??唳??
tailTxt   = (effBankedExempt and tp1Done ? "鞊?TS" : "??) + (effFadeDepth and lastFadeCut >= 2 ? " ??" : "") + (costFloorActive ? " ??? : "")

var table dash = table.new(position.top_right, 2, 14, border_width=1, frame_color=color.new(color.gray, 40), frame_width=1)
if showTable and barstate.islast
    bgH = color.new(color.blue, 20)
    bgV = color.new(color.black, 25)
    txc = color.white
    table.cell(dash, 0, 0, "撣???, text_color=txc, bgcolor=bgH, text_size=size.small)
    table.cell(dash, 1, 0, regimeTxt + (effMTFgate ? " ?專TF" : ""), text_color=txc, bgcolor=regimeOn ? color.new(color.green, 40) : color.new(color.orange, 40), text_size=size.small)
    table.cell(dash, 0, 1, "????挾", text_color=txc, bgcolor=bgH, text_size=size.small)
    table.cell(dash, 1, 1, posTxt, text_color=txc, bgcolor=inLong ? color.new(color.green, 45) : inShort ? color.new(color.red, 45) : bgV, text_size=size.small)
    table.cell(dash, 0, 2, "????, text_color=txc, bgcolor=bgH, text_size=size.small)
    table.cell(dash, 1, 2, stopTxt, text_color=txc, bgcolor=bgV, text_size=size.small)
    table.cell(dash, 0, 3, "頝???, text_color=txc, bgcolor=bgH, text_size=size.small)
    table.cell(dash, 1, 3, distTxt, text_color=txc, bgcolor=bgV, text_size=size.small)
    table.cell(dash, 0, 4, "瘜Ｗ???", text_color=txc, bgcolor=bgH, text_size=size.small)
    table.cell(dash, 1, 4, vtTxt, text_color=txc, bgcolor=bgV, text_size=size.small)
    table.cell(dash, 0, 5, "撟游?瘜Ｗ?", text_color=txc, bgcolor=bgH, text_size=size.small)
    table.cell(dash, 1, 5, ivTxt + (volBrakeOn ? " ??頠? : ""), text_color=txc, bgcolor=volBrakeOn ? color.new(color.red, 40) : bgV, text_size=size.small)
    table.cell(dash, 0, 6, "?桀? R", text_color=txc, bgcolor=bgH, text_size=size.small)
    table.cell(dash, 1, 6, inPos ? str.tostring(R, "#.0") + "R" : "??, text_color=txc, bgcolor=inPos and R >= 0 ? color.new(color.green, 50) : inPos ? color.new(color.red, 50) : bgV, text_size=size.small)
    table.cell(dash, 0, 7, "撜啣嘶/????, text_color=txc, bgcolor=bgH, text_size=size.small)
    table.cell(dash, 1, 7, peakTxt, text_color=txc, bgcolor=peakFloorOn ? color.new(color.green, 35) : bgV, text_size=size.small)
    table.cell(dash, 0, 8, "甇Ｙ??脣漲", text_color=txc, bgcolor=bgH, text_size=size.small)
    table.cell(dash, 1, 8, inPos ? tpTxt : "??, text_color=txc, bgcolor=bgV, text_size=size.small)
    table.cell(dash, 0, 9, "?巨L/S", text_color=txc, bgcolor=bgH, text_size=size.small)
    table.cell(dash, 1, 9, voteTxt, text_color=txc, bgcolor=votesUnreachable ? color.new(color.orange, 30) : bgV, text_size=size.small)
    table.cell(dash, 0, 10, "撠暸憸冽", text_color=txc, bgcolor=bgH, text_size=size.small)
    table.cell(dash, 1, 10, inPos ? tailTxt : "??, text_color=txc, bgcolor=(effBankedExempt and tp1Done) or costFloorActive ? color.new(color.teal, 40) : bgV, text_size=size.small)
    table.cell(dash, 0, 11, "?菜 R/F/T/M/B/S/X/K/D/C", text_color=txc, bgcolor=bgH, text_size=size.small)
    table.cell(dash, 1, 11, modTxt, text_color=txc, bgcolor=usePureA ? color.new(color.gray, 20) : color.new(color.purple, 45), text_size=size.small)
    bankedPctH = openInitQty > 1e-9 ? bankedQty / openInitQty * 100.0 : 0.0
    claimedPctH= (tp1Done ? tp1Pct : 0.0) + (tp2Done ? tp2Pct : 0.0)
    table.cell(dash, 0, 12, "?質?%/摰?迂%", text_color=txc, bgcolor=bgH, text_size=size.small)
    table.cell(dash, 1, 12, inPos ? str.tostring(bankedPctH, "#.0") + "/" + str.tostring(claimedPctH, "#.0") : "??, text_color=txc, bgcolor=bgV, text_size=size.small)
    chkH = stageLive == strategy.opentrades
    table.cell(dash, 0, 13, "撅斗撠董", text_color=txc, bgcolor=bgH, text_size=size.small)
    table.cell(dash, 1, 13, str.tostring(stageLive) + "=" + str.tostring(strategy.opentrades), text_color=txc, bgcolor=chkH ? bgV : color.new(color.red, 0), text_size=size.small)

// ????????????????????????????????????????????????????????????????????????????
// 禮14  ?日甈?撌亦??剁?votes / stageLive=opentrades 蝝?撠董 / floor / cap / TP ??/ 靽∪艙 /
//      peakR / ?質?% / ?澆?? / ?澆R?０ / fade?惜 / ??唳 / effTS / persist嚗?//      stage=opentrades 撠董?寧 stageLive(璉 fresh)嚗??璉??? stale stage 隤文?游董??// ????????????????????????????????????????????????????????????????????????????
bankedPct  = openInitQty > 1e-9 ? bankedQty / openInitQty * 100.0 : 0.0
claimedPct = (tp1Done ? tp1Pct : 0.0) + (tp2Done ? tp2Pct : 0.0)
var table dbg = table.new(position.bottom_right, 2, 13, border_width=1)
if showDebug and barstate.islast
    db = color.new(color.gray, 0)
    table.cell(dbg, 0, 0, "ER", text_color=color.white, bgcolor=db)
    table.cell(dbg, 1, 0, str.tostring(er, "#.00"), text_color=color.white, bgcolor=db)
    table.cell(dbg, 0, 1, "ADX", text_color=color.white, bgcolor=db)
    table.cell(dbg, 1, 1, str.tostring(adx, "#.0"), text_color=color.white, bgcolor=db)
    table.cell(dbg, 0, 2, "votesL/S(eff)", text_color=color.white, bgcolor=db)
    table.cell(dbg, 1, 2, str.tostring(votesLong) + "/" + str.tostring(votesShort) + " (?? + str.tostring(effMinVotes) + ")", text_color=color.white, bgcolor=db)
    table.cell(dbg, 0, 3, "stageLive=opentr", text_color=color.white, bgcolor=db)
    chk = stageLive == strategy.opentrades
    table.cell(dbg, 1, 3, str.tostring(stageLive) + "=" + str.tostring(strategy.opentrades), text_color=color.white, bgcolor=chk ? db : color.new(color.red, 0))
    table.cell(dbg, 0, 4, "?質?%/摰?迂%", text_color=color.white, bgcolor=db)
    table.cell(dbg, 1, 4, str.tostring(bankedPct, "#.0") + "/" + str.tostring(claimedPct, "#.0"), text_color=color.white, bgcolor=db)
    table.cell(dbg, 0, 5, "capHits/floor", text_color=color.white, bgcolor=db)
    table.cell(dbg, 1, 5, str.tostring(capHits) + "/" + str.tostring(floorHits), text_color=color.white, bgcolor=db)
    table.cell(dbg, 0, 6, "TP1/2 done", text_color=color.white, bgcolor=db)
    table.cell(dbg, 1, 6, (tp1Done?"T":"F") + "/" + (tp2Done?"T":"F"), text_color=color.white, bgcolor=db)
    table.cell(dbg, 0, 7, "convMult", text_color=color.white, bgcolor=db)
    table.cell(dbg, 1, 7, str.tostring(convMult, "#.00"), text_color=color.white, bgcolor=db)
    table.cell(dbg, 0, 8, "peakR/effGB", text_color=color.white, bgcolor=db)
    table.cell(dbg, 1, 8, str.tostring(peakR, "#.0") + "/" + str.tostring(effGiveback, "#.00"), text_color=color.white, bgcolor=db)
    table.cell(dbg, 0, 9, "breath/stair", text_color=color.white, bgcolor=db)
    table.cell(dbg, 1, 9, str.tostring(breathMult, "#.00") + "/" + str.tostring(stairRungs), text_color=color.white, bgcolor=db)
    table.cell(dbg, 0, 10, "effTightR/fadeCut", text_color=color.white, bgcolor=db)
    table.cell(dbg, 1, 10, str.tostring(effTightR, "#.0") + "/" + str.tostring(lastFadeCut), text_color=color.white, bgcolor=db)
    table.cell(dbg, 0, 11, "frFloor/beStep", text_color=color.white, bgcolor=db)
    table.cell(dbg, 1, 11, str.tostring(frictionFloorPx, format.mintick) + "/" + str.tostring(beStepUp, format.mintick), text_color=color.white, bgcolor=costFloorActive ? color.new(color.teal, 0) : db)
    table.cell(dbg, 0, 12, "effTS/persist", text_color=color.white, bgcolor=db)
    table.cell(dbg, 1, 12, str.tostring(effTimeStop) + "/" + str.tostring(persistBars), text_color=color.white, bgcolor=db)
