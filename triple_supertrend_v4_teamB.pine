entryGateTxt = (effEntryDistGate ? "?孵榆?????? + str.tostring(kBuf, "#.0") + "ATR)" : "?孵榆????) + " ??" + (effMidConfirm ? "銝剖偕摨衣Ⅱ隤???ST2??)" : "銝剖偕摨衣Ⅱ隤???) + " ??" + (effDiSlopeGate ? "DI?:???? + str.tostring(h1BlockedEntries) + ")" : "DI?:??) + " ??" + (effFlipFresh ? "蝧餉??圈悅:???? + str.tostring(flipFreshWin) + "璉瑟?" + str.tostring(i1BlockedEntries) + ")" : "蝧餉??圈悅:??)
