// ????????????????????????????????????????????????????????????????????????????
// 禮4  瘜Ｗ??摯閮???VT-Core ??
// ????????????????????????????????????????????????????????????????????????????
logRet      = math.log(close / close[1])
stdevDaily  = ta.stdev(logRet, volLen)
volAnnATR   = atrPct       * math.sqrt(barsPerYear)
volAnnStd   = stdevDaily   * math.sqrt(barsPerYear)
instVolAnn  = volEstMode == "Stdev" ? volAnnStd : volAnnATR
volFloor    = ta.percentile_linear_interpolation(instVolAnn, brakeLen, 5)
volFloor   := na(volFloor) ? 0.02 : math.max(volFloor, 0.001)
instVolAnn := math.max(nz(instVolAnn, volFloor), volFloor)
volMedian   = ta.median(instVolAnn, brakeLen)
volMedian  := na(volMedian) ? instVolAnn : math.max(volMedian, volFloor)
relVol      = instVolAnn / volMedian
volBrakeOn  = useVolBrake and relVol > brakeK
breathClamp = math.min(math.max(relVol, 1.0), brakeK)
atrPctRank  = ta.percentrank(atrPct, brakeLen)        // 0~100
breathPctl  = pctlLo + nz(atrPctRank, 50.0) / 100.0 * (pctlHi - pctlLo)
var int floorHits = 0
if instVolAnn <= volFloor + 1e-12
    floorHits += 1

// ????????????????????????????????????????????????????????????????????????????
// 禮5  Regime ??嚗R / ADX ?脫趙 / ST3 ?Ｘ??嚗? ?巨?券??脤?甇?// ????????????????????????????????????????????????????????????????????????????
erChange = math.abs(close - close[erLen])
erVolSum = math.sum(math.abs(close - close[1]), erLen)
er       = erVolSum > 0 ? erChange / erVolSum : 0.0
er      := nz(er, 0.0)
erSlope  = er - nz(er[1], er)
erAccel2 = erSlope - nz(erSlope[1], erSlope)

[diPlus, diMinus, adx] = ta.dmi(adxLen, adxLen)
var bool adxOn_state = false
if adx > adxOn
    adxOn_state := true
else if adx < adxOff
    adxOn_state := false

slowBull = st3Bull
slowBear = st3Bear

voteER_long   = useER     and er > erThr
voteADX_long  = useADX    and adxOn_state
voteSlow_long = useSlowST and slowBull
voteER_short  = useER     and er > erThr
voteADX_short = useADX    and adxOn_state
voteSlow_short= useSlowST and slowBear
votesLong  = (voteER_long?1:0)  + (voteADX_long?1:0)  + (voteSlow_long?1:0)
votesShort = (voteER_short?1:0) + (voteADX_short?1:0) + (voteSlow_short?1:0)
enabledVotes = (useER?1:0) + (useADX?1:0) + (useSlowST?1:0)
lowVolRegime = effAdaptiveMinVotes and not na(atrPctRank) and atrPctRank < lowVolPctile
minVotesEff  = minVotes + (lowVolRegime ? extraVoteLowVol : 0)
effMinVotes  = math.min(minVotesEff, enabledVotes)
votesUnreachable = minVotesEff > enabledVotes
dirLong  = diPlus  > diMinus
dirShort = diMinus > diPlus
diLongOK  = not useDIgate or dirLong
diShortOK = not useDIgate or dirShort

voteLongPass  = enabledVotes == 0 ? true : votesLong  >= effMinVotes
voteShortPass = enabledVotes == 0 ? true : votesShort >= effMinVotes
regimeLongOK  = not useRegime or (voteLongPass  and diLongOK  and mtfBullOK)
regimeShortOK = not useRegime or (voteShortPass and diShortOK and mtfBearOK)
regimeOn = (voteLongPass and dirLong) or (voteShortPass and dirShort)

// ????????????????????????????????????????????????????????????????????????????
// 禮6  ???嚗?擐?stage嚗?0 敺??fresh 瘣?stage嚗?// ????????????????????????????????????????????????????????????????????????????
var bool  l1On = false
var bool  l2On = false
var bool  l3On = false
var bool  s1On = false
var bool  s2On = false
var bool  s3On = false
var int   entryBar  = na
var float entryPx   = na
var float entryRisk = na
var float trailExt  = na
var float trailStop = na
var float cooldownUntil = 0.0
var bool  tp1Done = false
var bool  tp2Done = false
var float peakR = 0.0
var int   peakBar = 0
var float bankedQty = 0.0
var float openInitQty = 0.0
var bool  fadeArmed     = true
var int   lastFadeBar   = -100000
var int   lastAddBar    = -100000
var bool  voteFadeArmed   = true
var int   lastVoteFadeBar = -100000
var bool  dvArmed         = true
var int   lastDvBar       = -100000
// [????NEW-I2] 頝典偕摨行???Ｗ??憸券銝甈⊥扯風甈?+ ?撠??????脫趙嚗??regime-fade嚗?var bool  cohDeRiskArmed  = true
var int   lastCohDeRiskBar= -100000
var float notL1 = 0.0
var float notL2 = 0.0
var float notL3 = 0.0
var float notS1 = 0.0
var float notS2 = 0.0
var float notS3 = 0.0

inLong  = strategy.position_size > 0
inShort = strategy.position_size < 0
inPos   = strategy.position_size != 0
posSize = math.abs(strategy.position_size)
avgPx   = strategy.position_avg_price

if not inPos
    l1On := false
    l2On := false
    l3On := false
    s1On := false
    s2On := false
    s3On := false
    entryRisk := na
    entryPx   := na
    entryBar  := na
    trailExt  := na
    trailStop := na
    tp1Done   := false
    tp2Done   := false
    peakR     := 0.0
    peakBar   := bar_index
    bankedQty := 0.0
    openInitQty := 0.0
    fadeArmed := true
    voteFadeArmed := true
    lastVoteFadeBar := -100000
    dvArmed := true
    lastDvBar := -100000
    cohDeRiskArmed := true     // [I2] 頝典偕摨行???Ｚ風甈?蝵?    lastCohDeRiskBar := -100000  // [I2] ??閮??其?雿菟?蝵殷?雿踹?璇?蝵株楝敺? I2 閮??券＊撘?蝡?    lastAddBar := -100000
    notL1 := 0.0
    notL2 := 0.0
    notL3 := 0.0
    notS1 := 0.0
    notS2 := 0.0
    notS3 := 0.0

longStage  = (l1On?1:0) + (l2On?1:0) + (l3On?1:0)
shortStage = (s1On?1:0) + (s2On?1:0) + (s3On?1:0)
stage = inLong ? longStage : inShort ? shortStage : 0

// ????????????????????????????????????????????????????????????????????????????
// 禮7  ??閮?嚗T-Core嚗?// ????????????????????????????????????????????????????????????????????????????
var float avgEq = na
avgEq := na(avgEq) ? strategy.equity : avgEq * eqBlendSmooth + strategy.equity * (1.0 - eqBlendSmooth)
sizeBase = eqBlendInit * strategy.initial_capital + (1.0 - eqBlendInit) * avgEq

vtScale = useVolTarget ? targetVol / instVolAnn : 1.0
convMult = useConvAdd and erThr > 0 ? math.min(math.max(er / erThr, 0.5), 1.0) : 1.0
wL2eff = wL2 * convMult
wL3eff = wL3 * convMult
totW    = wL1 + wL2 + wL3
var int capHits = 0

qtyFor(w) =>
    float notion = vtScale * sizeBase * w
    float nCap = totW > 0 ? sizeBase * maxGross * (w / totW) : sizeBase * maxGross
    bool  capped = notion > nCap
    notion := math.min(notion, nCap)
    float q = close > 0 ? notion / close : 0.0
    q := math.max(nz(q, 0.0), 0.0)
    [q, capped]

[qty1, cap1] = qtyFor(wL1)
[qty2, cap2] = qtyFor(wL2eff)
[qty3, cap3] = qtyFor(wL3eff)

// ????????????????????????????????????????????????????????????????????????????
// 禮8  R-multiple ??Chandelier ratchet ??
// ????????????????????????????????????????????????????????????????????????????
rDenom  = na(entryRisk) ? (chandMult * atrChand) : entryRisk
rBasePx = na(entryPx)   ? avgPx : entryPx
R = inPos and rDenom > 0 ? (inLong ? (close - rBasePx) / rDenom : (rBasePx - close) / rDenom) : 0.0
if inPos
    if R > peakR
        peakR   := R
        peakBar := bar_index
barsSincePeak = inPos ? math.max(bar_index - peakBar, 0) : 0

multStepBase = not useRStep ? chandMult : (R < 1 ? chandMult : R < 2 ? trailMidR : trailTightR)
multStep = multStepBase
trailBreath = effDecorrGauge ? breathPctl : breathClamp
if effBreathTrail and useRStep and inPos and R >= 1
    float bt = multStepBase * trailBreath
    multStep := math.min(math.max(bt, trailTightR), chandMult)
if effCoherenceTrail and useRStep and inPos and R >= 1
    int coh = inLong ? coherenceLong : coherenceShort
    if coh >= 3
        multStep := math.min(multStep * cohRelaxK, chandMult)
    else if coh <= 1
        multStep := math.min(multStep, trailTightR)
// [???EW-H2] 瘜Ｗ??游撐銵??嗥??詨? trail嚗trPctRank ??fadeCoolBars 璉??仿?????蝯??游???嚗?//   ?蜓 trail ?嗅 trailTightR(??math.min ?蝺???? trail ?嗥???drain????stageLive????close??//   ??摰?嚗trPctRank[fadeCoolBars] na 蝬?nz ????撌?0 銝炊閫???volShockNow = nz(atrPctRank, 50.0) - nz(atrPctRank[fadeCoolBars], nz(atrPctRank, 50.0))
volShockOn  = effVolShockTrail and useRStep and inPos and R >= 1 and volShockNow >= volShockJumpFrac * 100.0
var int volShockHits = 0
if volShockOn
    multStep := math.min(multStep, trailTightR)
    volShockHits += 1

beActive = (useBE and R >= kBE) or (useBEonTP1 and tp1Done)

breathMult = effBreathGB ? breathClamp : 1.0
stallFrac   = barsSincePeak * 1.0 / math.max(timeStopBars, 1)
stallShrink = effStallRatchet and timeStopBars > 0 ? math.min(math.max(1.0 - stallFrac, stallShrinkMin), 1.0) : 1.0
effGiveback= multBE * breathMult * stallShrink
peakFloorOn= effPeakRatchet and inPos and peakR > effGiveback

stairRungs   = (tp1Done ? 1 : 0) + (tp2Done ? 1 : 0)
tpStairOn    = effTPstair and inPos and stairRungs > 0
tpStairFloorL= rBasePx + stairRungs * multBE * rDenom
tpStairFloorS= rBasePx - stairRungs * multBE * rDenom

bankFrac      = openInitQty > 1e-9 ? math.min(bankedQty / openInitQty, 1.0) : 0.0
bankedFloorOn = effBankedFloor and inPos and bankFrac > 1e-9
bankedFloorL  = rBasePx + bankFrac * rDenom
bankedFloorS  = rBasePx - bankFrac * rDenom

st3Band   = na(st3) ? 0.0 : math.abs(close - st3)
atrScaleX = effMultiScaleStop and beActive ? math.max(atrChand, st3Band) : atrChand

if useChandelier and inLong
    trailExt  := na(trailExt) ? high : math.max(trailExt, high)
    rawStop    = trailExt - multStep * atrScaleX
    trailStop := na(trailStop) ? rawStop : math.max(trailStop, rawStop)
    if beActive
        trailStop := math.max(trailStop, rBasePx + multBE * rDenom)
    if tpStairOn
        trailStop := math.max(trailStop, tpStairFloorL)
    if bankedFloorOn
        trailStop := math.max(trailStop, bankedFloorL)
    if peakFloorOn
        trailStop := math.max(trailStop, rBasePx + (peakR - effGiveback) * rDenom)
else if useChandelier and inShort
    trailExt  := na(trailExt) ? low : math.min(trailExt, low)
    rawStop    = trailExt + multStep * atrScaleX
    trailStop := na(trailStop) ? rawStop : math.min(trailStop, rawStop)
    if beActive
        trailStop := math.min(trailStop, rBasePx - multBE * rDenom)
    if tpStairOn
        trailStop := math.min(trailStop, tpStairFloorS)
    if bankedFloorOn
        trailStop := math.min(trailStop, bankedFloorS)
    if peakFloorOn
        trailStop := math.min(trailStop, rBasePx - (peakR - effGiveback) * rDenom)

// ????????????????????????????????????????????????????????????????????????????
// 禮9  ?箏閫貊
// ????????????????????????????????????????????????????????????????????????????
trailHitLong  = useChandelier and inLong  and not na(trailStop) and close < trailStop
trailHitShort = useChandelier and inShort and not na(trailStop) and close > trailStop
twoSTRevLong  = inLong  and st1Bear and st2Bear
twoSTRevShort = inShort and st1Bull and st2Bull
tsScale     = effAdaptiveTS and erThr > 0 ? math.min(math.max(er / erThr, 0.5), 1.0) : 1.0
effTimeStop = math.max(math.round(timeStopBars * tsScale), 1)
tsAge         = na(entryBar) ? 0 : (bar_index - entryBar)
timeStopLong  = useTimeStop and inLong  and not na(entryBar) and tsAge >= effTimeStop and R < 1 and stage < 3
timeStopShort = useTimeStop and inShort and not na(entryBar) and tsAge >= effTimeStop and R < 1 and stage < 3

// ????????????????????????????????????????????????????????????????????????????
// 禮10  銝?瑁?嚗??箏敺脣
// ????????????????????????????????????????????????????????????????????????????
var bool exitedThisBar = false
exitedThisBar := false

var float posLive = 0.0
posLive := posSize

bool fullExitNow = false

liveStopLong  = useHardStop and inLong  and not na(trailStop[1])
liveStopShort = useHardStop and inShort and not na(trailStop[1])
if useHardStop and inLong and not na(trailStop)
    strategy.exit("hX-L", stop=trailStop, comment="HardStopL")
if useHardStop and inShort and not na(trailStop)
    strategy.exit("hX-S", stop=trailStop, comment="HardStopS")
bool brokerStopHit = (liveStopLong and low <= trailStop[1]) or (liveStopShort and high >= trailStop[1])
bool blockPartials = brokerStopHit
// [?游董繚????芣晾靽桀儔] broker intrabar ?典?鈭文?嚗?砍惜敹???trail/2ST/time ?典像頝臬???蝔晞
//   摰?蔭 stage ???+ 撖怠?颯???brokerStopHit ?芾身 exitedThisBar/blockPartials 撠梁???
//   撠閰脫? broker ?其????trategy.opentrades=0 雿?l1On..s3On 隞?????stageLive>=1嚗憯?//   禮14 chk=stageLive==strategy.opentrades ??撘?銝迨????箏(頝喟征蝛踹?????0 ?瑕嚗???//   cooldown 閮剛??◎?耨瘜?隞?brokerStopHit 雿萄 fullExitNow 頝臬??身 fullExitNow:=true 韏唬???//   ??fullExitNow 摰?詨????湧?蝵?+ 撖?cooldownUntil????閰脣??臭??潔遙雿?close_all嚗roker 撌?//   ?漱?典像嚗?鋆?砍惜撣喳?撠迂嚗??銝)嚗?????exitedThisBar:=true 雿?trail/2ST/time ?憛?//   鋡?not exitedThisBar ?剛楝(銝?銴?close_all)?lockPartials ?璉???甇支?璇??渲楝敺?//   (trail/2ST/time/brokerStop/cut-to-flat)撠????蔭 + ?瑕???典?蝔晞?if brokerStopHit
    exitedThisBar := true
    fullExitNow := true

if not exitedThisBar and trailHitLong
    strategy.close_all(comment="TrailL")
    fullExitNow := true
else if not exitedThisBar and trailHitShort
    strategy.close_all(comment="TrailS")
    fullExitNow := true

if not exitedThisBar and not fullExitNow and twoSTRevLong
    strategy.close_all(comment="2STrevL")
    fullExitNow := true
else if not exitedThisBar and not fullExitNow and twoSTRevShort
    strategy.close_all(comment="2STrevS")
    fullExitNow := true

if not exitedThisBar and not fullExitNow and (timeStopLong or timeStopShort)
    strategy.close_all(comment="TimeStop")
    fullExitNow := true

if fullExitNow
    l1On := false
    l2On := false
    l3On := false
    s1On := false
    s2On := false
    s3On := false
    entryRisk := na
    entryPx   := na
    entryBar  := na
    trailExt  := na
    trailStop := na
    tp1Done   := false
    tp2Done   := false
    peakR     := 0.0
    peakBar   := bar_index
    bankedQty := 0.0
    openInitQty := 0.0
    fadeArmed := true
    lastAddBar := -100000      // [?梯?靽格迤繚P3 撠迂? 憿臬??蔭 E3 閮??剁?雿?fullExit ??cut-to-flat 撠迂
    voteFadeArmed := true
    lastVoteFadeBar := -100000
    dvArmed := true
    lastDvBar := -100000
    cohDeRiskArmed := true     // [I2] 頝典偕摨行???Ｚ風甈?蝵?    lastCohDeRiskBar := -100000  // [I2] ??閮??其?雿菟?蝵?    notL1 := 0.0
    notL2 := 0.0
    notL3 := 0.0
    notS1 := 0.0
    notS2 := 0.0
    notS3 := 0.0
    exitedThisBar := true
    float effCooldown = effAdaptiveCooldown ? math.max(math.round(cooldownBars * breathClamp), 0) : cooldownBars
    cooldownUntil := bar_index + effCooldown
    posLive := 0.0

// ?? contiguous-stack ?臭?皜?隤?蝝撘?top-first drain + global-scope 閫???神嚗??
drainLong(reqQty, posAbs, n3, n2, n1) =>
    float want = math.min(math.max(nz(reqQty, 0.0), 0.0), posAbs)
    float done = 0.0
    float r3 = n3
    float r2 = n2
    float r1 = n1
    if r3 > 1e-9 and want - done > 1e-9
        float take = math.min(want - done, r3)
        if take > 1e-9
            strategy.close("L3", qty=take, comment="cut-L3")
            r3   := r3 - take
            done := done + take
    if r2 > 1e-9 and want - done > 1e-9
        float take = math.min(want - done, r2)
        if take > 1e-9
            strategy.close("L2", qty=take, comment="cut-L2")
            r2   := r2 - take
            done := done + take
    if r1 > 1e-9 and want - done > 1e-9
        float take = math.min(want - done, r1)
        if take > 1e-9
            strategy.close("L1", qty=take, comment="cut-L1")
            r1   := r1 - take
            done := done + take
    [done, r3, r2, r1, r3 > 1e-9, r2 > 1e-9, r1 > 1e-9]
drainShort(reqQty, posAbs, n3, n2, n1) =>
    float want = math.min(math.max(nz(reqQty, 0.0), 0.0), posAbs)
    float done = 0.0
    float r3 = n3
    float r2 = n2
    float r1 = n1
    if r3 > 1e-9 and want - done > 1e-9
        float take = math.min(want - done, r3)
        if take > 1e-9
            strategy.close("S3", qty=take, comment="cut-S3")
            r3   := r3 - take
            done := done + take
    if r2 > 1e-9 and want - done > 1e-9
        float take = math.min(want - done, r2)
        if take > 1e-9
            strategy.close("S2", qty=take, comment="cut-S2")
            r2   := r2 - take
            done := done + take
    if r1 > 1e-9 and want - done > 1e-9
        float take = math.min(want - done, r1)
        if take > 1e-9
            strategy.close("S1", qty=take, comment="cut-S1")
            r1   := r1 - take
            done := done + take
    [done, r3, r2, r1, r3 > 1e-9, r2 > 1e-9, r1 > 1e-9]

trancheTopLong(on3, on2, on1, n3, n2, n1) =>
    on3 ? n3 : on2 ? n2 : on1 ? n1 : 0.0
trancheTopShort(on3, on2, on1, n3, n2, n1) =>
    on3 ? n3 : on2 ? n2 : on1 ? n1 : 0.0

// ?? ?挾 R-multiple Partial TP ??
tpHitL1 = usePartialTP and not exitedThisBar and not blockPartials and inLong  and R >= tp1R and not tp1Done
tpHitL2 = usePartialTP and not exitedThisBar and not blockPartials and inLong  and R >= tp2R and not tp2Done
tpHitS1 = usePartialTP and not exitedThisBar and not blockPartials and inShort and R >= tp1R and not tp1Done
tpHitS2 = usePartialTP and not exitedThisBar and not blockPartials and inShort and R >= tp2R and not tp2Done
if tpHitL1
    [d, n3, n2, n1, o3, o2, o1] = drainLong(posLive * tp1Pct / 100.0, posLive, notL3, notL2, notL1)
    notL3 := n3
    notL2 := n2
    notL1 := n1
    l3On  := o3
    l2On  := o2
    l1On  := o1
    bankedQty := bankedQty + d
    posLive   := math.max(posLive - d, 0.0)
    tp1Done := true
if tpHitL2
    [d, n3, n2, n1, o3, o2, o1] = drainLong(posLive * tp2Pct / 100.0, posLive, notL3, notL2, notL1)
    notL3 := n3
    notL2 := n2
    notL1 := n1
    l3On  := o3
    l2On  := o2
    l1On  := o1
    bankedQty := bankedQty + d
    posLive   := math.max(posLive - d, 0.0)
    tp2Done := true
if tpHitS1
    [d, n3, n2, n1, o3, o2, o1] = drainShort(posLive * tp1Pct / 100.0, posLive, notS3, notS2, notS1)
    notS3 := n3
    notS2 := n2
    notS1 := n1
    s3On  := o3
    s2On  := o2
    s1On  := o1
    bankedQty := bankedQty + d
    posLive   := math.max(posLive - d, 0.0)
    tp1Done := true
if tpHitS2
    [d, n3, n2, n1, o3, o2, o1] = drainShort(posLive * tp2Pct / 100.0, posLive, notS3, notS2, notS1)
    notS3 := n3
    notS2 := n2
    notS1 := n1
    s3On  := o3
    s2On  := o2
    s1On  := o1
    bankedQty := bankedQty + d
    posLive   := math.max(posLive - d, 0.0)
    tp2Done := true

// ???箏 D嚗T ???挾皜?cut嚗??top-first嚗?// [P6a繚?孵??嗥?] cutL1/cutS1 鋆?fresh 瘣?stage>=2 霅瑟?(瘥 cutL2/cutS2)嚗? (l1On or l2On or l3On)
//   ??撅斗敹?stage==1)???銝?詨?撅斗撅文???0嚗 cut-to-flat ?游董頝臬?閫貊皞閬??喳?
//   銝?Ⅳ撅文??瘣?stage>=2)嚗蝙 ST1 ???典撅文?銝??詨? L1(?寧 禮9 trail/2STrev ?典像??)??撌脰?
//   銝 cut-to-flat ?? + 擐 not inPos ???脰風嚗??撘瑕漲??璈銝撘瑕漲(??A 頝舐?)??cutFreshStageLong  = (l1On?1:0) + (l2On?1:0) + (l3On?1:0)
cutFreshStageShort = (s1On?1:0) + (s2On?1:0) + (s3On?1:0)
cutL1 = usePartialST and not exitedThisBar and not blockPartials and inLong  and st1FlipDn and cutFreshStageLong  >= 2
cutL2 = usePartialST and not exitedThisBar and not blockPartials and inLong  and st2FlipDn and (l2On or l3On)
cutS1 = usePartialST and not exitedThisBar and not blockPartials and inShort and st1FlipUp and cutFreshStageShort >= 2
cutS2 = usePartialST and not exitedThisBar and not blockPartials and inShort and st2FlipUp and (s2On or s3On)
if cutL1
    float tr = trancheTopLong(l3On, l2On, l1On, notL3, notL2, notL1)
    if tr > 1e-9
        [d, n3, n2, n1, o3, o2, o1] = drainLong(tr, posLive, notL3, notL2, notL1)
        notL3 := n3
        notL2 := n2
        notL1 := n1
        l3On  := o3
        l2On  := o2
        l1On  := o1
        posLive := math.max(posLive - d, 0.0)
if cutL2
    float tr = trancheTopLong(l3On, l2On, l1On, notL3, notL2, notL1)
    if tr > 1e-9
        [d, n3, n2, n1, o3, o2, o1] = drainLong(tr, posLive, notL3, notL2, notL1)
        notL3 := n3
        notL2 := n2
        notL1 := n1
        l3On  := o3
        l2On  := o2
        l1On  := o1
        posLive := math.max(posLive - d, 0.0)
if cutS1
    float tr = trancheTopShort(s3On, s2On, s1On, notS3, notS2, notS1)
    if tr > 1e-9
        [d, n3, n2, n1, o3, o2, o1] = drainShort(tr, posLive, notS3, notS2, notS1)
        notS3 := n3
        notS2 := n2
        notS1 := n1
        s3On  := o3
        s2On  := o2
        s1On  := o1
        posLive := math.max(posLive - d, 0.0)
if cutS2
    float tr = trancheTopShort(s3On, s2On, s1On, notS3, notS2, notS1)
    if tr > 1e-9
        [d, n3, n2, n1, o3, o2, o1] = drainShort(tr, posLive, notS3, notS2, notS1)
        notS3 := n3
        notS2 := n2
        notS1 := n1
        s3On  := o3
        s2On  := o2
        s1On  := o1
        posLive := math.max(posLive - d, 0.0)

// ???箏 E嚗egime-fade ?詨??駁◢????if not inPos or er >= erThr
    fadeArmed := true
fadeTrig    = effRegimeFade and not exitedThisBar and not blockPartials and erThr > 0 and er < erThr * fadeK
fadeReady   = fadeArmed and (bar_index - lastFadeBar) >= fadeCoolBars
fadeStageLong  = (l1On?1:0) + (l2On?1:0) + (l3On?1:0)
fadeStageShort = (s1On?1:0) + (s2On?1:0) + (s3On?1:0)
regimeFadeLong  = fadeTrig and inLong  and fadeStageLong  >= 2 and fadeReady
regimeFadeShort = fadeTrig and inShort and fadeStageShort >= 2 and fadeReady
if regimeFadeLong
    float tr = trancheTopLong(l3On, l2On, l1On, notL3, notL2, notL1)
    if tr > 1e-9
        [d, n3, n2, n1, o3, o2, o1] = drainLong(tr, posLive, notL3, notL2, notL1)
        notL3 := n3
        notL2 := n2
        notL1 := n1
        l3On  := o3
        l2On  := o2
        l1On  := o1
        posLive := math.max(posLive - d, 0.0)
    fadeArmed   := false
    lastFadeBar := bar_index
if regimeFadeShort
    float tr = trancheTopShort(s3On, s2On, s1On, notS3, notS2, notS1)
    if tr > 1e-9
        [d, n3, n2, n1, o3, o2, o1] = drainShort(tr, posLive, notS3, notS2, notS1)
        notS3 := n3
        notS2 := n2
        notS1 := n1
        s3On  := o3
        s2On  := o2
        s1On  := o1
        posLive := math.max(posLive - d, 0.0)
    fadeArmed   := false
    lastFadeBar := bar_index

// ???箏 E2嚗??EW-F2 ?梯?蟡冽銵圈?駁◢????votesDirLong  = votesLong
votesDirShort = votesShort
if not inPos or enabledVotes == 0 or (inLong and votesDirLong >= effMinVotes) or (inShort and votesDirShort >= effMinVotes)
    voteFadeArmed := true
voteFadeReady   = voteFadeArmed and (bar_index - lastVoteFadeBar) >= fadeCoolBars
vfStageLong  = (l1On?1:0) + (l2On?1:0) + (l3On?1:0)
vfStageShort = (s1On?1:0) + (s2On?1:0) + (s3On?1:0)
voteFadeTrigLong  = effVoteFade and not exitedThisBar and not blockPartials and enabledVotes > 0 and inLong  and votesDirLong  < effMinVotes and vfStageLong  >= 2 and voteFadeReady
voteFadeTrigShort = effVoteFade and not exitedThisBar and not blockPartials and enabledVotes > 0 and inShort and votesDirShort < effMinVotes and vfStageShort >= 2 and voteFadeReady
var int voteFadeCuts = 0
if voteFadeTrigLong
    float tr = trancheTopLong(l3On, l2On, l1On, notL3, notL2, notL1)
    if tr > 1e-9
        [d, n3, n2, n1, o3, o2, o1] = drainLong(tr, posLive, notL3, notL2, notL1)
        notL3 := n3
        notL2 := n2
        notL1 := n1
        l3On  := o3
        l2On  := o2
        l1On  := o1
        posLive := math.max(posLive - d, 0.0)
        voteFadeCuts += 1
    voteFadeArmed   := false
    lastVoteFadeBar := bar_index
if voteFadeTrigShort
    float tr = trancheTopShort(s3On, s2On, s1On, notS3, notS2, notS1)
    if tr > 1e-9
        [d, n3, n2, n1, o3, o2, o1] = drainShort(tr, posLive, notS3, notS2, notS1)
        notS3 := n3
        notS2 := n2
        notS1 := n1
        s3On  := o3
        s2On  := o2
        s1On  := o1
        posLive := math.max(posLive - d, 0.0)
        voteFadeCuts += 1
    voteFadeArmed   := false
    lastVoteFadeBar := bar_index

// ???箏 E3嚗???NEW-G2 撜啣澆????箏??drawdown-velocity嚗?dvGap     = inPos ? math.max(peakR - R, 0.0) : 0.0
dvGapPast = nz(dvGap[fadeCoolBars], dvGap)
dvRate    = dvGap - dvGapPast
dvThr     = dvThrK * multBE
if not inPos or dvRate <= dvThr
    dvArmed := true
dvReady   = dvArmed and (bar_index - lastDvBar) >= fadeCoolBars
dvStageLong  = (l1On?1:0) + (l2On?1:0) + (l3On?1:0)
dvStageShort = (s1On?1:0) + (s2On?1:0) + (s3On?1:0)
drawVelTrigLong  = effDrawVel and not exitedThisBar and not blockPartials and inLong  and dvRate > dvThr and dvStageLong  >= 2 and dvReady
drawVelTrigShort = effDrawVel and not exitedThisBar and not blockPartials and inShort and dvRate > dvThr and dvStageShort >= 2 and dvReady
var int dvCuts = 0
if drawVelTrigLong
    float tr = trancheTopLong(l3On, l2On, l1On, notL3, notL2, notL1)
    if tr > 1e-9
        [d, n3, n2, n1, o3, o2, o1] = drainLong(tr, posLive, notL3, notL2, notL1)
        notL3 := n3
        notL2 := n2
        notL1 := n1
        l3On  := o3
        l2On  := o2
        l1On  := o1
        posLive := math.max(posLive - d, 0.0)
        dvCuts += 1
    dvArmed   := false
    lastDvBar := bar_index
if drawVelTrigShort
    float tr = trancheTopShort(s3On, s2On, s1On, notS3, notS2, notS1)
    if tr > 1e-9
        [d, n3, n2, n1, o3, o2, o1] = drainShort(tr, posLive, notS3, notS2, notS1)
        notS3 := n3
        notS2 := n2
        notS1 := n1
        s3On  := o3
        s2On  := o2
        s1On  := o1
        posLive := math.max(posLive - d, 0.0)
        dvCuts += 1
    dvArmed   := false
    lastDvBar := bar_index

// ???箏 E4嚗????EW-I2 頝典偕摨行???Ｗ??憸券嚗oherence 銝?榆?瑞?瑽垢繚???菜嚗?//   ?祆? coherenceDir < coherenceDir[fadeCoolBars](撏抵圾??繚蝯?蝡?銝暑 stage>=2 ?? cutTop ?撅扎?//   ??F2(蟡冽?賊?繚瘞湔?)/G2(R ??繚撟漲??)/H2(瘜Ｗ??游撐??)甇?漱嚗2 ??撠箏漲?孵??矽?援閫??繚蝯?蝡胯?//   ???脫趙嚗e-arm ??coherenceDir ??銝??潛????? fadeCoolBars 璉???coherence/cutTop/fadeCoolBars
//   ?嗆憓?? input?粥 cutTop 銝粥 close_all 蝬剜? stageLive ????璈?銵?[fadeCoolBars] na ???潦?cohDirNow  = inLong ? coherenceLong : inShort ? coherenceShort : 0
cohDirPast = nz(cohDirNow[fadeCoolBars], cohDirNow)
cohDecaying = cohDirNow < cohDirPast
if not inPos or cohDirNow >= cohDirPast
    cohDeRiskArmed := true
cohDeRiskReady = cohDeRiskArmed and (bar_index - lastCohDeRiskBar) >= fadeCoolBars
i2StageLong  = (l1On?1:0) + (l2On?1:0) + (l3On?1:0)
i2StageShort = (s1On?1:0) + (s2On?1:0) + (s3On?1:0)
cohDeRiskTrigLong  = effCohDeRisk and not exitedThisBar and not blockPartials and inLong  and cohDecaying and i2StageLong  >= 2 and cohDeRiskReady
cohDeRiskTrigShort = effCohDeRisk and not exitedThisBar and not blockPartials and inShort and cohDecaying and i2StageShort >= 2 and cohDeRiskReady
var int i2Cuts = 0
if cohDeRiskTrigLong
    float tr = trancheTopLong(l3On, l2On, l1On, notL3, notL2, notL1)
    if tr > 1e-9
        [d, n3, n2, n1, o3, o2, o1] = drainLong(tr, posLive, notL3, notL2, notL1)
        notL3 := n3
        notL2 := n2
        notL1 := n1
        l3On  := o3
        l2On  := o2
        l1On  := o1
        posLive := math.max(posLive - d, 0.0)
        i2Cuts += 1
    cohDeRiskArmed   := false
    lastCohDeRiskBar := bar_index
if cohDeRiskTrigShort
    float tr = trancheTopShort(s3On, s2On, s1On, notS3, notS2, notS1)
    if tr > 1e-9
        [d, n3, n2, n1, o3, o2, o1] = drainShort(tr, posLive, notS3, notS2, notS1)
        notS3 := n3
        notS2 := n2
        notS1 := n1
        s3On  := o3
        s2On  := o2
        s1On  := o1
        posLive := math.max(posLive - d, 0.0)
        i2Cuts += 1
    cohDeRiskArmed   := false
    lastCohDeRiskBar := bar_index

// ???箏 F嚗elowAvg/aboveAvg ?怠惜皜Ⅳ嚗?挾??閮剝?嚗?belowStageLong  = (l1On?1:0) + (l2On?1:0) + (l3On?1:0)
aboveStageShort = (s1On?1:0) + (s2On?1:0) + (s3On?1:0)
belowAvgLong  = useBelowAvg and not exitedThisBar and not blockPartials and inLong  and belowStageLong  >= 2 and close < avgPx - kBuf * atrChand
aboveAvgShort = useBelowAvg and not exitedThisBar and not blockPartials and inShort and aboveStageShort >= 2 and close > avgPx + kBuf * atrChand
if belowAvgLong
    float tr = trancheTopLong(l3On, l2On, l1On, notL3, notL2, notL1)
    if tr > 1e-9
        [d, n3, n2, n1, o3, o2, o1] = drainLong(tr, posLive, notL3, notL2, notL1)
        notL3 := n3
        notL2 := n2
        notL1 := n1
        l3On  := o3
        l2On  := o2
        l1On  := o1
        posLive := math.max(posLive - d, 0.0)
if aboveAvgShort
    float tr = trancheTopShort(s3On, s2On, s1On, notS3, notS2, notS1)
    if tr > 1e-9
        [d, n3, n2, n1, o3, o2, o1] = drainShort(tr, posLive, notS3, notS2, notS1)
        notS3 := n3
        notS2 := n2
        notS1 := n1
        s3On  := o3
        s2On  := o2
        s1On  := o1
        posLive := math.max(posLive - d, 0.0)

// ????????????????????????????????????????????????????????????????????????????
// [P1繚禮10??1 cut-to-flat 撠迂??嚚?游?? ? ?脣銝?湔折?] ????????????????????
//   禮10 隞颱? drain ?典撅文?stage==1)??賣??臭??詨?撅文???0嚗?銝粥 fullExitNow??閮?exitedThisBar??//   銝神 cooldownUntil??臬??寞?(cutS1 閫貊=st1FlipUp嚗1Cond 鈭血 st1FlipUp)鋡怠???0 ?????禮11
//   擐隞?curStage==0 ?斤征? position_size 隞??嗥?????? entry????颯ntrabar
//   stop-and-reverse 撟賡??其?嚗憯?禮14 chk=stageLive==opentrades ??撘耨敺抬??菜葫??璉??蝬?drain
//   敺?暑 stage ??0?? cut-to-flat 鈭辣嚗???fullExitNow 摰?蔭+撖怠??閮?exitedThisBar ?剛楝?祆?
//   ?脣?迨????銝?close(drain 撌脩葬? 0)嚗?鋆???脣撣喳?撠迂?項????drain 頝臬???啣? input??//   [P3] 銝雿菟?蝵?G2/F2/E3/I2 閮??剁?雿踴撟喳摰?蔭????頝臬?(?典像/fullExit/?圈???cut-to-flat)憿臬?????// ????????????????????????????????????????????????????????????????????????????
liveStageLongNow  = (l1On?1:0) + (l2On?1:0) + (l3On?1:0)
liveStageShortNow = (s1On?1:0) + (s2On?1:0) + (s3On?1:0)
openBarInPos      = posSize > 1e-9        // 禮6 璉?撖阡??其?(???禮10 drain 銋??翰??
cutToFlatNow      = not exitedThisBar and openBarInPos and liveStageLongNow == 0 and liveStageShortNow == 0
if cutToFlatNow
    l1On := false
    l2On := false
    l3On := false
    s1On := false
    s2On := false
    s3On := false
    entryRisk := na
    entryPx   := na
    entryBar  := na
    trailExt  := na
    trailStop := na
    tp1Done   := false
    tp2Done   := false
    peakR     := 0.0
    peakBar   := bar_index
    bankedQty := 0.0
    openInitQty := 0.0
    fadeArmed := true
    lastAddBar := -100000
    voteFadeArmed := true
    lastVoteFadeBar := -100000
    dvArmed := true
    lastDvBar := -100000
    cohDeRiskArmed := true             // [I2] cut-to-flat 蝚砍?璇?蝵株楝敺＊撘???    lastCohDeRiskBar := -100000
    notL1 := 0.0
    notL2 := 0.0
    notL3 := 0.0
    notS1 := 0.0
    notS2 := 0.0
    notS3 := 0.0
    posLive := 0.0
    exitedThisBar := true
    float effCooldownCut = effAdaptiveCooldown ? math.max(math.round(cooldownBars * breathClamp), 0) : cooldownBars
    cooldownUntil := bar_index + effCooldownCut

// ????????????????????????????????????????????????????????????????????????????
// 禮11  ?脣嚗?蝛箏?潮??
// ????????????????????????????????????????????????????????????????????????????
canEnter = bar_index >= cooldownUntil and not exitedThisBar
curLongStage  = (l1On?1:0) + (l2On?1:0) + (l3On?1:0)
curShortStage = (s1On?1:0) + (s2On?1:0) + (s3On?1:0)
// [NEW-A2] ?脣???孵榆蝣箄???entryDistOK = not effEntryDistGate or na(st1) or na(atrChand) or atrChand <= 0 or math.abs(close - st1) <= kBuf * atrChand
// [?EW-C2] 銝剖偕摨阡脣蝣箄???midConfirmLongOK  = not effMidConfirm or st2Bull
midConfirmShortOK = not effMidConfirm or st2Bear
// [???EW-H1] DI ?孵榆?蝣箄??脣???孵??孵榆 diSpread 銝?榆???券＊?????diPlus/diMinus 銋?[1]嚗?//   ?脫趙撣嗥 (adxOn?dxOff) 瘣曄?(??G1 ??)??璈?銵?diSlope=?嗅??z(??璉??嗅?)嚗?璉??0??diSlopeHystBand   = diSlopeHystFrac * math.max(adxOn - adxOff, 0.0)
diSpreadLong      = diPlus  - diMinus
diSpreadShort     = diMinus - diPlus
diSlopeLong       = diSpreadLong  - nz(diSpreadLong[1],  diSpreadLong)
diSlopeShort      = diSpreadShort - nz(diSpreadShort[1], diSpreadShort)
diSlopeLongOK     = not effDiSlopeGate or diSlopeLong  >= -diSlopeHystBand
diSlopeShortOK    = not effDiSlopeGate or diSlopeShort >= -diSlopeHystBand
// [????NEW-I1] ST 蝧餉??圈悅摨行??※皜脣??頝?ST1 ?餈蕃頧???N 璉(N=clamp(len1,2,persistBars))??//   ??A2(蝛粹?頝)甇?漱????st1FlipBar+bar_index??閮剝????餅?嚗???擐??flip 閫貊??璉?=0??flipFreshWin   = math.min(math.max(len1, 2), persistBars)
flipFreshOK    = not effFlipFresh or (bar_index - st1FlipBar) <= flipFreshWin
// 擐嚗T1 蝧餃? + regime gate + A2 + C2 + H1 + I1
//   [P2繚cut-to-flat ??瘙⊥??脰風] AND not inPos嚗雿踵璉?禮10 drain ?暑 stage ? 0嚗閬?broker
//     position_size 隞?????鈭支?銝璉???)擐?喃??曇?嚗?蝯?璉?intrabar ??嚗雁霅?禮14 ??撘?l1Cond = curLongStage == 0 and curShortStage == 0 and not inPos and st1FlipUp and regimeLongOK  and canEnter and entryDistOK and midConfirmLongOK  and diSlopeLongOK  and flipFreshOK
s1Cond = curLongStage == 0 and curShortStage == 0 and not inPos and st1FlipDn and regimeShortOK and canEnter and entryDistOK and midConfirmShortOK and diSlopeShortOK and flipFreshOK
// [H1 甇詨?閫皜柵
var int h1BlockedEntries = 0
h1BaseLong  = curLongStage == 0 and curShortStage == 0 and not inPos and st1FlipUp and regimeLongOK  and canEnter and entryDistOK and midConfirmLongOK  and flipFreshOK
h1BaseShort = curLongStage == 0 and curShortStage == 0 and not inPos and st1FlipDn and regimeShortOK and canEnter and entryDistOK and midConfirmShortOK and flipFreshOK
if effDiSlopeGate and ((h1BaseLong and diSlopeLong < -diSlopeHystBand) or (h1BaseShort and diSlopeShort < -diSlopeHystBand))
    h1BlockedEntries += 1
// [I1 甇詨?閫皜柵
var int i1BlockedEntries = 0
i1BaseLong  = curLongStage == 0 and curShortStage == 0 and not inPos and st1FlipUp and regimeLongOK  and canEnter and entryDistOK and midConfirmLongOK  and diSlopeLongOK
i1BaseShort = curLongStage == 0 and curShortStage == 0 and not inPos and st1FlipDn and regimeShortOK and canEnter and entryDistOK and midConfirmShortOK and diSlopeShortOK
if effFlipFresh and (bar_index - st1FlipBar) > flipFreshWin and (i1BaseLong or i1BaseShort)
    i1BlockedEntries += 1
// ?Ⅳ??addCohLongOK  = not effCoherenceAdd or coherenceLong  >= 2
addCohShortOK = not effCoherenceAdd or coherenceShort >= 2
erHystBand    = erHystFrac * erThr
addErAccelOK  = not effErAccelAdd or er >= nz(er[1], er) - erHystBand
addSpaceBase  = math.min(math.max(len1, 2), persistBars)
spaceVolK     = effAddSpaceVol ? math.min(math.max(1.0 + (50.0 - nz(atrPctRank, 50.0)) / 100.0, spcVolLo), spcVolHi) : 1.0
addSpace      = math.min(math.max(math.round(addSpaceBase * spaceVolK), 2), persistBars)
addSpacingOK  = not effAddSpacing or (bar_index - lastAddBar) >= addSpace
adxSlopeHystBand = adxSlopeHystFrac * math.max(adxOn - adxOff, 0.0)
adxSlope         = adx - nz(adx[1], adx)
addAdxSlopeOK    = not effAdxSlopeAdd or adxSlope >= -adxSlopeHystBand
// [????NEW-J2] 撌脰鋡?靘?蝣潮?皜?嚗?蝣澆? AND bankFrac<=bankCapFrac(撌脣祕?曄??雿?蝬剖漲)??//   bankFrac ?Ｘ??芾◤ bankedFloor ?砍?踹??芰?澆?蝣潛?瘚ankCapFrac=1.0=identity 瘞訾???//   ??C1/A3/G1/E3/F1 ?冽迤鈭扎?蝛箏?典?銝 bankFrac???addBankOK        = not effJBankThrottle or bankFrac <= bankCapFrac
addOKLong  = not volBrakeOn and R > 0 and addCohLongOK  and addErAccelOK and addSpacingOK and addAdxSlopeOK and addBankOK
addOKShort = not volBrakeOn and R > 0 and addCohShortOK and addErAccelOK and addSpacingOK and addAdxSlopeOK and addBankOK
// [E3/F1 甇詨?閫皜柵
var int e3BlockedAdds = 0
spacingBlocked = effAddSpacing and (bar_index - lastAddBar) < addSpace
addBaseLong2  = curLongStage == 1 and l1On and inLong  and st2FlipUp and st1Bull and not volBrakeOn and R > 0 and addCohLongOK  and addErAccelOK and addAdxSlopeOK
addBaseLong3  = curLongStage == 2 and l1On and l2On and inLong  and st3FlipUp and st1Bull and st2Bull and not volBrakeOn and R > 0 and addCohLongOK  and addErAccelOK and addAdxSlopeOK
addBaseShort2 = curShortStage == 1 and s1On and inShort and st2FlipDn and st1Bear and not volBrakeOn and R > 0 and addCohShortOK and addErAccelOK and addAdxSlopeOK
addBaseShort3 = curShortStage == 2 and s1On and s2On and inShort and st3FlipDn and st1Bear and st2Bear and not volBrakeOn and R > 0 and addCohShortOK and addErAccelOK and addAdxSlopeOK
if spacingBlocked and (addBaseLong2 or addBaseLong3 or addBaseShort2 or addBaseShort3)
    e3BlockedAdds += 1
// [G1 甇詨?閫皜柵
var int g1BlockedAdds = 0
adxBlocked = effAdxSlopeAdd and adxSlope < -adxSlopeHystBand
g1BaseLong2  = curLongStage == 1 and l1On and inLong  and st2FlipUp and st1Bull and not volBrakeOn and R > 0 and addCohLongOK  and addErAccelOK and addSpacingOK
g1BaseLong3  = curLongStage == 2 and l1On and l2On and inLong  and st3FlipUp and st1Bull and st2Bull and not volBrakeOn and R > 0 and addCohLongOK  and addErAccelOK and addSpacingOK
g1BaseShort2 = curShortStage == 1 and s1On and inShort and st2FlipDn and st1Bear and not volBrakeOn and R > 0 and addCohShortOK and addErAccelOK and addSpacingOK
g1BaseShort3 = curShortStage == 2 and s1On and s2On and inShort and st3FlipDn and st1Bear and st2Bear and not volBrakeOn and R > 0 and addCohShortOK and addErAccelOK and addSpacingOK
if adxBlocked and (g1BaseLong2 or g1BaseLong3 or g1BaseShort2 or g1BaseShort3)
    g1BlockedAdds += 1
// [J2 甇詨?閫皜柵
var int j2BlockedAdds = 0
bankBlocked = effJBankThrottle and bankFrac > bankCapFrac
j2BaseLong2  = curLongStage == 1 and l1On and inLong  and st2FlipUp and st1Bull and not volBrakeOn and R > 0 and addCohLongOK  and addErAccelOK and addSpacingOK and addAdxSlopeOK
j2BaseLong3  = curLongStage == 2 and l1On and l2On and inLong  and st3FlipUp and st1Bull and st2Bull and not volBrakeOn and R > 0 and addCohLongOK  and addErAccelOK and addSpacingOK and addAdxSlopeOK
j2BaseShort2 = curShortStage == 1 and s1On and inShort and st2FlipDn and st1Bear and not volBrakeOn and R > 0 and addCohShortOK and addErAccelOK and addSpacingOK and addAdxSlopeOK
j2BaseShort3 = curShortStage == 2 and s1On and s2On and inShort and st3FlipDn and st1Bear and st2Bear and not volBrakeOn and R > 0 and addCohShortOK and addErAccelOK and addSpacingOK and addAdxSlopeOK
if bankBlocked and (j2BaseLong2 or j2BaseLong3 or j2BaseShort2 or j2BaseShort3)
    j2BlockedAdds += 1
l2Cond = curLongStage == 1 and l1On and inLong  and st2FlipUp and st1Bull and addOKLong
l3Cond = curLongStage == 2 and l1On and l2On and inLong  and st3FlipUp and st1Bull and st2Bull and addOKLong
s2Cond = curShortStage == 1 and s1On and inShort and st2FlipDn and st1Bear and addOKShort
s3Cond = curShortStage == 2 and s1On and s2On and inShort and st3FlipDn and st1Bear and st2Bear and addOKShort

if l1Cond
    strategy.entry("L1", strategy.long, qty=qty1, comment="L1")
    entryRisk := chandMult * atrChand
    entryPx   := close
    trailExt  := high
    trailStop := na
    entryBar  := bar_index
    peakR     := 0.0
    peakBar   := bar_index
    bankedQty := 0.0
    openInitQty := qty1
    fadeArmed := true
    voteFadeArmed := true
    lastVoteFadeBar := -100000
    dvArmed := true
    lastDvBar := -100000
    cohDeRiskArmed := true     // [I2] 頝典偕摨行???Ｚ風甈?蝵??啣甇西?)
    lastCohDeRiskBar := -100000
    lastAddBar := bar_index
    l1On := true
    notL1 := qty1
if l2Cond
    strategy.entry("L2", strategy.long, qty=qty2, comment="L2")
    l2On := true
    notL2 := qty2
    openInitQty := openInitQty + qty2
    lastAddBar := bar_index
if l3Cond
    strategy.entry("L3", strategy.long, qty=qty3, comment="L3")
    l3On := true
    notL3 := qty3
    openInitQty := openInitQty + qty3
    lastAddBar := bar_index
if s1Cond
    strategy.entry("S1", strategy.short, qty=qty1, comment="S1")
    entryRisk := chandMult * atrChand
    entryPx   := close
    trailExt  := low
    trailStop := na
    entryBar  := bar_index
    peakR     := 0.0
    peakBar   := bar_index
    bankedQty := 0.0
    openInitQty := qty1
    fadeArmed := true
    voteFadeArmed := true
    lastVoteFadeBar := -100000
    dvArmed := true
    lastDvBar := -100000
    cohDeRiskArmed := true     // [I2] 頝典偕摨行???Ｚ風甈?蝵??啣甇西?)
    lastCohDeRiskBar := -100000
    lastAddBar := bar_index
    s1On := true
    notS1 := qty1
if s2Cond
    strategy.entry("S2", strategy.short, qty=qty2, comment="S2")
    s2On := true
    notS2 := qty2
    openInitQty := openInitQty + qty2
    lastAddBar := bar_index
if s3Cond
    strategy.entry("S3", strategy.short, qty=qty3, comment="S3")
    s3On := true
    notS3 := qty3
    openInitQty := openInitQty + qty3
    lastAddBar := bar_index

if cap1 or cap2 or cap3
    capHits += 1

stageLive = inLong ? ((l1On?1:0) + (l2On?1:0) + (l3On?1:0)) : inShort ? ((s1On?1:0) + (s2On?1:0) + (s3On?1:0)) : 0

// [NEW-A4] ?詨????拙?蹂?皞飛??蝝閫皜祆改?
floorBE_L    = beActive ? rBasePx + multBE * rDenom : na
floorBE_S    = beActive ? rBasePx - multBE * rDenom : na
floorPeak_L  = peakFloorOn ? rBasePx + (peakR - effGiveback) * rDenom : na
floorPeak_S  = peakFloorOn ? rBasePx - (peakR - effGiveback) * rDenom : na
floorStair_L = tpStairOn ? tpStairFloorL : na
floorStair_S = tpStairOn ? tpStairFloorS : na
floorBank_L  = bankedFloorOn ? bankedFloorL : na
floorBank_S  = bankedFloorOn ? bankedFloorS : na
var string activeFloorTxt = "??
activeFloorTxt := "??
if inPos
    float best = na
    string src = "蝝rail"
    if inLong
        if not na(floorBE_L) and (na(best) or floorBE_L > best)
            best := floorBE_L
            src  := "BE靽"
        if not na(floorStair_L) and (na(best) or floorStair_L > best)
            best := floorStair_L
            src  := "?０?唳"
        if not na(floorBank_L) and (na(best) or floorBank_L > best)
            best := floorBank_L
            src  := "撌脣祕?暸"
        if not na(floorPeak_L) and (na(best) or floorPeak_L > best)
            best := floorPeak_L
            src  := "撜啣?撟湧翩??"
    else
        if not na(floorBE_S) and (na(best) or floorBE_S < best)
            best := floorBE_S
            src  := "BE靽"
        if not na(floorStair_S) and (na(best) or floorStair_S < best)
            best := floorStair_S
            src  := "?０?唳"
        if not na(floorBank_S) and (na(best) or floorBank_S < best)
            best := floorBank_S
            src  := "撌脣祕?暸"
        if not na(floorPeak_S) and (na(best) or floorPeak_S < best)
            best := floorPeak_S
            src  := "撜啣?撟湧翩??"
    activeFloorTxt := src

// ????????????????????????????????????????????????????????????????????????????
// 禮12  閬死???典 global scope嚗?// ????????????????????????????????????????????????????????????????????????????
c1 = st1Bull ? color.new(color.green, 0)  : color.new(color.red, 0)
c2 = st2Bull ? color.new(color.green, 30) : color.new(color.red, 30)
c3 = st3Bull ? color.new(color.green, 55) : color.new(color.red, 55)
plot(showST ? st1 : na, "ST1", color=c1, linewidth=1)
plot(showST ? st2 : na, "ST2", color=c2, linewidth=1)
plot(showST ? st3 : na, "ST3", color=c3, linewidth=2)
plot(showAvg and stageLive >= 1 ? avgPx : na, "AvgCost", color=color.new(color.yellow, 0), linewidth=1, style=plot.style_linebr)
plot(showStop and inPos ? trailStop : na, "TrailStop", color=color.new(color.orange, 0), linewidth=1, style=plot.style_linebr)

bgReg = showBg and regimeOn ? (dirLong ? color.new(color.green, 93) : color.new(color.red, 93)) : na
bgStg = showBg and inPos ? (inLong ? color.new(color.teal, 90 - stageLive * 6) : color.new(color.maroon, 90 - stageLive * 6)) : na
bgcolor(na(bgStg) ? bgReg : bgStg)

plotshape(showSignals and l1Cond, "L1", shape.triangleup,   location.belowbar, color.new(color.lime, 0),   size=size.tiny,   text="L1")
plotshape(showSignals and l2Cond, "L2", shape.triangleup,   location.belowbar, color.new(color.green, 0),  size=size.small,  text="L2")
plotshape(showSignals and l3Cond, "L3", shape.triangleup,   location.belowbar, color.new(color.teal, 0),   size=size.normal, text="L3")
plotshape(showSignals and s1Cond, "S1", shape.triangledown, location.abovebar, color.new(color.orange, 0), size=size.tiny,   text="S1")
plotshape(showSignals and s2Cond, "S2", shape.triangledown, location.abovebar, color.new(color.red, 0),    size=size.small,  text="S2")
plotshape(showSignals and s3Cond, "S3", shape.triangledown, location.abovebar, color.new(color.maroon, 0), size=size.normal, text="S3")
tpAny  = tpHitL1 or tpHitL2 or tpHitS1 or tpHitS2
cutAny = cutL1 or cutL2 or cutS1 or cutS2
// fade 璅?瘨菔????箏?游憸券??regime-fade + F2 + G2 + I2
fadeAny= regimeFadeLong or regimeFadeShort or voteFadeTrigLong or voteFadeTrigShort or drawVelTrigLong or drawVelTrigShort or cohDeRiskTrigLong or cohDeRiskTrigShort
plotshape(showSignals and tpAny,  "TP",   shape.circle,   location.abovebar, color.new(color.aqua, 0),   size=size.tiny, text="TP")
plotshape(showSignals and cutAny, "Cut",  shape.diamond,  location.abovebar, color.new(color.purple, 0), size=size.tiny, text="cut")
plotshape(showSignals and fadeAny,"Fade", shape.xcross,   location.belowbar, color.new(color.fuchsia, 0),size=size.tiny, text="fade")
fullExitMark = trailHitLong or trailHitShort or twoSTRevLong or twoSTRevShort or timeStopLong or timeStopShort or brokerStopHit
plotshape(showSignals and fullExitMark, "OUT", shape.xcross, location.abovebar, color.new(color.red, 0), size=size.tiny, text="X")

// ????????????????????????????????????????????????????????????????????????????
